-- ── Send chat message ─────────────────────────────────────

local function sendMessage(message)
    print("[ChatCmd] Attempting to send:", message)

    -- ── NEW TextChatService path ──────────────────────────
    if usingNewChat then
        local channels = TextChatService:FindFirstChild("TextChannels")
        if channels then
            for _, ch in ipairs(channels:GetChildren()) do
                if ch:IsA("TextChannel") then
                    local ok, err = pcall(function()
                        ch:SendAsync(message)
                    end)
                    if ok then
                        print("[ChatCmd] ✓ Sent via TextChannel:", ch.Name)
                        return true
                    else
                        print("[ChatCmd] ✗ Channel", ch.Name, "failed:", err)
                    end
                end
            end
        else
            print("[ChatCmd] ✗ TextChannels not found under TextChatService")
        end
    end

    -- ── LEGACY chat: SayMessageRequest ───────────────────
    local ok1, err1 = pcall(function()
        local events = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
        if not events then error("DefaultChatSystemChatEvents not found") end
        local sayReq = events:FindFirstChild("SayMessageRequest")
        if not sayReq then error("SayMessageRequest not found") end
        sayReq:FireServer(message, "All")
    end)
    if ok1 then
        print("[ChatCmd] ✓ Sent via SayMessageRequest (legacy)")
        return true
    else
        print("[ChatCmd] ✗ SayMessageRequest failed:", err1)
    end

    -- ── LEGACY chat: LocalPlayer:Chat() ──────────────────
    local ok2, err2 = pcall(function()
        LocalPlayer:Chat(message)
    end)
    if ok2 then
        print("[ChatCmd] ✓ Sent via LocalPlayer:Chat()")
        return true
    else
        print("[ChatCmd] ✗ LocalPlayer:Chat() failed:", err2)
    end

    -- ── Bubble-only fallback (visual only, won't fire server cmds) ──
    local ok3, err3 = pcall(function()
        local BubbleSvc = game:GetService("Chat")
        local char = LocalPlayer.Character
        if not char then error("No character") end
        BubbleSvc:Chat(char:FindFirstChild("Head") or char.PrimaryPart, message, Enum.ChatColor.White)
    end)
    if ok3 then
        print("[ChatCmd] ⚠ BubbleChat only — visual, may not trigger server commands")
        return true
    else
        print("[ChatCmd] ✗ BubbleChat failed:", err3)
    end

    print("[ChatCmd] ✗ ALL METHODS FAILED — press F9 to open Output for details")
    return false
end

-- ── Open / Close ──────────────────────────────────────────

local isOpen   = false
local tweenIn  = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local tweenOut = TweenInfo.new(0.10, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

local function openBar()
    if isOpen then return end
    isOpen = true
    StatusLabel.Text = ""
    TextBox.Text = ""
    Frame.Position = UDim2.new(0.5, -260, 1, -80)
    Frame.Visible  = true
    TweenService:Create(Frame, tweenIn, { Position = UDim2.new(0.5, -260, 1, -100) }):Play()
    task.defer(function() TextBox:CaptureFocus() end)
end

local function closeBar()
    if not isOpen then return end
    isOpen = false
    local t = TweenService:Create(Frame, tweenOut, { Position = UDim2.new(0.5, -260, 1, -80) })
    t:Play()
    t.Completed:Connect(function() Frame.Visible = false end)
    TextBox:ReleaseFocus()
end

local function flashStatus(msg, success)
    StatusLabel.TextColor3 = success
        and Color3.fromRGB(80, 220, 120)
        or  Color3.fromRGB(255, 90, 90)
    StatusLabel.Text = msg
    task.delay(2.5, function() StatusLabel.Text = "" end)
end

-- ── Keybinds ──────────────────────────────────────────────

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Semicolon then
        if isOpen then closeBar() else openBar() end
    end
    if input.KeyCode == Enum.KeyCode.Escape and isOpen then
        closeBar()
    end
end)

TextBox.FocusLost:Connect(function(enterPressed)
    if not enterPressed then return end
    local msg = TextBox.Text:match("^%s*(.-)%s*$")
    if msg == "" then closeBar(); return end

    local ok = sendMessage(msg)
    if ok then
        flashStatus("✓ Sent: " .. msg, true)
    else
        flashStatus("✗ Failed — press F9 and check Output for details", false)
    end
    closeBar()
end)

print("[ChatCmd] Ready — Press [;] to open | Chat system:", usingNewChat and "NEW" or "LEGACY")
