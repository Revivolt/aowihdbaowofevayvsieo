local SEND_KEY     = Enum.KeyCode.Return  -- key to send
local CLOSE_KEY    = Enum.KeyCode.Escape  -- key to cancel
local CHAT_CHANNEL = "All"               -- chat channel target
-- ──────────────────────────────────────────────────────────


