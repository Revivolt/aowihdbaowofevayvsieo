-- ── Chat Sender ───────────────────────────────────────────

local function sendChatMessage(message)
    if not message or message == "" then return false end

    -- Method 1: DefaultChatSystemChatEvents (works on most Roblox games)
    local success1, err1 = pcall(function()
        local chatEvents = ReplicatedStorage:WaitForChild("DefaultChatSystemChatEvents", 3)
        if chatEvents then
            local sayRequest = chatEvents:WaitForChild("SayMessageRequest", 3)
            if sayRequest then
                sayRequest:FireServer(message, CHAT_CHANNEL)
            end
        end
    end)

    if success1 then return true end

    -- Method 2: Fallback – use the deprecated LocalPlayer:Chat() (still works in some games)
    local success2, err2 = pcall(function()
        LocalPlayer:Chat(message)
    end)

    if success2 then return true end

    -- Method 3: Try TextChatService (newer Roblox chat system)
    local success3, err3 = pcall(function()
        local TextChatService = game:GetService("TextChatService")
        local channels = TextChatService:WaitForChild("TextChannels", 3)
        if channels then
            local general = channels:FindFirstChild("RBXGeneral")
            if general then
                general:SendAsync(message)
            end
        end
    end)

    if success3 then return true end

    return false -- all methods failed
end

-- ──────────────────────────────────────────────────────────


-- ── Open / Close helpers ──────────────────────────────────

local isOpen = false
local tweenInfo = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function openBar()
    if isOpen then return end
    isOpen = true
    Frame.Visible = true
    TextBox.Text = ""
    HintLabel.Text = ""
    -- Animate in (slide up)
    Frame.Position = UDim2.new(0.5, -250, 1, -70)
    local t = TweenService:Create(Frame, tweenInfo, {
        Position = UDim2.new(0.5, -250, 1, -90)
    })
    t:Play()
    task.defer(function() TextBox:CaptureFocus() end)
end

local function closeBar(clearText)
    if not isOpen then return end
    isOpen = false
    if clearText then TextBox.Text = "" end
    -- Animate out
    local t = TweenService:Create(Frame, tweenInfo, {
        Position = UDim2.new(0.5, -250, 1, -70)
    })
    t:Play()
    t.Completed:Wait()
    Frame.Visible = false
    TextBox:ReleaseFocus()
end

local function flashHint(msg, color)
    HintLabel.TextColor3 = color or Color3.fromRGB(80, 200, 120)
    HintLabel.Text = msg
    task.delay(2, function()
        HintLabel.Text = ""
    end)
end

-- ──────────────────────────────────────────────────────────


-- ── Input Handling ────────────────────────────────────────

-- Toggle bar open with [/]
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- Don't trigger if already typing in something else
    if gameProcessed then return end

    if input.KeyCode == TOGGLE_KEY then
        if isOpen then
            closeBar(true)
        else
            openBar()
        end
    end
end)

-- Send on Enter, cancel on Escape (while TextBox is focused)
TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local msg = TextBox.Text:match("^%s*(.-)%s*$")  -- trim whitespace
        if msg ~= "" then
            local ok = sendChatMessage(msg)
            if ok then
                flashHint("✓  Sent: " .. msg, Color3.fromRGB(80, 200, 120))
            else
                flashHint("✗  Could not send (chat may be restricted)", Color3.fromRGB(255, 100, 100))
            end
            task.delay(0.8, function() closeBar(true) end)
        else
            closeBar(true)
        end
    end
end)

-- Capture Escape to close without sending
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == CLOSE_KEY and isOpen then
        closeBar(true)
    end
end)

-- Also allow pressing [/] inside the textbox to not re-trigger toggle
TextBox:GetPropertyChangedSignal("Text"):Connect(function()
    -- Prevent the slash key itself from appearing in the box when opening
    if TextBox.Text == "m" then
        TextBox.Text = ""
        TextBox.CursorPosition = 1
    end
end)

