-- CONFIG
-----------------------------

-- DEFAULT ANIMS
local TRANSFORMATION_ID = 112109141479594
local IDLE_ID = 0
local WALK_ID = 118320322718866
local SPRINT_ID = 76931637880681
local JUMP_ID = 119889021060156
local FALL_ID = 119889021060156
local M1_ID = 119889021060156

-- ALT ANIMS (TOGGLES)
local ALT_IDLE_ID = 130432219266930 -- G
local ALT_WALK_ID = 82598234841035 -- H
local ALT_SPRINT_ID = 82598234841035 -- J
local ALT_JUMP_ID = 110340154189809 -- K
local ALT_FALL_ID = 0 -- I
local ALT_M1_ID = 0 -- L

-- EMOTES (movement cancels)
local EMOTE_T_ID = 93334432462341
local EMOTE_Y_ID = 130070387700656
local EMOTE_U_ID = 91255053058083

-- TIMING
local TRANSFORMATION_DURATION = 5

-- MOVEMENT SPEEDS
local BASE_WALK_SPEED = 100
local SPRINT_SPEED = 300

-- Animation Playback Speeds
local TRANSFORM_ANIM_SPEED = 1
local IDLE_ANIM_SPEED = 1
local WALK_ANIM_SPEED = 0.7
local SPRINT_ANIM_SPEED = 1
local JUMP_ANIM_SPEED = 10
local FALL_ANIM_SPEED = 10
local M1_ANIM_SPEED = 10
local M1_LOOP = true -- If true, holding left click loops the animation. If false, each click plays it once.

-----------------------------
-- SERVICES
-----------------------------
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Player = player
local mouse = player:GetMouse()

-----------------------------
-- CHARACTER
-----------------------------
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local animator = humanoid:WaitForChild("Animator")
humanoid.AutoRotate = true

-----------------------------
-- STATE
-----------------------------
local transformed = false
local sprinting = false
local m1Held = false
local currentState = "None"

local useAltIdle = false
local useAltWalk = false
local useAltSprint = false
local useAltJump = false
local useAltFall = false
local useAltM1 = false

-- Track reload detection
local lastUseAltIdle = false
local lastUseAltWalk = false
local lastUseAltSprint = false

local idleTrack, walkTrack, sprintTrack, jumpTrack, fallTrack
local transformationTrack
local actionTrack
local emoteTrack

-----------------------------
-- HELPERS
-----------------------------
local function isValidId(id)
	return typeof(id) == "number" and id > 0
end

local function loadAnimation(assetId, looped, priority)
	if not isValidId(assetId) then return nil end
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. assetId
	local track = animator:LoadAnimation(anim)
	track.Looped = looped
	track.Priority = priority
	return track
end

local function destroyTrack(track)
	if track then
		track:Stop()
		track:Destroy()
	end
end

-----------------------------
-- SKID FLING
-----------------------------
local function SkidFling(TargetPlayer)

	local Character = Player.Character
	local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
	local RootPart = Humanoid and Humanoid.RootPart

	local TCharacter = TargetPlayer.Character
	if not TCharacter then return end

	local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
	local TRootPart = THumanoid and THumanoid.RootPart
	local THead = TCharacter:FindFirstChild("Head")

	if not (Character and Humanoid and RootPart and THumanoid) then return end

	getgenv().OldPos = RootPart.CFrame

	local function FPos(BasePart, Pos, Ang)
		RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
		Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
		RootPart.Velocity = Vector3.new(9e7,9e7,9e7)
		RootPart.RotVelocity = Vector3.new(9e8,9e8,9e8)
	end

	local function SFBasePart(BasePart)
		local TimeToWait = 2
		local Time = tick()
		local Angle = 0

		repeat
			Angle += 100

			FPos(BasePart,CFrame.new(0,1.5,0),CFrame.Angles(math.rad(Angle),0,0))
			task.wait()

			FPos(BasePart,CFrame.new(0,-1.5,0),CFrame.Angles(math.rad(Angle),0,0))
			task.wait()

		until BasePart.Velocity.Magnitude > 500
		or BasePart.Parent ~= TargetPlayer.Character
		or tick() > Time + TimeToWait
	end

	local BV = Instance.new("BodyVelocity")
	BV.Parent = RootPart
	BV.Velocity = Vector3.new(9e8,9e8,9e8)
	BV.MaxForce = Vector3.new(math.huge,math.huge,math.huge)

	if TRootPart then
		SFBasePart(TRootPart)
	elseif THead then
		SFBasePart(THead)
	end

	BV:Destroy()
	workspace.CurrentCamera.CameraSubject = Humanoid

	repeat
		RootPart.CFrame = getgenv().OldPos
		Humanoid:ChangeState("GettingUp")
		task.wait()
	until (RootPart.Position - getgenv().OldPos.Position).Magnitude < 25
end

-----------------------------
-- ACTION STOP
-----------------------------
local function stopAction()
	if actionTrack then
		destroyTrack(actionTrack)
		actionTrack = nil
	end
end

local function stopEmote()
	if emoteTrack then
		destroyTrack(emoteTrack)
		emoteTrack = nil
	end
end

-----------------------------
-- MOVEMENT STATES
-----------------------------
local function playIdle()
	if not transformed or currentState == "Idle" or emoteTrack then return end

	currentState = "Idle"

	destroyTrack(walkTrack); walkTrack = nil
	destroyTrack(sprintTrack); sprintTrack = nil

	local animId = (useAltIdle and isValidId(ALT_IDLE_ID)) and ALT_IDLE_ID or IDLE_ID

	destroyTrack(idleTrack)
	idleTrack = loadAnimation(animId, true, Enum.AnimationPriority.Movement)

	if idleTrack then
		idleTrack:Play()
		idleTrack:AdjustSpeed(IDLE_ANIM_SPEED)
	end
end

local function playWalk()
	if not transformed or currentState == "Walk" or sprinting or emoteTrack then return end

	currentState = "Walk"

	destroyTrack(idleTrack); idleTrack = nil
	destroyTrack(sprintTrack); sprintTrack = nil

	local animId = (useAltWalk and isValidId(ALT_WALK_ID)) and ALT_WALK_ID or WALK_ID

	destroyTrack(walkTrack)
	walkTrack = loadAnimation(animId, true, Enum.AnimationPriority.Movement)

	if walkTrack then
		walkTrack:Play()
		walkTrack:AdjustSpeed(WALK_ANIM_SPEED * humanoid.WalkSpeed / BASE_WALK_SPEED)
	end
end

local function playSprint()
	if not transformed or currentState == "Sprint" or emoteTrack then return end

	currentState = "Sprint"

	destroyTrack(idleTrack); idleTrack = nil
	destroyTrack(walkTrack); walkTrack = nil

	local animId = (useAltSprint and isValidId(ALT_SPRINT_ID)) and ALT_SPRINT_ID or SPRINT_ID

	destroyTrack(sprintTrack)
	sprintTrack = loadAnimation(animId, true, Enum.AnimationPriority.Movement)

	if sprintTrack then
		sprintTrack:Play()
		sprintTrack:AdjustSpeed(SPRINT_ANIM_SPEED * humanoid.WalkSpeed / BASE_WALK_SPEED)
	end
end

local function playJump()
	if not transformed then return end

	local animId = (useAltJump and isValidId(ALT_JUMP_ID)) and ALT_JUMP_ID or JUMP_ID
	if not isValidId(animId) then return end

	-- Stop movement animations while jumping
	destroyTrack(idleTrack); idleTrack = nil
	destroyTrack(walkTrack); walkTrack = nil
	destroyTrack(sprintTrack); sprintTrack = nil

	currentState = "Jump"

	destroyTrack(jumpTrack)
	jumpTrack = loadAnimation(animId, false, Enum.AnimationPriority.Action)

	if jumpTrack then
		jumpTrack:Play()
		jumpTrack:AdjustSpeed(JUMP_ANIM_SPEED)
	end
end

local function playFall()
	if not transformed then return end

	local animId = (useAltFall and isValidId(ALT_FALL_ID)) and ALT_FALL_ID or FALL_ID
	if not isValidId(animId) then return end

	-- Stop movement animations while falling
	destroyTrack(idleTrack); idleTrack = nil
	destroyTrack(walkTrack); walkTrack = nil
	destroyTrack(sprintTrack); sprintTrack = nil
	destroyTrack(jumpTrack); jumpTrack = nil

	currentState = "Fall"

	destroyTrack(fallTrack)
	fallTrack = loadAnimation(animId, true, Enum.AnimationPriority.Action)

	if fallTrack then
		fallTrack:Play()
		fallTrack:AdjustSpeed(FALL_ANIM_SPEED)
	end
end

-----------------------------
-- M1
-----------------------------
local function playM1()
	stopAction()

	local animId = (useAltM1 and isValidId(ALT_M1_ID)) and ALT_M1_ID or M1_ID
	if not isValidId(animId) then return end

	if M1_LOOP then
		-- Loop mode: play looped, keep going while held
		actionTrack = loadAnimation(animId, true, Enum.AnimationPriority.Action)
		if actionTrack then
			actionTrack:Play()
			actionTrack:AdjustSpeed(M1_ANIM_SPEED)
		end
	else
		-- Single-shot mode: play once, then chain if still held
		actionTrack = loadAnimation(animId, false, Enum.AnimationPriority.Action)
		if actionTrack then
			actionTrack:Play()
			actionTrack:AdjustSpeed(M1_ANIM_SPEED)
			actionTrack.Stopped:Connect(function()
				destroyTrack(actionTrack)
				actionTrack = nil
				if m1Held then
					playM1()
				end
			end)
		end
	end
end

-----------------------------
-- LOOP EMOTE
-----------------------------
local function playLoopEmote(assetId)
	if not isValidId(assetId) then return end
	stopEmote()
	emoteTrack = loadAnimation(assetId, true, Enum.AnimationPriority.Action)
	if emoteTrack then emoteTrack:Play() end
end

-----------------------------
-- REFRESH
-----------------------------
local function refreshState()
	if not transformed then return end
	if emoteTrack then return end

	-- Reload if toggle changed
	if lastUseAltIdle ~= useAltIdle or
	   lastUseAltWalk ~= useAltWalk or
	   lastUseAltSprint ~= useAltSprint then
		currentState = "None"
	end

	lastUseAltIdle = useAltIdle
	lastUseAltWalk = useAltWalk
	lastUseAltSprint = useAltSprint

	local speed = humanoid.MoveDirection.Magnitude

	if speed > 0.1 then
		if sprinting then playSprint() else playWalk() end
	else
		playIdle()
	end
end

-----------------------------
-- TRANSFORMATION
-----------------------------
local function playTransformation()
	if isValidId(TRANSFORMATION_ID) then
		transformationTrack = loadAnimation(TRANSFORMATION_ID, false, Enum.AnimationPriority.Movement)
		if transformationTrack then
			transformationTrack:Play()
			transformationTrack:AdjustSpeed(TRANSFORM_ANIM_SPEED)
		end
	end

	transformed = true
	humanoid.WalkSpeed = BASE_WALK_SPEED

	task.delay(TRANSFORMATION_DURATION, refreshState)
end

-----------------------------
-- INPUT
-----------------------------
UserInputService.InputBegan:Connect(function(input, gp)
	if gp or not transformed then return end

	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = true
		humanoid.WalkSpeed = SPRINT_SPEED
	end

	if input.KeyCode == Enum.KeyCode.T then
		playLoopEmote(EMOTE_T_ID)
	elseif input.KeyCode == Enum.KeyCode.Y then
		playLoopEmote(EMOTE_Y_ID)
	elseif input.KeyCode == Enum.KeyCode.U then
		playLoopEmote(EMOTE_U_ID)
	end

	-- Toggle keys
	if input.KeyCode == Enum.KeyCode.H then
		useAltWalk = not useAltWalk
		refreshState()
	elseif input.KeyCode == Enum.KeyCode.J then
		useAltSprint = not useAltSprint
		refreshState()
	elseif input.KeyCode == Enum.KeyCode.G then
		useAltIdle = not useAltIdle
		refreshState()
	elseif input.KeyCode == Enum.KeyCode.K then
		useAltJump = not useAltJump
	elseif input.KeyCode == Enum.KeyCode.I then
		useAltFall = not useAltFall
	elseif input.KeyCode == Enum.KeyCode.L then
		useAltM1 = not useAltM1
	end

	if input.UserInputType == Enum.UserInputType.MouseButton1 then
	m1Held = true
	playM1()

	local target = mouse.Target
	if target then
		local character = target:FindFirstAncestorOfClass("Model")
		if character then
			local targetPlayer = Players:GetPlayerFromCharacter(character)
			if targetPlayer and targetPlayer ~= player then
				SkidFling(targetPlayer)
			end
		end
	end
end
end)

UserInputService.InputEnded:Connect(function(input)
	if not transformed then return end
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = false
		humanoid.WalkSpeed = BASE_WALK_SPEED
	end
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		m1Held = false
		stopAction()
	end
end)

-----------------------------
-- MOVEMENT
-----------------------------
humanoid.Running:Connect(function(speed)
	if not transformed then return end

	if speed > 0 and emoteTrack then
		stopEmote()
	end

	refreshState()
end)

humanoid.StateChanged:Connect(function(_, new)
	if not transformed then return end

	if new == Enum.HumanoidStateType.Jumping then
		playJump()

	elseif new == Enum.HumanoidStateType.Freefall then
		playFall()

	elseif new == Enum.HumanoidStateType.Landed then
		destroyTrack(jumpTrack)
		jumpTrack = nil
		destroyTrack(fallTrack)
		fallTrack = nil
		currentState = "None"
		refreshState()
	end
end)

-----------------------------
-- START
-----------------------------
playTransformation()
