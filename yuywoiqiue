--// test2

-----------------------------
-- CONFIG
-----------------------------

-- DEFAULT ANIMATIONS
local TRANSFORMATION_ID = 0
local IDLE_ID = 130128432111327
local WALK_ID = 99498309796580
local SPRINT_ID = 70636286183373
local JUMP_ID = 0
local M1_ID = 121573002971812

-- ALTERNATE ANIMATIONS
local ALT_IDLE_ID = 0
local ALT_WALK_ID = 0
local ALT_SPRINT_ID = 0
local ALT_JUMP_ID = 0
local ALT_M1_ID = 73468073017890

-- EMOTES (movement cancels)
local EMOTE_T_ID = 0
local EMOTE_Y_ID = 0
local EMOTE_U_ID = 0

-- TIMING
local TRANSFORMATION_DURATION = 0

-- MOVEMENT SPEEDS
local BASE_WALK_SPEED = 16
local SPRINT_SPEED = 28

-- ANIMATION SPEEDS
local TRANSFORM_ANIM_SPEED = 1
local IDLE_ANIM_SPEED = 1
local WALK_ANIM_SPEED = 1
local SPRINT_ANIM_SPEED = 1.2
local JUMP_ANIM_SPEED = 1
local M1_ANIM_SPEED = 1

-----------------------------
-- SERVICES
-----------------------------

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local animator = humanoid:WaitForChild("Animator")

-----------------------------
-- STATE VARIABLES
-----------------------------

local transformed = false
local sprinting = false

local useAltWalk = false
local useAltSprint = false
local useAltIdle = false
local useAltJump = false
local useAltM1 = false

local movementTrack -- for Idle / Walk / Sprint / Jump
local actionTrack   -- for M1 / Emotes
local emoteTrack
local actionLocked = false

-----------------------------
-- SAFETY CHECK
-----------------------------

local function isValidId(id)
	return typeof(id) == "number" and id > 0
end

-----------------------------
-- PLAY ANIMATIONS
-----------------------------

local function playMovementAnimation(assetId, looped, speed)
	if not isValidId(assetId) then return end

	if movementTrack then
		movementTrack:Stop()
		movementTrack:Destroy()
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. tostring(assetId)

	movementTrack = animator:LoadAnimation(anim)
	movementTrack.Priority = Enum.AnimationPriority.Movement
	movementTrack.Looped = looped
	movementTrack:Play()

	if speed then
		movementTrack:AdjustSpeed(speed)
	end
end

local function playActionAnimation(assetId, speed)
	if not isValidId(assetId) then return end

	if actionTrack then
		actionTrack:Stop()
		actionTrack:Destroy()
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. tostring(assetId)

	actionTrack = animator:LoadAnimation(anim)
	actionTrack.Priority = Enum.AnimationPriority.Action
	actionTrack.Looped = false
	actionTrack:Play()

	if speed then
		actionTrack:AdjustSpeed(speed)
	end

	actionTrack.Stopped:Connect(function()
		actionTrack:Destroy()
		actionTrack = nil
	end)
end

local function stopEmote()
	if emoteTrack then
		emoteTrack:Stop()
		emoteTrack:Destroy()
		emoteTrack = nil
	end
end

-----------------------------
-- STATE FUNCTIONS
-----------------------------

local function playIdle()
	if emoteTrack or actionLocked then return end
	local idleAnim = IDLE_ID
	if useAltIdle and isValidId(ALT_IDLE_ID) then idleAnim = ALT_IDLE_ID end
	playMovementAnimation(idleAnim, true, IDLE_ANIM_SPEED)
end

local function playWalk()
	if emoteTrack or actionLocked then return end
	local walkAnim = WALK_ID
	if useAltWalk and isValidId(ALT_WALK_ID) then walkAnim = ALT_WALK_ID end
	playMovementAnimation(walkAnim, true, WALK_ANIM_SPEED)
end

local function playSprint()
	if emoteTrack or actionLocked then return end
	local sprintAnim = SPRINT_ID
	if useAltSprint and isValidId(ALT_SPRINT_ID) then sprintAnim = ALT_SPRINT_ID end
	playMovementAnimation(sprintAnim, true, SPRINT_ANIM_SPEED)
end

local function playJump()
	actionLocked = true
	local jumpAnim = JUMP_ID
	if useAltJump and isValidId(ALT_JUMP_ID) then jumpAnim = ALT_JUMP_ID end
	playMovementAnimation(jumpAnim, false, JUMP_ANIM_SPEED)
end

local function playM1()
	local m1Anim = M1_ID
	if useAltM1 and isValidId(ALT_M1_ID) then m1Anim = ALT_M1_ID end
	if not isValidId(m1Anim) then return end

	actionLocked = true
	stopEmote()
	playActionAnimation(m1Anim, M1_ANIM_SPEED)

	task.delay(1, function()
		actionLocked = false
		refreshState()
	end)
end

local function playLoopEmote(assetId)
	if not isValidId(assetId) then return end
	stopEmote()

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. tostring(assetId)

	emoteTrack = animator:LoadAnimation(anim)
	emoteTrack.Priority = Enum.AnimationPriority.Action
	emoteTrack.Looped = true
	emoteTrack:Play()
end

-----------------------------
-- STATE REFRESH
-----------------------------

function refreshState()
	if not transformed then return end
	if actionLocked then return end
	if emoteTrack then return end

	if humanoid:GetState() == Enum.HumanoidStateType.Freefall then
		return
	end

	if humanoid.MoveDirection.Magnitude > 0 then
		if sprinting then
			playSprint()
		else
			playWalk()
		end
	else
		playIdle()
	end
end

-----------------------------
-- TRANSFORMATION
-----------------------------

local function playTransformation()
	if isValidId(TRANSFORMATION_ID) then
		playMovementAnimation(TRANSFORMATION_ID, false, TRANSFORM_ANIM_SPEED)
	end

	transformed = true
	humanoid.WalkSpeed = BASE_WALK_SPEED

	task.delay(TRANSFORMATION_DURATION, function()
		if transformed then
			refreshState()
		end
	end)
end

-----------------------------
-- EVENTS
-----------------------------

humanoid.Running:Connect(function()
	refreshState()
end)

humanoid.StateChanged:Connect(function(_, new)
	if not transformed then return end
	if new == Enum.HumanoidStateType.Jumping then
		playJump()
	elseif new == Enum.HumanoidStateType.Landed then
		actionLocked = false
		refreshState()
	end
end)

-----------------------------
-- INPUT
-----------------------------

UserInputService.InputBegan:Connect(function(input, gp)
	if gp or not transformed then return end

	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = true
		humanoid.WalkSpeed = SPRINT_SPEED
	end

	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		playM1()
	end

	-- Toggle alternates
	if input.KeyCode == Enum.KeyCode.G then useAltWalk = not useAltWalk end
	if input.KeyCode == Enum.KeyCode.H then useAltSprint = not useAltSprint end
	if input.KeyCode == Enum.KeyCode.J then useAltIdle = not useAltIdle end
	if input.KeyCode == Enum.KeyCode.K then useAltJump = not useAltJump end
	if input.KeyCode == Enum.KeyCode.L then useAltM1 = not useAltM1 end

	-- Loop emotes
	if input.KeyCode == Enum.KeyCode.T then playLoopEmote(EMOTE_T_ID) end
	if input.KeyCode == Enum.KeyCode.Y then playLoopEmote(EMOTE_Y_ID) end
	if input.KeyCode == Enum.KeyCode.U then playLoopEmote(EMOTE_U_ID) end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = false
		humanoid.WalkSpeed = BASE_WALK_SPEED
		refreshState()
	end
end)

-----------------------------
-- START
-----------------------------

playTransformation()
