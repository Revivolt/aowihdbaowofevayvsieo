-- ============================================================
-- ENTRY / CAPTURE LOGIC
-- ============================================================
local captured = 0
local seen = {}

local function setStatus(msg) statusLbl.Text = msg end
local function flashStatus(msg)
    setStatus(msg)
    task.delay(2.5, function() setStatus("Listening…") end)
end

local function addEntry(animId)
    local id = numId(animId)
    if seen[id] then flashStatus("Already captured · " .. id) return end

    seen[id] = true
    captured += 1
    emptyLbl.Visible = false
    countLbl.Text = captured .. " captured"
    setStatus("Fetching name…")

    -- Row
    local row = Instance.new("Frame")
    row.LayoutOrder = captured
    row.Size = UDim2.new(1,0,0,46)
    row.BackgroundColor3 = W; row.BackgroundTransparency = 0.93
    row.BorderSizePixel = 0; row.Parent = sf
    corner(row, 7)
    stroke(row, 0.88)

    -- Left accent line
    local acc = Instance.new("Frame")
    acc.Size = UDim2.new(0,2,1,-12)
    acc.Position = UDim2.new(0,0,0,6)
    acc.BackgroundColor3 = C(180,180,180)
    acc.BackgroundTransparency = 0.55
    acc.BorderSizePixel = 0; acc.Parent = row
    corner(acc, 2)

    -- Index number
    local idx = Instance.new("TextLabel")
    idx.Size = UDim2.new(0,18,0,18)
    idx.Position = UDim2.new(0,8,0.5,-9)
    idx.BackgroundColor3 = W; idx.BackgroundTransparency = 0.88
    idx.Text = tostring(captured)
    idx.TextColor3 = C(180,180,180); idx.TextTransparency = 0.10
    idx.TextSize = 9; idx.Font = Enum.Font.GothamBold
    idx.Parent = row
    corner(idx, 4)

    -- Name label
    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size = UDim2.new(1,-96,0,18)
    nameLbl.Position = UDim2.new(0,32,0,7)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = "Loading…"
    nameLbl.TextColor3 = W; nameLbl.TextTransparency = 0.08
    nameLbl.TextSize = 11; nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.TextTruncate = Enum.TextTruncate.AtEnd
    nameLbl.Parent = row

    -- ID sub-label
    local idLbl = Instance.new("TextLabel")
    idLbl.Size = UDim2.new(1,-96,0,14)
    idLbl.Position = UDim2.new(0,32,0,26)
    idLbl.BackgroundTransparency = 1
    idLbl.Text = id
    idLbl.TextColor3 = C(130,130,130); idLbl.TextTransparency = 0.10
    idLbl.TextSize = 9; idLbl.Font = Enum.Font.Gotham
    idLbl.TextXAlignment = Enum.TextXAlignment.Left
    idLbl.TextTruncate = Enum.TextTruncate.AtEnd
    idLbl.Parent = row

    -- Copy button
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0,42,0,24)
    copyBtn.Position = UDim2.new(1,-48,0.5,-12)
    copyBtn.BackgroundColor3 = W; copyBtn.BackgroundTransparency = 0.88
    copyBtn.BorderSizePixel = 0; copyBtn.AutoButtonColor = false
    copyBtn.Text = "Copy"
    copyBtn.TextColor3 = W; copyBtn.TextTransparency = 0.12
    copyBtn.TextSize = 9; copyBtn.Font = Enum.Font.GothamBold
    copyBtn.Parent = row
    corner(copyBtn, 5); stroke(copyBtn, 0.84)
    hov(copyBtn, 0.70, 0.88)

    copyBtn.MouseButton1Click:Connect(function()
        setclipboard(id)
        copyBtn.Text = "✓"
        copyBtn.BackgroundTransparency = 0.72
        flashStatus("Copied · " .. id)
        task.delay(1.4, function()
            copyBtn.Text = "Copy"
            copyBtn.BackgroundTransparency = 0.88
        end)
    end)

    -- Fade in
    row.BackgroundTransparency = 1
    TweenService:Create(row, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 0.93
    }):Play()

    task.defer(function()
        sf.CanvasPosition = Vector2.new(0, math.huge)
    end)

    -- Async name lookup
    task.spawn(function()
        local name = fetchName(id)
        nameLbl.Text = name
        flashStatus("Captured · " .. name)
    end)
end

-- Clear
clearBtn.MouseButton1Click:Connect(function()
    for _, c in ipairs(sf:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    seen = {}; captured = 0
    countLbl.Text = "0 captured"
    emptyLbl.Visible = true
    flashStatus("Cleared")
end)

-- ============================================================
-- DETECTION
-- ============================================================
local function onPlayed(track)
    if not track.Animation then return end
    local id = track.Animation.AnimationId
    if id and id ~= "" and not isDefault(id) then
        addEntry(id)
    end
end

local function connect(char)
    char:WaitForChild("Humanoid").AnimationPlayed:Connect(onPlayed)
end

connect(player.Character or player.CharacterAdded:Wait())
player.CharacterAdded:Connect(connect)

print("[AnimDetector] Ready.")
