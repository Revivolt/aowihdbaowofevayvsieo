local function isDefault(id)
    if DEFAULT_IDS[id] then return true end
    local n = tonumber(id:match("%d+$"))
    return n and DEFAULT_NUM[n]
end
local function numId(id) return id:match("%d+$") or id end

-- ============================================================
-- NAME FETCH
-- ============================================================
local function fetchName(id)
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(tonumber(id), Enum.InfoType.Asset)
    end)
    return (ok and info and info.Name) or "Unknown"
end

-- ============================================================
-- MINI HELPERS
-- ============================================================
local W = Color3.fromRGB(255,255,255)
local function C(r,g,b) return Color3.fromRGB(r,g,b) end

local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = p
end
local function stroke(p, t)
    local s = Instance.new("UIStroke")
    s.Color = W; s.Transparency = t or 0.84; s.Thickness = 1
    s.Parent = p
end
local function hov(b, on, off)
    b.MouseEnter:Connect(function() b.BackgroundTransparency = on  end)
    b.MouseLeave:Connect(function() b.BackgroundTransparency = off end)
end

