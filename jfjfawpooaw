--// Sonic

-----------------------------
-- CONFIG
-----------------------------

-- DEFAULT ANIMATIONS
local TRANSFORMATION_ID = 0
local IDLE_ID = 0
local WALK_ID = 118320322718866
local SPRINT_ID = 76931637880681
local JUMP_ID = 0
local M1_ID = 0

-- ALTERNATE ANIMATIONS
local ALT_IDLE_ID = 0
local ALT_WALK_ID = 0
local ALT_SPRINT_ID = 0
local ALT_JUMP_ID = 0
local ALT_M1_ID = 0

-- EMOTES (movement cancels)
local EMOTE_T_ID = 0
local EMOTE_Y_ID = 0
local EMOTE_U_ID = 0

-- TIMING
local TRANSFORMATION_DURATION = 0

-- MOVEMENT SPEEDS
local BASE_WALK_SPEED = 100
local SPRINT_SPEED = 300

-- ANIMATION SPEEDS
local TRANSFORM_ANIM_SPEED = 1
local IDLE_ANIM_SPEED = 1
local WALK_ANIM_SPEED = 0.5
local SPRINT_ANIM_SPEED = 3
local JUMP_ANIM_SPEED = 1
local M1_ANIM_SPEED = 1

-----------------------------
-- SERVICES
-----------------------------
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

-----------------------------
-- CHARACTER SETUP
-----------------------------
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local animator = humanoid:WaitForChild("Animator")
humanoid.AutoRotate = true

-----------------------------
-- STATE VARIABLES
-----------------------------
local transformed = false
local sprinting = false
local currentState = "None"

local useAltIdle = false
local useAltWalk = false
local useAltSprint = false
local useAltJump = false
local useAltM1 = false

local idleTrack, walkTrack, sprintTrack, jumpTrack, transformationTrack, emoteTrack

-----------------------------
-- HELPER FUNCTIONS
-----------------------------
local function isValidId(id)
	return typeof(id) == "number" and id > 0
end

local function loadAnimation(assetId, looped)
	if not isValidId(assetId) then return nil end
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://"..tostring(assetId)
	local track = animator:LoadAnimation(anim)
	track.Looped = looped
	track.Priority = Enum.AnimationPriority.Action
	return track
end

local function stopEmote()
	if emoteTrack then
		emoteTrack:Stop()
		emoteTrack:Destroy()
		emoteTrack = nil
	end
end

-----------------------------
-- PLAY STATE FUNCTIONS
-----------------------------
local function playIdle()
	if not transformed or currentState == "Idle" or emoteTrack then return end
	currentState = "Idle"
	if walkTrack then walkTrack:Stop() end
	if sprintTrack then sprintTrack:Stop() end
	local animId = useAltIdle and isValidId(ALT_IDLE_ID) and ALT_IDLE_ID or IDLE_ID
	if not idleTrack then idleTrack = loadAnimation(animId,true) end
	if idleTrack then
		idleTrack:Play()
		idleTrack:AdjustSpeed(IDLE_ANIM_SPEED)
	end
end

local function playWalk()
	if not transformed or currentState == "Walk" or sprinting or emoteTrack then return end
	currentState = "Walk"
	if idleTrack then idleTrack:Stop() end
	if sprintTrack then sprintTrack:Stop() end
	local animId = useAltWalk and isValidId(ALT_WALK_ID) and ALT_WALK_ID or WALK_ID
	if not walkTrack then walkTrack = loadAnimation(animId,true) end
	if walkTrack then
		walkTrack:Play()
		walkTrack:AdjustSpeed(WALK_ANIM_SPEED * (humanoid.WalkSpeed/BASE_WALK_SPEED))
	end
end

local function playSprint()
	if not transformed or currentState == "Sprint" or emoteTrack then return end
	currentState = "Sprint"
	if idleTrack then idleTrack:Stop() end
	if walkTrack then walkTrack:Stop() end
	local animId = useAltSprint and isValidId(ALT_SPRINT_ID) and ALT_SPRINT_ID or SPRINT_ID
	if not sprintTrack then sprintTrack = loadAnimation(animId,true) end
	if sprintTrack then
		sprintTrack:Play()
		sprintTrack:AdjustSpeed(SPRINT_ANIM_SPEED * (humanoid.WalkSpeed/BASE_WALK_SPEED))
	end
end

local function playJump()
	if not transformed then return end
	local animId = useAltJump and isValidId(ALT_JUMP_ID) and ALT_JUMP_ID or JUMP_ID
	if not isValidId(animId) then return end
	if jumpTrack then jumpTrack:Stop() end
	jumpTrack = loadAnimation(animId,false)
	if jumpTrack then
		jumpTrack:Play()
		jumpTrack:AdjustSpeed(JUMP_ANIM_SPEED)
	end
end

local function playM1()
	if not transformed then return end
	local animId = useAltM1 and isValidId(ALT_M1_ID) and ALT_M1_ID or M1_ID
	if not isValidId(animId) then return end
	stopEmote()
	local track = loadAnimation(animId,false)
	if track then
		track.Priority = Enum.AnimationPriority.Action
		track:Play()
		task.delay(1,function() refreshState() end)
	end
end

local function playLoopEmote(assetId)
	if not transformed or not isValidId(assetId) then return end
	stopEmote()
	emoteTrack = loadAnimation(assetId,true)
	if emoteTrack then emoteTrack:Play() end
end

-----------------------------
-- REFRESH STATE
-----------------------------
function refreshState()
	if not transformed then return end
	if emoteTrack then return end
	local speed = humanoid.MoveDirection.Magnitude
	if speed > 0.1 then
		if sprinting then playSprint() else playWalk() end
	else
		playIdle()
	end
end

-----------------------------
-- TRANSFORMATION
-----------------------------
local function playTransformation()
	if isValidId(TRANSFORMATION_ID) then
		transformationTrack = loadAnimation(TRANSFORMATION_ID,false)
		if transformationTrack then
			transformationTrack:Play()
			transformationTrack:AdjustSpeed(TRANSFORM_ANIM_SPEED)
		end
	end
	transformed = true
	humanoid.WalkSpeed = BASE_WALK_SPEED
	task.delay(TRANSFORMATION_DURATION,function()
		if transformed then
			refreshState()
		end
	end)
end

-----------------------------
-- INPUT
-----------------------------
UserInputService.InputBegan:Connect(function(input,gp)
	if gp or not transformed then return end
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = true
		humanoid.WalkSpeed = SPRINT_SPEED
	end

	if input.KeyCode == Enum.KeyCode.T then playLoopEmote(EMOTE_T_ID)
	elseif input.KeyCode == Enum.KeyCode.Y then playLoopEmote(EMOTE_Y_ID)
	elseif input.KeyCode == Enum.KeyCode.U then playLoopEmote(EMOTE_U_ID) end

	-- Toggle alternates
	if input.KeyCode == Enum.KeyCode.G then useAltWalk = not useAltWalk end
	if input.KeyCode == Enum.KeyCode.H then useAltSprint = not useAltSprint end
	if input.KeyCode == Enum.KeyCode.J then useAltIdle = not useAltIdle end
	if input.KeyCode == Enum.KeyCode.K then useAltJump = not useAltJump end
	if input.KeyCode == Enum.KeyCode.L then useAltM1 = not useAltM1 end

	-- Left click M1
	if input.UserInputType == Enum.UserInputType.MouseButton1 then playM1() end
end)

UserInputService.InputEnded:Connect(function(input)
	if not transformed then return end
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = false
		humanoid.WalkSpeed = BASE_WALK_SPEED
	end
end)

-----------------------------
-- MOVEMENT DETECTION
-----------------------------
humanoid.Running:Connect(function(speed)
	if not transformed then return end
	if speed > 0 and emoteTrack then stopEmote() end
	if speed > 0 then
		if sprinting then playSprint() else playWalk() end
	else
		playIdle()
	end
end)

humanoid.StateChanged:Connect(function(_,new)
	if not transformed then return end
	if new == Enum.HumanoidStateType.Jumping then playJump()
	elseif new == Enum.HumanoidStateType.Landed then refreshState() end
end)

-----------------------------
-- START
-----------------------------
playTransformation()
