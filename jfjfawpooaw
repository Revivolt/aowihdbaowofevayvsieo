--// test5

-----------------------------
-- CONFIG
-----------------------------

-- DEFAULT ANIMATIONS
local TRANSFORMATION_ID = 0
local IDLE_ID = 0
local WALK_ID = 118320322718866
local SPRINT_ID = 76931637880681
local JUMP_ID = 0
local M1_ID = 0

-- ALTERNATE ANIMATIONS
local ALT_IDLE_ID = 0
local ALT_WALK_ID = 0
local ALT_SPRINT_ID = 0
local ALT_JUMP_ID = 0
local ALT_M1_ID = 0

-- EMOTES (movement cancels)
local EMOTE_T_ID = 0
local EMOTE_Y_ID = 0
local EMOTE_U_ID = 0

-- TIMING
local TRANSFORMATION_DURATION = 0

-- MOVEMENT SPEEDS
local BASE_WALK_SPEED = 100
local SPRINT_SPEED = 300

-- ANIMATION SPEEDS
local TRANSFORM_ANIM_SPEED = 1
local IDLE_ANIM_SPEED = 1
local WALK_ANIM_SPEED = 0.5
local SPRINT_ANIM_SPEED = 6
local JUMP_ANIM_SPEED = 1
local M1_ANIM_SPEED = 1

-----------------------------
-- SERVICES
-----------------------------
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local animator = humanoid:WaitForChild("Animator")

humanoid.AutoRotate = true

-----------------------------
-- STATE
-----------------------------
local transformed = false
local sprinting = false
local useAltWalk, useAltSprint, useAltIdle, useAltJump, useAltM1 = false, false, false, false, false
local movementTrack
local actionTrack
local emoteTrack
local actionLocked = false

-----------------------------
-- UTILITY
-----------------------------
local function isValidId(id)
	return typeof(id) == "number" and id > 0
end

local function stopMovementTrack()
	if movementTrack then
		movementTrack:Stop()
		movementTrack:Destroy()
		movementTrack = nil
	end
end

local function playMovementAnimation(assetId, looped, speed)
	if not isValidId(assetId) then
		stopMovementTrack()
		return
	end
	if movementTrack then
		movementTrack:Stop()
		movementTrack:Destroy()
	end
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://"..tostring(assetId)
	movementTrack = animator:LoadAnimation(anim)
	movementTrack.Priority = Enum.AnimationPriority.Movement
	movementTrack.Looped = looped
	movementTrack:Play()
	if speed then movementTrack:AdjustSpeed(speed) end
end

local function playActionAnimation(assetId, speed)
	if not isValidId(assetId) then return end
	if actionTrack then
		actionTrack:Stop()
		actionTrack:Destroy()
	end
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://"..tostring(assetId)
	actionTrack = animator:LoadAnimation(anim)
	actionTrack.Priority = Enum.AnimationPriority.Action
	actionTrack.Looped = false
	actionTrack:Play()
	if speed then actionTrack:AdjustSpeed(speed) end
	actionTrack.Stopped:Connect(function()
		actionTrack:Destroy()
		actionTrack = nil
	end)
end

local function stopEmote()
	if emoteTrack then
		emoteTrack:Stop()
		emoteTrack:Destroy()
		emoteTrack = nil
	end
end

-----------------------------
-- STATE FUNCTIONS
-----------------------------
local function playIdle()
	if emoteTrack or actionLocked then return end
	local animId = IDLE_ID
	if useAltIdle and isValidId(ALT_IDLE_ID) then animId = ALT_IDLE_ID end
	playMovementAnimation(animId, true, IDLE_ANIM_SPEED)
end

local function playWalk()
	if emoteTrack or actionLocked then return end
	local animId = WALK_ID
	if useAltWalk and isValidId(ALT_WALK_ID) then animId = ALT_WALK_ID end
	local speedFactor = humanoid.WalkSpeed / BASE_WALK_SPEED
	playMovementAnimation(animId, true, WALK_ANIM_SPEED * speedFactor)
end

local function playSprint()
	if emoteTrack or actionLocked then return end
	local animId = SPRINT_ID
	if useAltSprint and isValidId(ALT_SPRINT_ID) then animId = ALT_SPRINT_ID end
	local speedFactor = humanoid.WalkSpeed / BASE_WALK_SPEED
	playMovementAnimation(animId, true, SPRINT_ANIM_SPEED * speedFactor)
end

local function playJump()
	actionLocked = true
	local animId = JUMP_ID
	if useAltJump and isValidId(ALT_JUMP_ID) then animId = ALT_JUMP_ID end
	playMovementAnimation(animId, false, JUMP_ANIM_SPEED)
end

local function playM1()
	local animId = M1_ID
	if useAltM1 and isValidId(ALT_M1_ID) then animId = ALT_M1_ID end
	if not isValidId(animId) then return end
	actionLocked = true
	stopEmote()
	playActionAnimation(animId, M1_ANIM_SPEED)
	task.delay(1, function()
		actionLocked = false
		refreshState()
	end)
end

local function playLoopEmote(assetId)
	if not isValidId(assetId) then return end
	stopEmote()
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://"..tostring(assetId)
	emoteTrack = animator:LoadAnimation(anim)
	emoteTrack.Priority = Enum.AnimationPriority.Action
	emoteTrack.Looped = true
	emoteTrack:Play()
end

-----------------------------
-- STATE REFRESH
-----------------------------
function refreshState()
	if not transformed then return end
	if actionLocked then return end
	if emoteTrack then return end
	if humanoid:GetState() == Enum.HumanoidStateType.Freefall then return end

	local moveMag = humanoid.MoveDirection.Magnitude
	if moveMag > 0.1 then
		if sprinting then playSprint() else playWalk() end
	else
		playIdle()
	end
end

-----------------------------
-- TRANSFORMATION
-----------------------------
local function playTransformation()
	if isValidId(TRANSFORMATION_ID) then
		playMovementAnimation(TRANSFORMATION_ID, false, TRANSFORM_ANIM_SPEED)
	end
	transformed = true
	humanoid.WalkSpeed = BASE_WALK_SPEED
	task.delay(TRANSFORMATION_DURATION, function()
		if transformed then refreshState() end
	end)
end

-----------------------------
-- EVENTS
-----------------------------
humanoid.Running:Connect(refreshState)
humanoid.StateChanged:Connect(function(_, new)
	if not transformed then return end
	if new == Enum.HumanoidStateType.Jumping then
		playJump()
	elseif new == Enum.HumanoidStateType.Landed then
		actionLocked = false
		refreshState()
	end
end)

-----------------------------
-- INPUT
-----------------------------
UserInputService.InputBegan:Connect(function(input, gp)
	if gp or not transformed then return end
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = true
		humanoid.WalkSpeed = SPRINT_SPEED
	end
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		playM1()
	end

	-- Alternate toggles
	if input.KeyCode == Enum.KeyCode.G then useAltWalk = not useAltWalk end
	if input.KeyCode == Enum.KeyCode.H then useAltSprint = not useAltSprint end
	if input.KeyCode == Enum.KeyCode.J then useAltIdle = not useAltIdle end
	if input.KeyCode == Enum.KeyCode.K then useAltJump = not useAltJump end
	if input.KeyCode == Enum.KeyCode.L then useAltM1 = not useAltM1 end

	-- Loop emotes
	if input.KeyCode == Enum.KeyCode.T then playLoopEmote(EMOTE_T_ID) end
	if input.KeyCode == Enum.KeyCode.Y then playLoopEmote(EMOTE_Y_ID) end
	if input.KeyCode == Enum.KeyCode.U then playLoopEmote(EMOTE_U_ID) end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = false
		humanoid.WalkSpeed = BASE_WALK_SPEED
		refreshState()
	end
end)

-----------------------------
-- START
-----------------------------
playTransformation()
