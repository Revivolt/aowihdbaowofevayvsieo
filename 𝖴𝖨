-- Services
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- ICON YOU CAN CHANGE
local ICON_ID = "rbxassetid://82213030031204"

-- Toggle GUI
local toggleGui = Instance.new("ScreenGui")
toggleGui.Name = "ToggleGui"
toggleGui.ResetOnSpawn = false
toggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
toggleGui.Parent = (RunService:IsStudio() and LocalPlayer.PlayerGui) or game:GetService("CoreGui")

-- Toggle Button (Square Image Button)
local toggleButton = Instance.new("ImageButton")
toggleButton.Name = "ToggleButton"
toggleButton.Size = UDim2.fromOffset(40, 40)
toggleButton.Position = UDim2.fromOffset(10, 10)
toggleButton.BackgroundColor3 = Color3.fromRGB(50, 52, 55)
toggleButton.BorderSizePixel = 0
toggleButton.Image = ICON_ID
toggleButton.ScaleType = Enum.ScaleType.Fit
toggleButton.Parent = toggleGui

-- Rounded corners
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = toggleButton

-- Outline
local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(0, 0, 0)
stroke.Thickness = 1
stroke.Parent = toggleButton

-- Drag + Click system
local dragging = false
local dragStart
local startPos
local moved = false
local DRAG_THRESHOLD = 6

toggleButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		moved = false
		dragStart = input.Position
		startPos = toggleButton.Position
	end
end)

toggleButton.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false

		if not moved then
			Library.Toggled = not Library.Toggled
			Library:show(Library.Toggled)
		end
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart

		if math.abs(delta.X) > DRAG_THRESHOLD or math.abs(delta.Y) > DRAG_THRESHOLD then
			moved = true
		end

		if moved then
			toggleButton.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end
end)

-- Destroy toggle button when the main UI is closed
Library.mainFrame.AbsoluteObject.AncestryChanged:Connect(function(_, parent)
    if parent == nil then
        toggleGui:Destroy()
    end
end)
