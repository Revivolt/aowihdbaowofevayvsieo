--[[
    ╔══════════════════════════════════════════════════════════╗
    ║               SECRET CHAT — LocalScript                  ║
    ║  Only players running this exact script can communicate  ║
    ╚══════════════════════════════════════════════════════════╝

    HOW IT WORKS:
    • When loaded, this script places a hidden "handshake" StringValue
      inside your Character that replicates to all other clients.
    • Other players also running this script detect that value and
      know you're in the secret channel.
    • Messages are sent by updating a second StringValue in your
      Character — changes replicate instantly to everyone watching.
    • Players NOT running this script see nothing unusual.

    USAGE:
    • Press Enter or click Send to chat.
    • Press Ctrl+H (or the [─] button) to hide/show the window.
    • Drag the title bar to reposition the window.
--]]

-- ─────────────────────────────────────────────
--  CONFIG  (all values must be identical in every copy of the script)
-- ─────────────────────────────────────────────
local HANDSHAKE_TAG  = "__SC_hs_a9f3c2__"   -- hidden value name placed in Character
local MESSAGE_TAG    = "__SC_msg_a9f3c2__"   -- hidden value name used to broadcast messages
local HANDSHAKE_VAL  = "SC_AUTH_v1_a9f3c2"  -- secret token — must match exactly
local WINDOW_TITLE   = "🔒 Secret Chat"

-- ─────────────────────────────────────────────
--  SERVICES & LOCALS
-- ─────────────────────────────────────────────
local Players          = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

-- ─────────────────────────────────────────────
--  UTILITIES
-- ─────────────────────────────────────────────
local function waitForChildTimeout(parent, name, timeout)
    local t = 0
    while t < timeout do
        local child = parent:FindFirstChild(name)
        if child then return child end
        task.wait(0.1)
        t = t + 0.1
    end
    return nil
end

-- ─────────────────────────────────────────────
--  INJECT HANDSHAKE & MESSAGE VALUE INTO OWN CHARACTER
-- ─────────────────────────────────────────────
local activeMsgValue  -- StringValue used to broadcast outgoing messages

local function injectIntoCharacter(char)
    if not char:FindFirstChild(HANDSHAKE_TAG) then
        local hs  = Instance.new("StringValue")
        hs.Name   = HANDSHAKE_TAG
        hs.Value  = HANDSHAKE_VAL
        hs.Parent = char
    end

    -- Replace any old message value
    local old = char:FindFirstChild(MESSAGE_TAG)
    if old then old:Destroy() end

    local mv      = Instance.new("StringValue")
    mv.Name       = MESSAGE_TAG
    mv.Value      = ""
    mv.Parent     = char
    activeMsgValue = mv
end

local function sendRaw(text)
    if activeMsgValue and text ~= "" then
        -- Format: "DisplayName \31 message \31 timestamp"
        -- \31 = ASCII Unit Separator — never typed by a user
        activeMsgValue.Value = LocalPlayer.DisplayName
            .. "\31" .. text
            .. "\31" .. tostring(os.clock())
    end
end

