-- REPORT BUILDER
-- ─────────────────────────────────────────────────────────────────────────────
local function buildReport(e)
    local L = {}
    local function ln(s) table.insert(L, s or "") end
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln("  INJECTION CAPTURE REPORT")
    ln("  Detected at : " .. e.time)
    ln("  Method      : " .. e.method)
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln(); ln("[ IDENTITY ]")
    ln("  Name      : " .. tostring(e.name))
    ln("  ClassName : " .. tostring(e.className))
    ln("  Path      : " .. tostring(e.path))
    ln(); ln("[ PROPERTIES ]")
    for k, v in pairs(e.props) do
        if k ~= "Name" and k ~= "ClassName" then
            ln(string.format("  %-16s: %s", k, v))
        end
    end
    ln()
    if e.source and #e.source > 0 then
        ln("[ SOURCE / BYTECODE ]"); ln()
        ln(e.source)
    else
        ln("[ SOURCE / BYTECODE ]"); ln()
        ln("-- Source not readable.")
        ln("-- Executor with decompile() required for full source.")
    end
    ln(); ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    return table.concat(L, "\n")
end

local function toClip(t)
    if type(setclipboard) == "function" then pcall(setclipboard, t); return true end
    if type(toclipboard)  == "function" then pcall(toclipboard,  t); return true end
    return false
end

