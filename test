-- ─────────────────────────────────────────────
--  CONFIG  (keep identical across all copies!)
-- ─────────────────────────────────────────────
local SECRET_KEY  = { 72, 88, 51, 90, 99, 14, 37 }  -- XOR key bytes
local MSG_PREFIX  = "SCX:"                            -- identifies script messages
local MAX_MSGS    = 60                                -- history limit
local USING_NEW_CHAT = (TextChatService.ChatVersion == Enum.ChatVersion.TextChatService)

-- ─────────────────────────────────────────────
--  ENCODING  (XOR + hex; filter-safe)
-- ─────────────────────────────────────────────
local function encode(text)
    local out = {}
    for i = 1, #text do
        local xb = bit32.bxor(text:byte(i), SECRET_KEY[((i - 1) % #SECRET_KEY) + 1])
        out[#out + 1] = string.format("%02X", xb)
    end
    return MSG_PREFIX .. table.concat(out)
end

local function decode(raw)
    local hex = raw:match("^" .. MSG_PREFIX .. "([0-9A-Fa-f]+)$")
    if not hex or #hex % 2 ~= 0 then return nil end
    local chars, j = {}, 1
    for i = 1, #hex, 2 do
        local b = tonumber(hex:sub(i, i + 1), 16)
        chars[#chars + 1] = string.char(
            bit32.bxor(b, SECRET_KEY[((j - 1) % #SECRET_KEY) + 1])
        )
        j = j + 1
    end
    return table.concat(chars)
end

