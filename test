-- ════════════════════════════════════════════════════════════════════
--  KILL THE ROBLOX TOP BAR + COREGUI
--  SetCore("TopbarEnabled", false) removes the actual black bar.
--  SetCoreGuiEnabled removes chat, backpack, health, etc.
--  We retry on a loop because Roblox re-enables them on respawn.
-- ════════════════════════════════════════════════════════════════════
local function killRobloxGui()
    pcall(function() StarterGui:SetCore("TopbarEnabled", false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All,        false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack,   false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat,       false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Health,     false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.EmotesMenu, false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.SelfView,   false) end)
end

-- Call immediately
killRobloxGui()

-- Re-apply every 0.5s for 10 seconds (Roblox loads CoreGui pieces late)
task.spawn(function()
    for _ = 1, 20 do
        task.wait(0.5)
        killRobloxGui()
    end
    -- Then every 5 seconds forever to handle respawns
    while true do
        task.wait(5)
        killRobloxGui()
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.2)
    killRobloxGui()
end)

