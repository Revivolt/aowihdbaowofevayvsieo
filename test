-- ─────────────────────────────────────────────────────────
--  Monitor common LocalScript containers
-- ─────────────────────────────────────────────────────────
local function hookAllContainers()
    -- PlayerGui
    scanContainer(PlayerGui)

    -- Backpack (tools carry LocalScripts)
    local Backpack = LocalPlayer:WaitForChild("Backpack", 5)
    if Backpack then scanContainer(Backpack) end

    -- Character (spawned scripts)
    local function hookCharacter(character)
        if character then scanContainer(character) end
    end
    hookCharacter(LocalPlayer.Character)
    LocalPlayer.CharacterAdded:Connect(hookCharacter)

    -- StarterGui scripts already cloned into PlayerGui (above)
    -- Also scan game root for any accessible descendants
    scanContainer(game:GetService("ReplicatedStorage"))
end

hookAllContainers()

-- ─────────────────────────────────────────────────────────
--  Debug hook: fires every time a Lua function is CALLED
--  This catches dynamically executed scripts / closures.
-- ─────────────────────────────────────────────────────────
debug.sethook(function(event)
    local info = debug.getinfo(2, "nS")
    if not info then return end

    local src  = info.source or ""
    local name = info.name   or "(anonymous)"

    -- Only care about game-defined scripts (starts with "=" or "@" or script paths)
    if src:sub(1,1) == "@" then
        -- Source is a file path — in Studio this may reveal the script
        local entry = string.format("[Hook] call event: %s | func: %s\n", src, name)
        -- We only log unique sources to avoid spam
        if not capturedScripts["__hook__" .. src] then
            capturedScripts["__hook__" .. src] = entry
            table.insert(capturedOrder, "__hook__" .. src)
            refreshDisplay()
        end
    end
end, "c")   -- "c" = call events only

