--  SERVER CHAT
-- ─────────────────────────────────────────────────────────────────────
local ChatPanel,chatBox,chatSend,addLocalMsg=
    buildChat("ServerChat",310,420,"Server Chat",C.ACC,"Message players here…")

addLocalMsg(nil,"📡 Players on this server running this script can see these messages.",true)
addLocalMsg(nil,"──────────────────────────────",true)

local LocalRemote=nil
task.spawn(function()
    local folder=ReplicatedStorage:FindFirstChild("CGUIv1")
               or inst("Folder",{Name="CGUIv1"},ReplicatedStorage)
    local re=folder:FindFirstChild("LC")
           or inst("RemoteEvent",{Name="LC"},folder)
    LocalRemote=re
    re.OnClientEvent:Connect(function(s,m)
        if type(s)=="string" and type(m)=="string" and s~=LP.Name then
            addLocalMsg(s,m)
        end
    end)
end)

local lastLS=0
local function sendLocal()
    local m=chatBox.Text:match("^%s*(.-)%s*$")
    if m=="" then return end
    if tick()-lastLS<0.8 then return end
    lastLS=tick(); chatBox.Text=""
    m=m:sub(1,MAX_MSG)
    addLocalMsg(LP.Name,m)
    if LocalRemote then pcall(function() LocalRemote:FireServer(m) end) end
end
chatSend.MouseButton1Click:Connect(sendLocal)
chatBox.FocusLost:Connect(function(e) if e then sendLocal() end end)

-- ─────────────────────────────────────────────────────────────────────
--  GLOBAL CHAT
-- ─────────────────────────────────────────────────────────────────────
local GlobalPanel,globalBox,globalSend,addGlobalMsg=
    buildChat("GlobalChat",310,420,"Global Chat",C.GLOB,"Message everyone across servers…")

addGlobalMsg(nil,"🌐 Chat with everyone using this script across all servers.",true)
addGlobalMsg(nil,"⚠ Requires a published game — not available in Studio.",true)
addGlobalMsg(nil,"──────────────────────────────",true)

task.spawn(function()
    local ok,err=pcall(function()
        MessagingService:SubscribeAsync(GCHANNEL,function(data)
            local p=data.Data
            if type(p)~="table" then return end
            if type(p.s)~="string" or type(p.m)~="string" then return end
            if p.s==LP.Name and p.id==SID then return end
            addGlobalMsg((p.id and "["..p.id.."] " or "")..p.s, p.m:sub(1,MAX_MSG))
            if not GlobalPanel.Visible then
                notify("Global · "..p.s, p.m:sub(1,55), C.GLOB)
            end
        end)
    end)
    if not ok then addGlobalMsg(nil,"⚠ MessagingService: "..tostring(err),true) end
end)

local lastGS=0
local function sendGlobal()
    local m=globalBox.Text:match("^%s*(.-)%s*$")
    if m=="" then return end
    if tick()-lastGS<1.2 then return end
    lastGS=tick(); globalBox.Text=""
    m=m:sub(1,MAX_MSG)
    addGlobalMsg("["..SID.."] "..LP.Name,m)
    task.spawn(function()
        local ok,err=pcall(function()
            MessagingService:PublishAsync(GCHANNEL,{s=LP.Name,m=m,id=SID})
        end)
        if not ok then addGlobalMsg(nil,"⚠ "..tostring(err),true) end
    end)
end
globalSend.MouseButton1Click:Connect(sendGlobal)
globalBox.FocusLost:Connect(function(e) if e then sendGlobal() end end)

-- ─────────────────────────────────────────────────────────────────────
--  PANEL TOGGLE
-- ─────────────────────────────────────────────────────────────────────
local entries={
    {btn=menuBtn,   setActive=setMenuActive,   panel=MenuPanel},
    {btn=chatBtn,   setActive=setChatActive,   panel=ChatPanel},
    {btn=globalBtn, setActive=setGlobalActive, panel=GlobalPanel},
}

for _,e in ipairs(entries) do
    e.btn.MouseButton1Click:Connect(function()
        local opening=not e.panel.Visible
        for _,x in ipairs(entries) do
            x.panel.Visible=false
            x.setActive(false)
        end
        if opening then
            e.panel.Visible=true
            e.setActive(true)
        end
    end)
end

