--  NOTIFICATION SYSTEM  (defined early so menu items can use it)
-- ════════════════════════════════════════════════════════════════════════
local notifEnabled = true
local nQueue = {}
local nBusy  = false

local function showNotif(title, body, color)
    if not notifEnabled then return end
    table.insert(nQueue, {title=title, body=body, color=color or T.ACCENT})
    if nBusy then return end
    nBusy = true
    task.spawn(function()
        while #nQueue > 0 do
            local n = table.remove(nQueue, 1)
            local box = new("Frame", {
                Size=UDim2.new(0,265,0,64), Position=UDim2.new(1,10,1,-72),
                AnchorPoint=Vector2.new(1,1), BackgroundColor3=T.BG2, ZIndex=60,
            }, Root)
            corner(box, 10); stroke(box, n.color, 1)
            new("Frame", {Size=UDim2.new(0,4,1,-12), Position=UDim2.new(0,0,0,6),
                BackgroundColor3=n.color, BorderSizePixel=0, ZIndex=61}, box)
            new("TextLabel", {Size=UDim2.new(1,-12,0,20), Position=UDim2.new(0,10,0,6),
                BackgroundTransparency=1, Text=n.title, TextColor3=n.color,
                TextSize=13, Font=Enum.Font.GothamBold,
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=61}, box)
            new("TextLabel", {Size=UDim2.new(1,-12,0,26), Position=UDim2.new(0,10,0,26),
                BackgroundTransparency=1, Text=n.body, TextColor3=T.TEXT_DIM,
                TextSize=11, Font=Enum.Font.Gotham, TextWrapped=true,
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=61}, box)
            tw(box, {Position=UDim2.new(1,-8,1,-72)}, 0.22)
            task.wait(3.2)
            tw(box, {Position=UDim2.new(1,280,1,-72)}, 0.22)
            task.wait(0.26); box:Destroy(); task.wait(0.1)
        end
        nBusy = false
    end)
end

