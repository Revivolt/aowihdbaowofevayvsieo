local function makeTopBtn(icon, tooltip)
    local btn = make("TextButton", {
        Size             = UDim2.new(0, 32, 0, 26),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 1,
        Text             = icon,
        TextColor3       = T.TEXT,
        TextSize         = 17,
        Font             = Enum.Font.GothamBold,
        AutoButtonColor  = false,
        ZIndex           = 4,
    }, Pill)
    addCorner(btn, 6)

    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundTransparency = 0.5})
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundTransparency = 1})
    end)

    -- Tooltip label
    local tip = make("TextLabel", {
        Size                   = UDim2.new(0, 0, 0, 20),
        AutomaticSize          = Enum.AutomaticSize.X,
        Position               = UDim2.new(0.5, 0, 1, 4),
        AnchorPoint            = Vector2.new(0.5, 0),
        BackgroundColor3       = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.25,
        Text                   = "  " .. tooltip .. "  ",
        TextColor3             = T.TEXT,
        TextSize               = 10,
        Font                   = Enum.Font.Gotham,
        Visible                = false,
        ZIndex                 = 10,
    }, btn)
    addCorner(tip, 4)
    btn.MouseEnter:Connect(function() tip.Visible = true  end)
    btn.MouseLeave:Connect(function() tip.Visible = false end)

    return btn
end

