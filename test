-- ─────────────────────────────────────────────────────────────────────────────
local function buildReport(e, useDeob)
    local L = {}
    local function ln(s) table.insert(L, s or "") end
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln("  INJECTION CAPTURE REPORT" .. (useDeob and "  [AI DEOBFUSCATED]" or ""))
    ln("  Detected at : " .. e.time)
    ln("  Method      : " .. e.method)
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln(); ln("[ IDENTITY ]")
    ln("  Name      : " .. tostring(e.name))
    ln("  ClassName : " .. tostring(e.className))
    ln("  Path      : " .. tostring(e.path))
    ln(); ln("[ PROPERTIES ]")
    for k, v in pairs(e.props) do
        if k ~= "Name" and k ~= "ClassName" then
            ln(string.format("  %-16s: %s", k, v))
        end
    end
    ln()
    local srcToShow = useDeob and (e.deobSource or e.source) or e.source
    if srcToShow and #srcToShow > 0 then
        ln("[ " .. (useDeob and "DEOBFUSCATED SOURCE" or "RAW SOURCE") .. " ]"); ln()
        ln(srcToShow)
    else
        ln("[ SOURCE ]"); ln()
        ln("-- Source not readable.")
        ln("-- Run via executor with decompile() for full source.")
    end
    ln(); ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    return table.concat(L, "\n")
end

-- ─────────────────────────────────────────────────────────────────────────────
-- EXECUTOR HTTP (tries multiple executor globals in order)
-- ─────────────────────────────────────────────────────────────────────────────
local function httpRequest(opts)
    if type(syn) == "table" and type(syn.request) == "function" then
        return syn.request(opts)
    elseif type(http) == "table" and type(http.request) == "function" then
        return http.request(opts)
    elseif type(request) == "function" then
        return request(opts)
    elseif type(http_request) == "function" then
        return http_request(opts)
    end
    return nil
end

-- ─────────────────────────────────────────────────────────────────────────────
-- DEOBFUSCATION via Anthropic API
-- ─────────────────────────────────────────────────────────────────────────────
local function callDeobfuscate(sourceCode, callback)
    if ANTHROPIC_API_KEY == "YOUR_API_KEY_HERE" or ANTHROPIC_API_KEY == "" then
        callback(false, "No API key set.\nPaste your Anthropic API key at the top of the script.\nGet one at: https://console.anthropic.com/")
        return
    end
    if not sourceCode or #sourceCode == 0 then
        callback(false, "No source code available to deobfuscate.")
        return
    end

    local prompt = "You are a Lua deobfuscator specializing in Roblox scripts.\n" ..
        "The following script may be obfuscated. Your job:\n" ..
        "1. Rename mangled variables/functions to meaningful names based on what they do\n" ..
        "2. Decode any encoded strings (hex escapes, char tables, base64, etc.)\n" ..
        "3. Remove junk code and dead branches\n" ..
        "4. Unroll loops that are just obfuscation padding\n" ..
        "5. Unfold VM-based obfuscation layers if present\n" ..
        "6. Reformat with proper indentation\n" ..
        "7. Add short comments explaining what each section does\n\n" ..
        "Return ONLY the cleaned Lua code. No explanation, no markdown fences.\n\n" ..
        "Script:\n" .. sourceCode:sub(1, 14000)

    task.spawn(function()
        local ok, res = pcall(function()
            local body = HttpService:JSONEncode({
                model      = "claude-sonnet-4-20250514",
                max_tokens = 4096,
                messages   = {{ role = "user", content = prompt }},
            })
            local response = httpRequest({
                Url    = "https://api.anthropic.com/v1/messages",
                Method = "POST",
                Headers = {
                    ["Content-Type"]      = "application/json",
                    ["x-api-key"]         = ANTHROPIC_API_KEY,
                    ["anthropic-version"] = "2023-06-01",
                },
                Body = body,
            })
            if not response then
                return nil, "No HTTP function found. Your executor may not support HTTP requests."
            end
            if response.StatusCode ~= 200 then
                return nil, "API error " .. tostring(response.StatusCode) .. ": " .. (response.Body or "")
            end
            local data = HttpService:JSONDecode(response.Body)
            if data and data.content and data.content[1] and data.content[1].text then
                return data.content[1].text
            end
            return nil, "Unexpected API response."
        end)

        if ok and res then
            callback(true, res)
        else
            callback(false, tostring(res))
        end
    end)
end

