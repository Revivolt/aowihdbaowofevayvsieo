local function scrollToBottom()
    task.defer(function()
        MsgScroll.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

local function updateBadge()
    local count = 0
    for _ in pairs(scriptUsers) do count += 1 end
    BadgeLabel.Text = string.format("● %d online", count)
    Badge.BackgroundColor3 = count > 0
        and Color3.fromRGB(30, 200, 100)
        or  Color3.fromRGB(100, 100, 120)
end

-- Add a message bubble to the scroll frame
local function addMessage(sender, body, msgType)
    -- msgType: "system" | "self" | "other"
    messageCount += 1
    if messageCount > CFG.MAX_MESSAGES then
        local first = MsgScroll:FindFirstChildWhichIsA("Frame")
        if first then first:Destroy() end
    end

    local Row = Instance.new("Frame")
    Row.Name             = "Msg_" .. messageCount
    Row.LayoutOrder      = messageCount
    Row.Size             = UDim2.new(1, 0, 0, 0)
    Row.AutomaticSize    = Enum.AutomaticSize.Y
    Row.BackgroundTransparency = 1
    Row.Parent           = MsgScroll

    local Label = Instance.new("TextLabel")
    Label.Size           = UDim2.new(1, 0, 0, 0)
    Label.AutomaticSize  = Enum.AutomaticSize.Y
    Label.BackgroundTransparency = 1
    Label.TextWrapped    = true
    Label.RichText       = true
    Label.TextSize       = 12
    Label.Font           = Enum.Font.Gotham
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent         = Row

    if msgType == "system" then
        Label.Text = string.format(
            '<font color="#4a5270"><i>⚙ %s</i></font>', body)
    elseif msgType == "self" then
        Label.Text = string.format(
            '<font color="#4a8aff"><b>%s</b></font><font color="#7080a0">: </font><font color="#ccd4ee">%s</font>',
            sender, body)
    else
        Label.Text = string.format(
            '<font color="#ff9044"><b>%s</b></font><font color="#7080a0">: </font><font color="#ccd4ee">%s</font>',
            sender, body)
    end

    scrollToBottom()
end

-- ─────────────────────────────────────────────────────────
--  CHAT CHANNEL
-- ─────────────────────────────────────────────────────────
local function getGeneralChannel()
    local channels = TextChatService:FindFirstChild("TextChannels")
    if channels then
        return channels:FindFirstChild("RBXGeneral")
    end
    return nil
end

local function trySendRaw(text)
    local ch = getGeneralChannel()
    if ch then
        -- pcall in case of rate limiting or other errors
        local ok, err = pcall(function()
            ch:SendAsync(text)
        end)
        if not ok then
            warn("[SecretChat] SendAsync failed:", err)
        end
    else
        warn("[SecretChat] RBXGeneral channel not found.")
    end
end

-- ─────────────────────────────────────────────────────────
--  HANDSHAKE & MESSAGING
-- ─────────────────────────────────────────────────────────
local function broadcastHandshake()
    trySendRaw(HS_FULL)
end

local function sendSecretMessage(text)
    text = text:match("^%s*(.-)%s*$")  -- trim whitespace
    if text == "" then return end
    trySendRaw(MSG_FULL .. text)
    addMessage(LocalPlayer.Name, text, "self")
end

-- ─────────────────────────────────────────────────────────
--  INTERCEPT INCOMING MESSAGES
-- ─────────────────────────────────────────────────────────
TextChatService.OnIncomingMessage = function(msg)
    local text   = msg.Text or ""
    local source = msg.TextSource
    if not source then return msg end

    local sender = Players:GetPlayerByUserId(source.UserId)
    if not sender or sender == LocalPlayer then
        -- Still suppress our own handshake / secret messages from Roblox chat
        if text:sub(1, #HS_FULL) == HS_FULL or text:sub(1, #MSG_FULL) == MSG_FULL then
            msg.Text = ""
        end
        return msg
    end

    -- ── Handshake detection ───────────────────────────────
    if text:sub(1, #HS_FULL) == HS_FULL then
        if not scriptUsers[sender.Name] then
            scriptUsers[sender.Name] = true
            updateBadge()
            addMessage("System",
                sender.Name .. " is running the script — chat unlocked 🔓", "system")
            -- Reply with our own handshake so they detect us too
            task.delay(0.5, broadcastHandshake)
        end
        msg.Text = ""   -- hide from Roblox chat
        return msg
    end

    -- ── Secret message ────────────────────────────────────
    if text:sub(1, #MSG_FULL) == MSG_FULL then
        local body = text:sub(#MSG_FULL + 1)
        if scriptUsers[sender.Name] then
            addMessage(sender.Name, body, "other")
        else
            -- Message arrived before handshake — accept and register them
            scriptUsers[sender.Name] = true
            updateBadge()
            addMessage(sender.Name, body, "other")
            addMessage("System",
                sender.Name .. " joined secret chat 🔓", "system")
            task.delay(0.5, broadcastHandshake)
        end
        msg.Text = ""   -- hide from Roblox chat
        return msg
    end

    return msg
end

