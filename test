-- ============================================================
-- ENTRY LOGIC
-- ============================================================
local capturedCount = 0
local seenIds = {}

local function setStatus(msg)
    statusLabel.Text = msg
end
local function flashStatus(msg)
    setStatus(msg)
    task.delay(2.5, function() setStatus("Listening for animations…") end)
end

local function addAnimationEntry(animId)
    local numId = extractNumericId(animId)
    if seenIds[numId] then
        flashStatus("Already captured: " .. numId)
        return
    end

    seenIds[numId] = true
    capturedCount += 1
    emptyLabel.Visible = false
    countLabel.Text = capturedCount .. " captured"
    setStatus("Fetching name…")

    -- ── Row ─────────────────────────────────────────────────
    local row = newFrame {
        LayoutOrder = capturedCount,
        Size = UDim2.new(1, 0, 0, ROW_H),
        BackgroundColor3 = W,
        BackgroundTransparency = 0.92,
        BorderSizePixel = 0,
        Parent = scrollFrame,
    }
    addCorner(row, 8)
    addStroke(row, 0.87, 1)

    -- Left accent bar
    local accent = newFrame {
        Size = UDim2.new(0, 3, 1, -18),
        Position = UDim2.new(0, 0, 0, 9),
        BackgroundColor3 = GREY,
        BackgroundTransparency = 0.60,
        BorderSizePixel = 0,
        Parent = row,
    }
    addCorner(accent, 2)

    -- Index badge
    local badge = newLabel {
        Size = UDim2.new(0, 22, 0, 22),
        Position = UDim2.new(0, 12, 0.5, -11),
        BackgroundColor3 = W,
        BackgroundTransparency = 0.86,
        Text = tostring(capturedCount),
        TextColor3 = W,
        TextTransparency = 0.12,
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        Parent = row,
    }
    badge.BackgroundTransparency = 0.86  -- override since newLabel forces 1
    local badgeBg = newFrame {
        Size = UDim2.new(0, 22, 0, 22),
        Position = UDim2.new(0, 12, 0.5, -11),
        BackgroundColor3 = W,
        BackgroundTransparency = 0.86,
        BorderSizePixel = 0,
        ZIndex = 1,
        Parent = row,
    }
    addCorner(badgeBg, 5)

    local badgeNum = newLabel {
        Size = UDim2.new(1, 0, 1, 0),
        Text = tostring(capturedCount),
        TextColor3 = W,
        TextTransparency = 0.12,
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        ZIndex = 2,
        Parent = badgeBg,
    }

    -- Text block
    local textBlock = newFrame {
        Size = UDim2.new(1, -110, 1, 0),
        Position = UDim2.new(0, 44, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = row,
    }

    local nameLabel = newLabel {
        Size = UDim2.new(1, 0, 0, 26),
        Position = UDim2.new(0, 0, 0, 10),
        Text = "Loading…",
        TextColor3 = W,
        TextTransparency = 0.08,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = textBlock,
    }

    local idLabel = newLabel {
        Size = UDim2.new(1, 0, 0, 16),
        Position = UDim2.new(0, 0, 0, 36),
        Text = numId,
        TextColor3 = GREY,
        TextTransparency = 0.14,
        TextSize = 10,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = textBlock,
    }

    -- Copy button
    local copyBtn = newButton {
        Size = UDim2.new(0, 52, 0, 28),
        Position = UDim2.new(1, -60, 0.5, -14),
        BackgroundColor3 = W,
        BackgroundTransparency = 0.86,
        Text = "Copy",
        TextColor3 = W,
        TextTransparency = 0.10,
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        Parent = row,
    }
    addCorner(copyBtn, 6)
    addStroke(copyBtn, 0.82, 1)
    hover(copyBtn, 0.68, 0.86)

    copyBtn.MouseButton1Click:Connect(function()
        setclipboard(numId)
        copyBtn.Text = "✓"
        copyBtn.BackgroundTransparency = 0.72
        flashStatus("Copied: " .. numId)
        task.delay(1.5, function()
            copyBtn.Text = "Copy"
            copyBtn.BackgroundTransparency = 0.86
        end)
    end)

    -- Fade in
    row.BackgroundTransparency = 1
    TweenService:Create(row, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 0.92
    }):Play()

    task.defer(function()
        scrollFrame.CanvasPosition = Vector2.new(0, math.huge)
    end)

    -- Async name fetch
    task.spawn(function()
        local name = fetchAnimName(numId)
        nameLabel.Text = name
        flashStatus("Captured: " .. name)
    end)
end

-- Clear
clearBtn.MouseButton1Click:Connect(function()
    for _, c in ipairs(scrollFrame:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    seenIds = {}
    capturedCount = 0
    countLabel.Text = "0 captured"
    emptyLabel.Visible = true
    flashStatus("Cleared all entries")
end)

-- ============================================================
-- ANIMATION DETECTION
-- ============================================================
local function onAnimationPlayed(track)
    if not track.Animation then return end
    local id = track.Animation.AnimationId
    if id and id ~= "" and not isDefaultAnimation(id) then
        addAnimationEntry(id)
    end
end

local function connectHumanoid(char)
    char:WaitForChild("Humanoid").AnimationPlayed:Connect(onAnimationPlayed)
end

connectHumanoid(player.Character or player.CharacterAdded:Wait())
player.CharacterAdded:Connect(connectHumanoid)

print("[AnimDetector] Loaded.")
