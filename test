-- Safely get full hierarchy path of an instance
local function getFullPath(inst)
    local parts = {}
    local cur = inst
    while cur and cur ~= game do
        table.insert(parts, 1, cur.Name)
        cur = cur.Parent
    end
    return table.concat(parts, " > ")
end

-- Try to read .Source (works in Studio or with executor decompile access)
local function tryGetSource(script)
    local ok, src = pcall(function() return script.Source end)
    if ok and type(src) == "string" and #src > 0 then
        return src
    end
    -- Fallback: try decompile if executor exposes it
    if type(decompile) == "function" then
        local ok2, decomp = pcall(decompile, script)
        if ok2 and type(decomp) == "string" and #decomp > 0 then
            return "-- [DECOMPILED]\n" .. decomp
        end
    end
    return nil
end

-- Collect all readable properties into a table
local function collectProps(script)
    local props = {}
    local checks = {
        "Name", "ClassName", "Disabled", "RunContext",
        "LinkedSource", "ScriptGuid",
    }
    for _, key in ipairs(checks) do
        local ok, val = pcall(function() return script[key] end)
        if ok then
            props[key] = tostring(val)
        end
    end
    return props
end

-- Build the full text report for a captured entry
local function buildReport(entry)
    local lines = {}
    table.insert(lines, "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    table.insert(lines, "  SCRIPT CAPTURE REPORT")
    table.insert(lines, "  Captured at: " .. entry.time)
    table.insert(lines, "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    table.insert(lines, "")
    table.insert(lines, "[ IDENTITY ]")
    table.insert(lines, "  Name      : " .. tostring(entry.name))
    table.insert(lines, "  ClassName : " .. tostring(entry.className))
    table.insert(lines, "  Path      : " .. tostring(entry.path))
    table.insert(lines, "")
    table.insert(lines, "[ PROPERTIES ]")
    for k, v in pairs(entry.props) do
        if k ~= "Name" and k ~= "ClassName" then
            table.insert(lines, string.format("  %-16s: %s", k, v))
        end
    end
    table.insert(lines, "")
    if entry.source then
        table.insert(lines, "[ SOURCE CODE ]")
        table.insert(lines, "")
        table.insert(lines, entry.source)
    else
        table.insert(lines, "[ SOURCE CODE ]")
        table.insert(lines, "")
        table.insert(lines, "-- Source not accessible in this environment.")
        table.insert(lines, "-- Run in Roblox Studio (Play Solo) or via an executor")
        table.insert(lines, "-- that provides decompile() access to read full source.")
    end
    table.insert(lines, "")
    table.insert(lines, "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    return table.concat(lines, "\n")
end

-- Set clipboard (works in Studio and most executors)
local function copyToClipboard(text)
    -- Try setclipboard (executor global)
    if type(setclipboard) == "function" then
        pcall(setclipboard, text)
        return true
    end
    -- Try toclipboard (some executors)
    if type(toclipboard) == "function" then
        pcall(toclipboard, text)
        return true
    end
    -- Studio fallback via Selection (won't work at runtime but harmless)
    return false
end

