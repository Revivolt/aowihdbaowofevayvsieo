-- ============================================================
--  SPEED / DURATION  (controlled by slider below)
-- ============================================================
local SPEED_MIN = 0.1
local SPEED_MAX = 3.0
local ANIM_DURATION = 1.0  -- live value, updated by slider

-- ============================================================
--  PRE-LOAD ANIMATION OBJECTS
-- ============================================================
local loadedAnimations = {}
for char, id in pairs(ANIMATION_IDS) do
    local anim = Instance.new("Animation")
    anim.AnimationId = id
    loadedAnimations[char] = anim
end

-- ============================================================
--  ANIMATION PLAYBACK
-- ============================================================
local isPlaying = false
local currentTrack = nil

local function stopCurrentTrack()
    if currentTrack and currentTrack.IsPlaying then
        currentTrack:Stop(0)
    end
    currentTrack = nil
end

local function playAnimationsForText(text)
    if isPlaying then return end
    isPlaying = true
    local upperText = string.upper(text)
    for i = 1, #upperText do
        if not isPlaying then break end
        local char = string.sub(upperText, i, i)
        local animObject = loadedAnimations[char]
        if animObject then
            stopCurrentTrack()
            local track = animator:LoadAnimation(animObject)
            track.Priority = Enum.AnimationPriority.Action
            track:Play(0)
            currentTrack = track
            task.wait(ANIM_DURATION)   -- uses live slider value
        else
            task.wait(0.2)
        end
    end
    stopCurrentTrack()
    isPlaying = false
end

