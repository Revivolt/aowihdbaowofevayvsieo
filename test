--  PANEL TOGGLE LOGIC
-- ══════════════════════════════════════════════════════════════════════
local panelMap = {
    {btn = BtnMenu,   panel = MenuPanel},
    {btn = BtnChat,   panel = ChatPanel},
    {btn = BtnGlobal, panel = GlobalPanel},
}

for _, entry in ipairs(panelMap) do
    entry.btn.MouseButton1Click:Connect(function()
        local opening = not entry.panel.Visible
        -- Close all panels and deactivate all buttons first
        for _, e in ipairs(panelMap) do
            e.panel.Visible = false
            setActiveBtn(e.btn, false)
        end
        -- Then open the clicked one
        if opening then
            entry.panel.Visible = true
            setActiveBtn(entry.btn, true)
        end
    end)
end

