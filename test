codeText.TextXAlignment    = Enum.TextXAlignment.Left
codeText.TextYAlignment    = Enum.TextYAlignment.Top
codeText.TextWrapped       = true
codeText.RichText          = false
codeText.Parent            = codeInner

-- Whenever the inner frame resizes → update canvas height and scroll to top
codeInner:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
    codeScroll.CanvasSize = UDim2.new(0, 0, 0, codeInner.AbsoluteSize.Y + 20)
end)

-- Helper: set text, update canvas, reset scroll to top
local function setCodeText(text, color)
    codeText.Text       = text
    codeText.TextColor3 = color or T.CODE_TX
    task.defer(function()
        if not (codeScroll and codeScroll.Parent) then return end
        codeScroll.CanvasSize     = UDim2.new(0, 0, 0, codeInner.AbsoluteSize.Y + 20)
        codeScroll.CanvasPosition = Vector2.new(0, 0)
    end)
end

