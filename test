--  SERVER CHAT
-- ════════════════════════════════════════════════════════════════════
local ChatPanel, chatBox, chatSendBtn, addLocalMsg =
    makeChatPanel("Chat", 305, 410, "  💬  Server Chat", T.ACCENT,
        "Message players on this server…")

addLocalMsg(nil, "📡 Visible to others on this server running the same script.", true)
addLocalMsg(nil, "—————————————————————————————————", true)

-- RemoteEvent relay (optional server script makes this cross-player)
local LocalRemote = nil
task.spawn(function()
    local folder = ReplicatedStorage:FindFirstChild("CGUI")
               or make("Folder", {Name = "CGUI"}, ReplicatedStorage)
    local re = folder:FindFirstChild("Chat")
            or make("RemoteEvent", {Name = "Chat"}, folder)
    LocalRemote = re
    re.OnClientEvent:Connect(function(sender, msg)
        if type(sender) ~= "string" or type(msg) ~= "string" then return end
        if sender == LocalPlayer.Name then return end
        addLocalMsg(sender, msg)
    end)
end)

local lastChat = 0
local function sendLocal()
    local txt = chatBox.Text:match("^%s*(.-)%s*$")
    if txt == "" or tick() - lastChat < 1 then return end
    lastChat = tick()
    chatBox.Text = ""
    txt = txt:sub(1, MAX_LEN)
    addLocalMsg(LocalPlayer.Name, txt)
    if LocalRemote then pcall(function() LocalRemote:FireServer(txt) end) end
end

chatSendBtn.MouseButton1Click:Connect(sendLocal)
chatBox.FocusLost:Connect(function(enter) if enter then sendLocal() end end)

