-- ─────────────────────────────────────────────────────────────────────────────
-- CAPTURE (only called AFTER snapshot is taken)
-- ─────────────────────────────────────────────────────────────────────────────
local function captureInjected(inst)
    if not (inst:IsA("LocalScript") or inst:IsA("ModuleScript") or inst:IsA("Script")) then
        return
    end
    -- Deduplicate
    for _, e in ipairs(captured) do
        if e.instance == inst then return end
    end

    local entry = {
        instance  = inst,
        name      = inst.Name,
        className = inst.ClassName,
        path      = getPath(inst),
        props     = collectProps(inst),
        source    = trySource(inst),
        time      = os.date("%X"),
    }
    table.insert(captured, entry)
    local idx = #captured

    cntLbl.Text = tostring(idx)
    addRow(idx, entry)

    -- Flash status bar
    sbarTxt.Text       = string.format("  ⚠  Injection detected: %s  |  Total: %d  |  %s", entry.name, idx, entry.time)
    sbarTxt.TextColor3 = T.DANGER
    task.delay(4, function()
        if sbarTxt and sbarTxt.Parent then
            sbarTxt.Text       = "  ✓  Monitoring for injections…"
            sbarTxt.TextColor3 = T.SUCCESS
        end
    end)

    print(string.format("[InjectionDetector] Caught: %s (%s) @ %s", entry.name, entry.className, entry.path))
end

-- ─────────────────────────────────────────────────────────────────────────────
-- SNAPSHOT + ACTIVATION
-- ─────────────────────────────────────────────────────────────────────────────
--
-- We wait for the game to fully load, then snapshot EVERY script currently
-- in the DataModel into a weak-reference set. After that, DescendantAdded
-- on `game` is the only thing that can add to `captured`.
--
task.spawn(function()
    -- 1. Wait for basic replication to finish
    if not game:IsLoaded() then
        game.Loaded:Wait()
    end

    -- 2. Extra frame buffer so late-loading scripts settle
    for _ = 1, 10 do RunService.Heartbeat:Wait() end

    -- 3. Build snapshot of all existing scripts
    local snapshot = {}    -- [instance] = true
    for _, desc in ipairs(game:GetDescendants()) do
        if desc:IsA("LuaSourceContainer") then
            snapshot[desc] = true
        end
    end
    local snapCount = 0
    for _ in pairs(snapshot) do snapCount = snapCount + 1 end

    -- 4. Mark ready + update UI
    isReady = true

    pillTxt.Text             = "ARMED"
    pillDot.TextColor3       = T.SUCCESS
    pillTxt.TextColor3       = T.SUCCESS
    pill.BackgroundColor3    = Color3.fromRGB(20, 55, 30)

    sbarTxt.Text       = string.format("  ✓  Monitoring active — %d existing scripts ignored", snapCount)
    sbarTxt.TextColor3 = T.SUCCESS

    detailTxt.Text       = string.format(
        "-- Ready.\n-- %d pre-existing scripts have been snapshoted and ignored.\n"..
        "-- Any new script injected from this point will appear in the list.",
        snapCount
    )
    detailTxt.TextColor3 = T.SUBTEXT

    -- 5. Watch the ENTIRE game tree for new script descendants
    --    Only fire if the instance is NOT in our snapshot.
    local conn = game.DescendantAdded:Connect(function(inst)
        if not isReady then return end
        if snapshot[inst] then return end   -- was already there at load time
        -- Small defer so the script has a parent and path set
        task.defer(function()
            pcall(captureInjected, inst)
        end)
    end)
    table.insert(connections, conn)

    print(string.format("[InjectionDetector] Armed. %d existing scripts ignored. Watching for injections…", snapCount))
end)
