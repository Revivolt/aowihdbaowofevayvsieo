local function addRow(index, entry)
    local isEven = (index % 2 == 0)
    local row = Instance.new("TextButton")
    row.Name = "R_"..index; row.Size = UDim2.new(1,0,0,56)
    row.BackgroundColor3 = isEven and T.ROW_A or T.ROW_B
    row.BorderSizePixel = 0; row.Text = ""; row.AutoButtonColor = false
    row.Parent = listScroll; corner(row, 5)

    local bar2 = Instance.new("Frame")
    bar2.Size = UDim2.new(0,3,0.6,0); bar2.Position = UDim2.new(0,0,0.2,0)
    bar2.BackgroundColor3 = T.DANGER; bar2.BorderSizePixel = 0; bar2.Parent = row; corner(bar2, 2)

    local ib = Instance.new("Frame")
    ib.Size = UDim2.new(0,18,0,14); ib.Position = UDim2.new(0,7,0,5)
    ib.BackgroundColor3 = Color3.fromRGB(80,20,20); ib.Parent = row; corner(ib, 4)
    local il = lbl(ib, tostring(index), 9, T.DANGER)
    il.Size = UDim2.new(1,0,1,0); il.TextXAlignment = Enum.TextXAlignment.Center; il.Font = Enum.Font.GothamBold

    local mb = Instance.new("Frame")
    mb.Size = UDim2.new(0,0,0,14); mb.Position = UDim2.new(0,30,0,5)
    mb.BackgroundColor3 = Color3.fromRGB(15,45,70); mb.AutomaticSize = Enum.AutomaticSize.X; mb.Parent = row; corner(mb, 4)
    local ml = lbl(mb, " "..entry.method.." ", 9, Color3.fromRGB(100,200,255))
    ml.Size = UDim2.new(0,0,1,0); ml.AutomaticSize = Enum.AutomaticSize.X; ml.Font = Enum.Font.GothamBold

    local nl = lbl(row, entry.name, 13, T.TEXT)
    nl.Size = UDim2.new(1,-14,0,18); nl.Position = UDim2.new(0,8,0,24)
    nl.Font = Enum.Font.GothamBold; nl.TextTruncate = Enum.TextTruncate.AtEnd

    local cl2 = lbl(row, entry.className, 10, T.SUB)
    cl2.Size = UDim2.new(1,-80,0,14); cl2.Position = UDim2.new(0,8,0,42)

    local tl = lbl(row, entry.time, 9, T.SUB)
    tl.Size = UDim2.new(0,60,0,12); tl.Position = UDim2.new(1,-64,0,38)
    tl.TextXAlignment = Enum.TextXAlignment.Right

    local sd = lbl(row, entry.source and "⬤" or "○", 9, entry.source and T.SUCCESS or T.WARNING)
    sd.Size = UDim2.new(0,10,0,10); sd.Position = UDim2.new(1,-13,0,5)

    local normalBG = isEven and T.ROW_A or T.ROW_B
    local function deselAll()
        for _, ch in ipairs(listScroll:GetChildren()) do
            if ch:IsA("TextButton") then
                local n = tonumber(ch.Name:match("R_(%d+)"))
                if n then ch.BackgroundColor3 = (n%2==0) and T.ROW_A or T.ROW_B end
            end
        end
    end

    row.MouseButton1Click:Connect(function()
        deselAll(); row.BackgroundColor3 = T.ROW_SEL
        selectedIdx = index; viewingDeob = false
        detailTitleL.Text = "📄  " .. entry.name
        refreshView()
    end)
    row.MouseEnter:Connect(function()
        if selectedIdx ~= index then row.BackgroundColor3 = Color3.fromRGB(25,22,16) end
    end)
    row.MouseLeave:Connect(function()
        if selectedIdx ~= index then row.BackgroundColor3 = normalBG end
    end)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- REGISTER A CAPTURE
-- ─────────────────────────────────────────────────────────────────────────────
local function registerCapture(inst, method)
    for _, e in ipairs(captured) do if e.instance == inst then return end end
    local entry = {
        instance   = inst,
        name       = inst.Name,
        className  = inst.ClassName,
        path       = getPath(inst),
        props      = collectProps(inst),
        source     = trySource(inst),
        deobSource = nil,
        time       = os.date("%X"),
        method     = method or "DataModel",
    }
    table.insert(captured, entry)
    local idx = #captured
    cntLbl.Text = tostring(idx)
    addRow(idx, entry)
    setStatus(string.format("⚠  Injection: %s  [%s]  @ %s", entry.name, entry.method, entry.time), T.DANGER)
    warn(string.format("[InjDetect] Caught '%s' via %s", entry.name, entry.method))
end

-- ─────────────────────────────────────────────────────────────────────────────
-- FILTER
-- ─────────────────────────────────────────────────────────────────────────────
local function shouldIgnore(inst)
    if not (inst:IsA("LocalScript") or inst:IsA("ModuleScript") or inst:IsA("Script")) then return true end
    if snapshot[inst] then return true end
    if ROBLOX_DEFAULTS[inst.Name] then return true end
    local cur = inst.Parent
    while cur do
        if cur == workspace then break end
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character and cur == p.Character then return true end
        end
        cur = cur.Parent
    end
    return false
end

-- ─────────────────────────────────────────────────────────────────────────────
-- HOOK loadstring
-- ─────────────────────────────────────────────────────────────────────────────
local function tryHookLoadstring()
    if type(hookfunction) ~= "function" or type(loadstring) ~= "function" then return false end
    local orig = loadstring
    local ok = pcall(hookfunction, loadstring, function(src, chunkName)
        if armed and type(src) == "string" and #src > 0 then
            local sig = src:sub(1, 80)
            local dup = false
            for _, e in ipairs(captured) do
                if e.source and e.source:sub(1,80) == sig then dup = true; break end
            end
            if not dup then
                local entry = {
                    instance = nil, name = chunkName or "(anonymous loadstring)",
                    className = "loadstring", path = chunkName or "N/A",
                    props = {Chunk = tostring(chunkName)}, source = src,
                    deobSource = nil, time = os.date("%X"), method = "loadstring",
                }
                table.insert(captured, entry)
                local idx = #captured
                cntLbl.Text = tostring(idx)
                addRow(idx, entry)
                setStatus(string.format("⚠  loadstring: %s  @ %s", entry.name, entry.time), T.DANGER)
            end
        end
        return orig(src, chunkName)
    end)
    return ok
end

