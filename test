local function iconBtn(icon, color, tipText)
    local wrap = inst("Frame",{
        Size=UDim2.new(1,0,0,36),
        BackgroundTransparency=1,
        ZIndex=3,
    },Card)

    local btn = inst("TextButton",{
        Size=UDim2.new(1,0,1,0),
        BackgroundColor3=C.RAISED,
        Text=icon,
        TextColor3=C.TEXT,
        TextSize=18,
        Font=Enum.Font.GothamBold,
        AutoButtonColor=false,
        ZIndex=4,
    },wrap)
    rnd(btn,10)

    -- Coloured bottom accent line
    local accent = inst("Frame",{
        Size=UDim2.new(0.6,0,0,2),
        Position=UDim2.new(0.2,0,1,-3),
        BackgroundColor3=color,
        BorderSizePixel=0,
        Visible=false,
        ZIndex=5,
    },btn)
    rnd(accent,1)

    -- Hover / press feedback
    btn.MouseEnter:Connect(function()
        tw(btn,{BackgroundColor3=color:Lerp(C.RAISED,0.6)})
        tw(btn,{TextColor3=color})
    end)
    btn.MouseLeave:Connect(function()
        tw(btn,{BackgroundColor3=C.RAISED})
        tw(btn,{TextColor3=C.TEXT})
    end)

    -- Tooltip (appears to the right of card)
    local tip = inst("TextLabel",{
        Size=UDim2.new(0,0,0,26),
        AutomaticSize=Enum.AutomaticSize.X,
        Position=UDim2.new(1,6,0.5,-13),
        AnchorPoint=Vector2.new(0,0.5),
        BackgroundColor3=C.RAISED,
        Text="  "..tipText.."  ",
        TextColor3=C.TEXT,
        TextSize=12,
        Font=Enum.Font.Gotham,
        Visible=false,
        ZIndex=20,
    },btn)
    rnd(tip,6)
    brdr(tip,C.BORDER,1)
    btn.MouseEnter:Connect(function() tip.Visible=true  end)
    btn.MouseLeave:Connect(function() tip.Visible=false end)

    local function setActive(on)
        accent.Visible=on
        if on then
            tw(btn,{BackgroundColor3=color:Lerp(C.RAISED,0.5)})
            tw(btn,{TextColor3=color})
        else
            tw(btn,{BackgroundColor3=C.RAISED})
            tw(btn,{TextColor3=C.TEXT})
        end
    end

    return btn, setActive
end

