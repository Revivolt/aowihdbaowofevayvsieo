    local bar2 = Instance.new("Frame"); bar2.Size = UDim2.new(0,3,0.6,0); bar2.Position = UDim2.new(0,0,0.2,0); bar2.BackgroundColor3 = T.DANGER; bar2.BorderSizePixel = 0; bar2.Parent = row; corner(bar2,2)

    local ib = Instance.new("Frame"); ib.Size = UDim2.new(0,18,0,14); ib.Position = UDim2.new(0,7,0,5); ib.BackgroundColor3 = Color3.fromRGB(80,20,20); ib.Parent = row; corner(ib,4)
