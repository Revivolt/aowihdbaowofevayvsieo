-- VibrateScript (LocalScript)
-- Place in StarterCharacterScripts
-- Vibrates your character SO fast it becomes a blur/unrecognizable
-- 100% client-side — other players see you standing completely still

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local Character   = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HRP         = Character:WaitForChild("HumanoidRootPart")

-- ============================================================
--  CONFIG
-- ============================================================
local TOGGLE_KEY   = Enum.KeyCode.Q   -- Hold to vibrate
local INTENSITY    = 9999                -- How far each shake goes (studs). 8 = full blur
local SPEED_MULT   = 9999                -- 1 = every frame. Lower = slower (not recommended)
-- ============================================================

local vibrating    = false
local originCF     = nil
local flip         = 1

-- Respawn support
LocalPlayer.CharacterAdded:Connect(function(c)
    Character  = c
    HRP        = c:WaitForChild("HumanoidRootPart")
    vibrating  = false
    originCF   = nil
    flip       = 1
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == TOGGLE_KEY then
        vibrating = true
        originCF  = HRP.CFrame  -- lock the origin the moment you press
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == TOGGLE_KEY then
        vibrating = false
        -- Snap back to where you started so you don't drift
        if originCF then
            HRP.CFrame = originCF
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if not vibrating then return end
    if not HRP or not HRP.Parent then return end

    -- Flip the offset direction every single frame (max frequency possible)
    flip = flip * -1

    local randX = (math.random() - 0.5) * 2 * INTENSITY
    local randY = (math.random() - 0.5) * 2 * INTENSITY
    local randZ = (math.random() - 0.5) * 2 * INTENSITY

    -- Apply a random offset from origin every frame — creates the blur effect
    HRP.CFrame = originCF * CFrame.new(randX * flip, randY * flip, randZ * flip)
end)

print("[VibrateScript] Loaded! Hold", TOGGLE_KEY.Name, "to vibrate into a blur.")
