--  CHAT PANEL BUILDER
-- ════════════════════════════════════════════════════════════════════
local COLORS = {
    Color3.fromRGB(0,162,255), Color3.fromRGB(255,80,80),
    Color3.fromRGB(60,210,90), Color3.fromRGB(255,195,0),
    Color3.fromRGB(195,90,255), Color3.fromRGB(255,135,35),
    Color3.fromRGB(0,215,195), Color3.fromRGB(255,70,175),
}
local nameColors, nameIdx = {}, 0
local function getNameColor(n)
    if not nameColors[n] then
        nameIdx = (nameIdx % #COLORS) + 1
        nameColors[n] = COLORS[nameIdx]
    end
    return nameColors[n]
end

local function makeChatPanel(name, w, h, title, accent, ph)
    local panel = makePanel(name, w, h, title, accent)

    local scroll = make("ScrollingFrame", {
        Size                 = UDim2.new(1, -2, 1, -96),
        Position             = UDim2.new(0, 1, 0, 46),
        BackgroundTransparency = 1,
        ScrollBarThickness   = 4,
        ScrollBarImageColor3 = accent,
        CanvasSize           = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize  = Enum.AutomaticSize.Y,
        ElasticBehavior      = Enum.ElasticBehavior.Never,
        ZIndex               = 6,
    }, panel)
    make("UIListLayout", {Padding = UDim.new(0, 3), SortOrder = Enum.SortOrder.LayoutOrder}, scroll)
    addPad(scroll, 7)

    -- Divider
    make("Frame", {
        Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -50),
        BackgroundColor3 = T.BORDER, BorderSizePixel = 0, ZIndex = 6,
    }, panel)

    -- Input row
    local inputRow = make("Frame", {
        Size = UDim2.new(1, 0, 0, 48), Position = UDim2.new(0, 0, 1, -48),
        BackgroundColor3 = T.BG2, ZIndex = 6,
    }, panel)
    -- Fill top-round corners of input row
    make("Frame", {
        Size = UDim2.new(1, 0, 0, 8), BackgroundColor3 = T.BG2, BorderSizePixel = 0, ZIndex = 6,
    }, inputRow)
    addCorner(inputRow, 10)

    local tbox = make("TextBox", {
        Size                = UDim2.new(1, -50, 1, -12),
        Position            = UDim2.new(0, 6, 0, 6),
        BackgroundColor3    = T.BG3,
        TextColor3          = T.TEXT,
        PlaceholderText     = ph or "Type a message…",
        PlaceholderColor3   = T.DIMTEXT,
        Text                = "",
        TextSize            = 12,
        Font                = Enum.Font.Gotham,
        ClearTextOnFocus    = false,
        TextXAlignment      = Enum.TextXAlignment.Left,
        ZIndex              = 7,
    }, inputRow)
    addCorner(tbox, 6); addPad(tbox, 7)

    local sendBtn = make("TextButton", {
        Size = UDim2.new(0, 34, 0, 30), Position = UDim2.new(1, -40, 0, 9),
        BackgroundColor3 = accent, Text = "➤", TextColor3 = T.WHITE,
        TextSize = 14, Font = Enum.Font.GothamBold, AutoButtonColor = false, ZIndex = 7,
    }, inputRow)
    addCorner(sendBtn, 6)
    onHover(sendBtn, accent, accent:Lerp(T.WHITE, 0.15))

    local mc = 0
    local function addMsg(sender, text, sys)
        mc += 1
        local col = sys and T.DIMTEXT or getNameColor(sender or "")

        local bubble = make("Frame", {
            Name = "M"..mc, Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = T.BG2, BackgroundTransparency = sys and 1 or 0,
            LayoutOrder = mc, ZIndex = 6,
        }, scroll)
        if not sys then addCorner(bubble, 6) end

        local inner = make("Frame", {
            Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1, ZIndex = 7,
        }, bubble)
        addPad(inner, 4)
        make("UIListLayout", {Padding = UDim.new(0, 1)}, inner)

        if not sys then
            local nr = make("Frame", {
                Size = UDim2.new(1, 0, 0, 15), BackgroundTransparency = 1, ZIndex = 7,
            }, inner)
            make("Frame", {
                Size = UDim2.new(0, 3, 1, -2), Position = UDim2.new(0, 0, 0, 1),
                BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 8,
            }, nr)
            make("TextLabel", {
                Size = UDim2.new(1, -7, 1, 0), Position = UDim2.new(0, 7, 0, 0),
                BackgroundTransparency = 1, Text = sender, TextColor3 = col,
                TextSize = 10, Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 8,
            }, nr)
        end

        make("TextLabel", {
            Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1, Text = text,
            TextColor3 = sys and T.DIMTEXT or T.TEXT,
            TextSize = 12, Font = sys and Enum.Font.GothamItalic or Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true, ZIndex = 7,
        }, inner)

        task.defer(function()
            scroll.CanvasPosition = Vector2.new(0, math.huge)
        end)

        local frames = {}
        for _, c in ipairs(scroll:GetChildren()) do
            if c:IsA("Frame") then frames[#frames+1] = c end
        end
        if #frames > 60 then
            table.sort(frames, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
            frames[1]:Destroy()
        end
    end

    return panel, tbox, sendBtn, addMsg
end

