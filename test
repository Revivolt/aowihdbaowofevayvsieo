local function isDefaultAnimation(animId)
    if DEFAULT_ANIMATION_IDS[animId] then return true end
    local numId = tonumber(animId:match("%d+$"))
    if numId and DEFAULT_NUMERIC_IDS[numId] then return true end
    return false
end

local function extractNumericId(animId)
    return animId:match("%d+$") or animId
end

-- ============================================================
-- FETCH ANIMATION NAME  (async, pcall-protected)
-- ============================================================
local function fetchAnimName(numericId)
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(tonumber(numericId), Enum.InfoType.Asset)
    end)
    if ok and info and info.Name then
        return info.Name
    end
    return "Unknown"
end

