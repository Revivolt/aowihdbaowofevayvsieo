--  NOTIFICATION SYSTEM
-- ════════════════════════════════════════════════════════════════════
local notifEnabled = true
local nQueue = {}
local nBusy  = false

local function showNotif(title, body, color)
    if not notifEnabled then return end
    table.insert(nQueue, {title = title, body = body, color = color or T.ACCENT})
    if nBusy then return end
    nBusy = true
    task.spawn(function()
        while #nQueue > 0 do
            local n = table.remove(nQueue, 1)
            local box = new("Frame", {
                Size             = UDim2.new(0, 260, 0, 62),
                Position         = UDim2.new(1, 10, 1, -70),
                AnchorPoint      = Vector2.new(1, 1),
                BackgroundColor3 = T.BG2,
                ZIndex           = 500,
            }, Root)
            corner(box, 9)
            stroke(box, n.color, 1)
            new("Frame", {
                Size             = UDim2.new(0, 3, 1, -10),
                Position         = UDim2.new(0, 0, 0, 5),
                BackgroundColor3 = n.color,
                BorderSizePixel  = 0,
                ZIndex           = 501,
            }, box)
            new("TextLabel", {
                Size                   = UDim2.new(1, -10, 0, 20),
                Position               = UDim2.new(0, 10, 0, 6),
                BackgroundTransparency = 1,
                Text                   = n.title,
                TextColor3             = n.color,
                TextSize               = 13,
                Font                   = Enum.Font.GothamBold,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 501,
            }, box)
            new("TextLabel", {
                Size                   = UDim2.new(1, -10, 0, 24),
                Position               = UDim2.new(0, 10, 0, 26),
                BackgroundTransparency = 1,
                Text                   = n.body,
                TextColor3             = T.TEXT_DIM,
                TextSize               = 11,
                Font                   = Enum.Font.Gotham,
                TextWrapped            = true,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 501,
            }, box)
            tw(box, {Position = UDim2.new(1, -8, 1, -70)}, 0.2)
            task.wait(3.2)
            tw(box, {Position = UDim2.new(1, 280, 1, -70)}, 0.2)
            task.wait(0.25)
            box:Destroy()
            task.wait(0.1)
        end
        nBusy = false
    end)
end

