-- Active highlight line under button
local function setActive(btn, on)
    -- find or create underline
    local ul = btn:FindFirstChild("Underline")
    if not ul then
        ul = new("Frame", {
            Name             = "Underline",
            Size             = UDim2.new(0.7, 0, 0, 2),
            Position         = UDim2.new(0.15, 0, 1, -2),
            BackgroundColor3 = T.ACCENT,
            BorderSizePixel  = 0,
            ZIndex           = 103,
        }, btn)
        corner(ul, 1)
    end
    ul.Visible = on
    tw(btn, {TextColor3 = on and T.ACCENT or Color3.new(1,1,1)})
end

