--  CHAT PANEL HELPER
-- ══════════════════════════════════════════════════════════════════════
local playerColors = {}
local colorList    = {
    Color3.fromRGB(0,162,255), Color3.fromRGB(255,80,80),
    Color3.fromRGB(80,220,80), Color3.fromRGB(255,200,0),
    Color3.fromRGB(190,90,255), Color3.fromRGB(255,135,40),
    Color3.fromRGB(0,215,195),  Color3.fromRGB(255,80,175),
}
local colorCursor = 0

local function playerColor(name)
    if not playerColors[name] then
        colorCursor = (colorCursor % #colorList) + 1
        playerColors[name] = colorList[colorCursor]
    end
    return playerColors[name]
end

local function buildChatPanel(panelName, w, h, title, accent, hint)
    local panel = makePanel(panelName, w, h, title, accent)

    local scroll = make("ScrollingFrame", {
        Size                 = UDim2.new(1, -4, 1, -94),
        Position             = UDim2.new(0, 2, 0, 46),
        BackgroundTransparency = 1,
        ScrollBarThickness   = 4,
        ScrollBarImageColor3 = accent,
        CanvasSize           = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize  = Enum.AutomaticSize.Y,
        ElasticBehavior      = Enum.ElasticBehavior.Never,
        ZIndex               = 21,
    }, panel)
    make("UIListLayout", {Padding = UDim.new(0, 3), SortOrder = Enum.SortOrder.LayoutOrder}, scroll)
    addPadding(scroll, 7)

    -- Thin divider
    make("Frame", {
        Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -48),
        BackgroundColor3 = T.BORDER, BorderSizePixel = 0, ZIndex = 21,
    }, panel)

    -- Input bar
    local inputBar = make("Frame", {
        Size = UDim2.new(1, 0, 0, 46), Position = UDim2.new(0, 0, 1, -46),
        BackgroundColor3 = T.BG2, ZIndex = 21,
    }, panel)
    -- fill top round corners of bar
    make("Frame", {
        Size = UDim2.new(1, 0, 0, 8), BackgroundColor3 = T.BG2,
        BorderSizePixel = 0, ZIndex = 21,
    }, inputBar)

    local textBox = make("TextBox", {
        Size = UDim2.new(1, -50, 1, -12), Position = UDim2.new(0, 6, 0, 6),
        BackgroundColor3 = T.BG3, TextColor3 = T.TEXT,
        PlaceholderText = hint, PlaceholderColor3 = T.DIM,
        Text = "", TextSize = 13, Font = Enum.Font.Gotham,
        ClearTextOnFocus = false,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 22,
    }, inputBar)
    addCorner(textBox, 6)
    addPadding(textBox, 7)

    local sendBtn = make("TextButton", {
        Size = UDim2.new(0, 34, 0, 30), Position = UDim2.new(1, -40, 0, 8),
        BackgroundColor3 = accent, Text = "➤", TextColor3 = T.WHITE,
        TextSize = 14, Font = Enum.Font.GothamBold,
        AutoButtonColor = false, ZIndex = 22,
    }, inputBar)
    addCorner(sendBtn, 6)
    onHover(sendBtn, accent, accent:Lerp(T.WHITE, 0.15))

    local n = 0
    local function addMessage(sender, text, isSystem)
        n += 1
        local col = isSystem and T.DIM or playerColor(sender or "?")

        local bubble = make("Frame", {
            Name = ("M%d"):format(n),
            Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = T.BG2,
            BackgroundTransparency = isSystem and 1 or 0,
            LayoutOrder = n, ZIndex = 22,
        }, scroll)
        if not isSystem then addCorner(bubble, 5) end

        local inner = make("Frame", {
            Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1, ZIndex = 23,
        }, bubble)
        addPadding(inner, 5)
        make("UIListLayout", {Padding = UDim.new(0, 1)}, inner)

        if not isSystem then
            local nameRow = make("Frame", {
                Size = UDim2.new(1, 0, 0, 16), BackgroundTransparency = 1, ZIndex = 23,
            }, inner)
            make("Frame", {
                Size = UDim2.new(0, 2, 1, -4), Position = UDim2.new(0, 0, 0, 2),
                BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 24,
            }, nameRow)
            make("TextLabel", {
                Size = UDim2.new(1, -6, 1, 0), Position = UDim2.new(0, 6, 0, 0),
                BackgroundTransparency = 1, Text = sender, TextColor3 = col,
                TextSize = 11, Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 24,
            }, nameRow)
        end

        make("TextLabel", {
            Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1, Text = text,
            TextColor3 = isSystem and T.DIM or T.TEXT,
            TextSize = 13,
            Font = isSystem and Enum.Font.GothamItalic or Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true, ZIndex = 23,
        }, inner)

        task.defer(function()
            scroll.CanvasPosition = Vector2.new(0, math.huge)
        end)

        -- Prune to 60 messages
        local frames = {}
        for _, c in ipairs(scroll:GetChildren()) do
            if c:IsA("Frame") then frames[#frames+1] = c end
        end
        if #frames > 60 then
            table.sort(frames, function(a,b) return a.LayoutOrder < b.LayoutOrder end)
            frames[1]:Destroy()
        end
    end

    return panel, textBox, sendBtn, addMessage
end

