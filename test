--  GLOBAL CHAT  (MessagingService — published games only)
-- ════════════════════════════════════════════════════════════════════
local GlobalPanel, globalBox, globalSend, addGlobalMsg =
    makeChatPanel("GlobalPanel", 310, 415,
        "  🌐  Global Chat", T.ACCENT_GLOB, "Message players across all servers…")

addGlobalMsg(nil, "🌐 Chat with everyone using this script across all servers.", true)
addGlobalMsg(nil, "⚠ Requires a published game — unavailable in Studio test.", true)
addGlobalMsg(nil, "──────────────────────────────────────────", true)

task.spawn(function()
    local ok, err = pcall(function()
        MessagingService:SubscribeAsync(GLOBAL_CHANNEL, function(data)
            local p = data.Data
            if type(p) ~= "table" then return end
            if type(p.sender) ~= "string" or type(p.msg) ~= "string" then return end
            -- Don't show our own message again (we already echoed it)
            if p.sender == LocalPlayer.Name and p.sid == SERVER_ID then return end
            local prefix = p.sid and ("[" .. p.sid .. "] ") or ""
            addGlobalMsg(prefix .. p.sender, p.msg:sub(1, MAX_LEN))
            if not GlobalPanel.Visible then
                showNotif("Global · " .. p.sender,
                    (p.msg):sub(1, 55), T.ACCENT_GLOB)
            end
        end)
    end)
    if not ok then
        addGlobalMsg(nil, "⚠ MessagingService: " .. tostring(err), true)
    end
end)

local lastGlobal = 0
local function doGlobalSend()
    local msg = globalBox.Text:match("^%s*(.-)%s*$")
    if msg == "" then return end
    if tick() - lastGlobal < 1.5 then return end
    lastGlobal = tick()
    globalBox.Text = ""
    msg = msg:sub(1, MAX_LEN)
    addGlobalMsg("[" .. SERVER_ID .. "] " .. LocalPlayer.Name, msg)
    task.spawn(function()
        local ok, err = pcall(function()
            MessagingService:PublishAsync(GLOBAL_CHANNEL, {
                sender = LocalPlayer.Name,
                msg    = msg,
                sid    = SERVER_ID,
            })
        end)
        if not ok then
            addGlobalMsg(nil, "⚠ Send failed: " .. tostring(err), true)
        end
    end)
end

globalSend.MouseButton1Click:Connect(doGlobalSend)
globalBox.FocusLost:Connect(function(enter) if enter then doGlobalSend() end end)

