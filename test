local function makeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function makeStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or THEME.BORDER
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function makePadding(parent, all, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    if all then
        p.PaddingTop    = UDim.new(0, all)
        p.PaddingBottom = UDim.new(0, all)
        p.PaddingLeft   = UDim.new(0, all)
        p.PaddingRight  = UDim.new(0, all)
    else
        if top    then p.PaddingTop    = UDim.new(0, top)    end
        if bottom then p.PaddingBottom = UDim.new(0, bottom) end
        if left   then p.PaddingLeft   = UDim.new(0, left)   end
        if right  then p.PaddingRight  = UDim.new(0, right)  end
    end
    p.Parent = parent
    return p
end

local function makeLabel(parent, text, size, color, halign)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextSize = size or 14
    l.TextColor3 = color or THEME.TEXT
    l.Font = Enum.Font.Gotham
    l.TextXAlignment = halign or Enum.TextXAlignment.Left
    l.TextWrapped = true
    l.Parent = parent
    return l
end

local function makeButton(parent, text, size, bgColor, textColor)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = bgColor or THEME.ACCENT
    btn.TextColor3 = textColor or THEME.BG
    btn.Text = text
    btn.TextSize = size or 13
    btn.Font = Enum.Font.GothamBold
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = parent
    makeCorner(btn, 5)

    -- hover effect
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.new(
            math.min(bgColor and bgColor.R + 0.08 or 0.47, 1),
            math.min(bgColor and bgColor.G + 0.08 or 0.75, 1),
            math.min(bgColor and bgColor.B + 0.08 or 1.0,  1)
        )
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = bgColor or THEME.ACCENT
    end)
    return btn
end

