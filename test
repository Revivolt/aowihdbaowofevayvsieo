-- ─────────────────────────────────────────────────────────
--  Utility: Build a structural tree string for an instance
-- ─────────────────────────────────────────────────────────
local function buildTree(instance, indent, depth)
    indent = indent or ""
    depth  = depth  or 0
    if depth > 6 then return indent .. "  ...\n" end

    local line = indent .. string.format("[%s] %s\n", instance.ClassName, instance.Name)
    local children = instance:GetChildren()
    for _, child in ipairs(children) do
        line = line .. buildTree(child, indent .. "  ", depth + 1)
    end
    return line
end

-- ─────────────────────────────────────────────────────────
--  Utility: Safely read .Source (works in Studio w/ API)
-- ─────────────────────────────────────────────────────────
local function getSource(scriptObj)
    local ok, src = pcall(function() return scriptObj.Source end)
    if ok and type(src) == "string" and #src > 0 then
        return src
    end
    return "(Source unavailable – enable 'Allow HTTP Requests' or view in Studio)"
end

-- ─────────────────────────────────────────────────────────
--  Build a full capture report for a script
-- ─────────────────────────────────────────────────────────
local function buildReport(scriptObj)
    local source   = getSource(scriptObj)
    local fullPath = scriptObj:GetFullName()
    local childCount = #scriptObj:GetChildren()

    local report = string.format(
[[━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 SCRIPT CAPTURED
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 Name      : %s
 ClassName : %s
 Full Path : %s
 Children  : %d
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 ▶ STRUCTURE TREE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
%s
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 ▶ SOURCE CODE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
%s

]],
        scriptObj.Name,
        scriptObj.ClassName,
        fullPath,
        childCount,
        buildTree(scriptObj),
        source
    )
    return report
end

