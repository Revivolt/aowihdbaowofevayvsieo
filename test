--  CHAT PANEL BUILDER
-- ════════════════════════════════════════════════════════════════════════
local colorPalette = {
    Color3.fromRGB(0,162,255), Color3.fromRGB(255,80,80),
    Color3.fromRGB(80,220,80), Color3.fromRGB(255,200,0),
    Color3.fromRGB(200,100,255), Color3.fromRGB(255,140,40),
    Color3.fromRGB(0,220,200),  Color3.fromRGB(255,80,180),
}
local colorMap, colorIdx = {}, 0

local function nameColor(name)
    if not colorMap[name] then
        colorIdx = (colorIdx % #colorPalette) + 1
        colorMap[name] = colorPalette[colorIdx]
    end
    return colorMap[name]
end

local function makeChatPanel(name, w, h, title, accent, placeholder)
    local panel = makePanel(name, w, h, title, accent)

    local scroll = new("ScrollingFrame", {
        Size=UDim2.new(1,-4,1,-100), Position=UDim2.new(0,2,0,50),
        BackgroundTransparency=1, ScrollBarThickness=4,
        ScrollBarImageColor3=accent, CanvasSize=UDim2.new(0,0,0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y,
        ElasticBehavior=Enum.ElasticBehavior.Never, ZIndex=6,
    }, panel)
    new("UIListLayout", {Padding=UDim.new(0,3), SortOrder=Enum.SortOrder.LayoutOrder}, scroll)
    pad(scroll, 8)

    local bar = new("Frame", {
        Size=UDim2.new(1,0,0,46), Position=UDim2.new(0,0,1,-46),
        BackgroundColor3=T.BG2, ZIndex=6,
    }, panel)
    new("Frame", {Size=UDim2.new(1,0,0,1), BackgroundColor3=T.BORDER,
        BorderSizePixel=0, ZIndex=7}, bar)

    local box = new("TextBox", {
        Size=UDim2.new(1,-54,1,-12), Position=UDim2.new(0,6,0,6),
        BackgroundColor3=T.BG3, TextColor3=T.TEXT,
        PlaceholderText=placeholder or "Type a message…",
        PlaceholderColor3=T.TEXT_DIM, Text="", TextSize=13,
        Font=Enum.Font.Gotham, ClearTextOnFocus=false,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=7,
    }, bar)
    corner(box, 7); pad(box, 8)

    local send = new("TextButton", {
        Size=UDim2.new(0,38,0,34), Position=UDim2.new(1,-44,0,6),
        BackgroundColor3=accent, Text="➤", TextColor3=T.TEXT,
        TextSize=16, Font=Enum.Font.GothamBold, AutoButtonColor=false, ZIndex=7,
    }, bar)
    corner(send, 7)
    hover(send, accent, accent:Lerp(Color3.new(1,1,1), 0.18))

    local msgN = 0
    local function addMsg(sender, text, isSystem)
        msgN += 1
        local col = isSystem and T.TEXT_DIM or nameColor(sender or "?")

        local bubble = new("Frame", {
            Name=("M%d"):format(msgN), Size=UDim2.new(1,0,0,0),
            AutomaticSize=Enum.AutomaticSize.Y, BackgroundColor3=T.BG2,
            BackgroundTransparency=isSystem and 1 or 0,
            LayoutOrder=msgN, ZIndex=6,
        }, scroll)
        corner(bubble, 6)

        local inner = new("Frame", {
            Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1, ZIndex=7,
        }, bubble)
        pad(inner, 5)
        new("UIListLayout", {Padding=UDim.new(0,1)}, inner)

        if not isSystem then
            local nr = new("Frame", {Size=UDim2.new(1,0,0,16), BackgroundTransparency=1, ZIndex=7}, inner)
            new("Frame", {Size=UDim2.new(0,3,1,-4), Position=UDim2.new(0,0,0,2),
                BackgroundColor3=col, BorderSizePixel=0, ZIndex=8}, nr)
            new("TextLabel", {Size=UDim2.new(1,-8,1,0), Position=UDim2.new(0,8,0,0),
                BackgroundTransparency=1, Text=sender, TextColor3=col,
                TextSize=11, Font=Enum.Font.GothamBold,
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=8}, nr)
        end

        new("TextLabel", {
            Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1, Text=text,
            TextColor3=isSystem and T.TEXT_DIM or T.TEXT,
            TextSize=13, Font=isSystem and Enum.Font.GothamItalic or Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true, ZIndex=7,
        }, inner)

        task.defer(function() scroll.CanvasPosition = Vector2.new(0, math.huge) end)

        -- Prune to 60 messages
        local all = {}
        for _, c in ipairs(scroll:GetChildren()) do
            if c:IsA("Frame") then all[#all+1] = c end
        end
        if #all > 60 then
            table.sort(all, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
            all[1]:Destroy()
        end
    end

    return panel, box, send, addMsg
end

