-- FastClientMove LocalScript
-- Place inside StarterPlayerScripts or StarterCharacterScripts
-- Uses BodyVelocity on the client side only — other players won't see the movement

local Players       = game:GetService("Players")
local RunService    = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer   = Players.LocalPlayer
local Character     = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HRP           = Character:WaitForChild("HumanoidRootPart")
local Humanoid      = Character:WaitForChild("Humanoid")

-- ============================================================
--  CONFIG
-- ============================================================
local SPEED         = 9999       -- how fast (studs/s). Crank it up if you want
local TOGGLE_KEY    = Enum.KeyCode.Q  -- hold Q to activate, release to stop
local VERTICAL_LOCK = true      -- keeps you on the ground while dashing
-- ============================================================

local bodyVel = nil
local active  = false

local function createBodyVelocity()
    if HRP:FindFirstChild("__FastVel") then
        HRP:FindFirstChild("__FastVel"):Destroy()
    end

    local bv       = Instance.new("BodyVelocity")
    bv.Name        = "__FastVel"
    bv.MaxForce    = Vector3.new(1e6, VERTICAL_LOCK and 0 or 1e6, 1e6)
    bv.Velocity    = Vector3.zero
    bv.Parent      = HRP
    return bv
end

-- Re-grab character after respawn
LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character = newChar
    HRP       = newChar:WaitForChild("HumanoidRootPart")
    Humanoid  = newChar:WaitForChild("Humanoid")
    bodyVel   = nil
    active    = false
end)

-- Key down → activate
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == TOGGLE_KEY then
        active  = true
        bodyVel = createBodyVelocity()
    end
end)

-- Key up → deactivate
UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == TOGGLE_KEY then
        active = false
        if bodyVel and bodyVel.Parent then
            bodyVel:Destroy()
            bodyVel = nil
        end
    end
end)

-- Every frame: point the BodyVelocity in the direction the camera faces + WASD
RunService.RenderStepped:Connect(function()
    if not active or not bodyVel or not bodyVel.Parent then return end

    -- Build a movement direction from WASD relative to the camera
    local camera    = workspace.CurrentCamera
    local camCF     = camera.CFrame
    local forward   = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z).Unit
    local right     = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z).Unit

    local moveDir   = Vector3.zero

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + forward  end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - forward  end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + right    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - right    end

    -- Optional vertical
    if not VERTICAL_LOCK then
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveDir = moveDir + Vector3.new(0, 1, 0)
        end
    end

    if moveDir.Magnitude > 0 then
        bodyVel.Velocity = moveDir.Unit * SPEED
    else
        bodyVel.Velocity = Vector3.zero
    end
end)

print("[FastClientMove] Loaded! Hold", TOGGLE_KEY.Name, "+ WASD to zoom around.")
