-- REFRESH DETAIL VIEW
-- ─────────────────────────────────────────────────────────────────────────────
local function refreshView()
    local e = selectedIdx and captured[selectedIdx]
    if not e then return end

    if viewingDeob then
        if e.deobSource then
            setCodeText(buildReport(e, true), T.DEOB_TX)
        else
            setCodeText("-- No deobfuscated version yet.\n-- Click  ✦ Deobfuscate  above to generate one.", T.WARNING)
        end
        toggleBtn.Text = "◈ Raw"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(20,50,25)
        toggleBtn.TextColor3 = T.SUCCESS
    else
        setCodeText(buildReport(e, false), T.CODE_TX)
        toggleBtn.Text = "◈ Deob"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(40,45,65)
        toggleBtn.TextColor3 = T.SUB
    end
end

