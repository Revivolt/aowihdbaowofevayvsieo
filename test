local function corner(p, r) local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 6); c.Parent = p end
local function stroke(p, c, t) local s = Instance.new("UIStroke"); s.Color = c or T.BORDER; s.Thickness = t or 1; s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; s.Parent = p end
local function pad(p, a) local u = Instance.new("UIPadding"); u.PaddingTop = UDim.new(0,a); u.PaddingBottom = UDim.new(0,a); u.PaddingLeft = UDim.new(0,a); u.PaddingRight = UDim.new(0,a); u.Parent = p end

local function lbl(p, txt, sz, col, ax)
    local l = Instance.new("TextLabel"); l.BackgroundTransparency = 1; l.Text = txt
    l.TextSize = sz or 13; l.TextColor3 = col or T.TEXT; l.Font = Enum.Font.Gotham
    l.TextXAlignment = ax or Enum.TextXAlignment.Left; l.TextWrapped = true; l.Parent = p; return l
end

local function btn(p, txt, sz, bg, tc)
    local b = Instance.new("TextButton"); b.BackgroundColor3 = bg or T.ACCENT
    b.TextColor3 = tc or T.BG; b.Text = txt; b.TextSize = sz or 13
    b.Font = Enum.Font.GothamBold; b.AutoButtonColor = false; b.BorderSizePixel = 0; b.Parent = p
    corner(b, 5)
    local orig = bg or T.ACCENT
    b.MouseEnter:Connect(function() b.BackgroundColor3 = Color3.new(math.min(orig.R+0.1,1),math.min(orig.G+0.1,1),math.min(orig.B+0.1,1)) end)
    b.MouseLeave:Connect(function() b.BackgroundColor3 = orig end)
    return b
end

local function hdrBlock(parent, color)
    local f = Instance.new("Frame"); f.Size = UDim2.new(1,0,0,34); f.BackgroundColor3 = color or T.HEADER; f.BorderSizePixel = 0; f.Parent = parent; corner(f, 8)
    local fill = Instance.new("Frame"); fill.Size = UDim2.new(1,0,0.5,0); fill.Position = UDim2.new(0,0,0.5,0); fill.BackgroundColor3 = color or T.HEADER; fill.BorderSizePixel = 0; fill.Parent = f
    return f
end

-- ─────────────────────────────────────────────────────────────────────────────
-- CODE VIEW — scrollable fixed-width text area
-- ─────────────────────────────────────────────────────────────────────────────
-- This is the single source of truth for the right-panel code display.
-- Calling setCodeText(str, color) updates content AND resizes the canvas.
local codeScroll   -- ScrollingFrame  (assigned below after GUI build)
local codeLabel    -- TextLabel       (assigned below)

local function setCodeText(str, col)
    if not (codeLabel and codeScroll) then return end
    codeLabel.TextColor3 = col or T.CODE_TX
    codeLabel.Text       = str or ""

    -- Wait one frame so Roblox has measured the text bounds
    task.defer(function()
        if not (codeLabel and codeLabel.Parent) then return end
        local bounds = codeLabel.TextBounds
        -- Height: use bounds + padding. Width: fixed CODE_WIDTH keeps wrapping stable.
        codeLabel.Size         = UDim2.new(0, CODE_WIDTH, 0, bounds.Y + 24)
        codeScroll.CanvasSize  = UDim2.new(0, 0, 0, bounds.Y + 40)
    end)
end

