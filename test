local pColors,pCI={},0
local clrs={
    Color3.fromRGB(99,102,241), Color3.fromRGB(244,114,182),
    Color3.fromRGB(52,211,153), Color3.fromRGB(251,191,36),
    Color3.fromRGB(167,139,250),Color3.fromRGB(251,146,60),
    Color3.fromRGB(34,211,238), Color3.fromRGB(74,222,128),
}
local function pColor(n)
    if not pColors[n] then pCI=(pCI%#clrs)+1; pColors[n]=clrs[pCI] end
    return pColors[n]
end

local function buildChat(name,w,h,title,accent,hint)
    local panel=makePanel(name,w,h,title,accent)

    local scroll=inst("ScrollingFrame",{
        Size=UDim2.new(1,-4,1,-96),Position=UDim2.new(0,2,0,48),
        BackgroundTransparency=1,ScrollBarThickness=4,
        ScrollBarImageColor3=accent,CanvasSize=UDim2.new(0,0,0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y,
        ElasticBehavior=Enum.ElasticBehavior.Never,ZIndex=11,
    },panel)
    inst("UIListLayout",{Padding=UDim.new(0,3),SortOrder=Enum.SortOrder.LayoutOrder},scroll)
    pdg(scroll,7)

    inst("Frame",{  -- divider
        Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-48),
        BackgroundColor3=C.BORDER,BorderSizePixel=0,ZIndex=11,
    },panel)

    local bar=inst("Frame",{
        Size=UDim2.new(1,0,0,46),Position=UDim2.new(0,0,1,-46),
        BackgroundColor3=C.SURFACE,ZIndex=11,
    },panel)
    rnd(bar,14)
    inst("Frame",{  -- fill top round corners
        Size=UDim2.new(1,0,0,14),BackgroundColor3=C.SURFACE,
        BorderSizePixel=0,ZIndex=11,
    },bar)

    local tbox=inst("TextBox",{
        Size=UDim2.new(1,-48,1,-12),Position=UDim2.new(0,6,0,6),
        BackgroundColor3=C.RAISED,TextColor3=C.TEXT,
        PlaceholderText=hint,PlaceholderColor3=C.MUTED,
        Text="",TextSize=12,Font=Enum.Font.Gotham,
        ClearTextOnFocus=false,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12,
    },bar)
    rnd(tbox,7); pdg(tbox,7)

    local send=inst("TextButton",{
        Size=UDim2.new(0,34,0,30),Position=UDim2.new(1,-40,0,8),
        BackgroundColor3=accent,Text="↑",TextColor3=C.WHITE,
        TextSize=16,Font=Enum.Font.GothamBold,AutoButtonColor=false,ZIndex=12,
    },bar)
    rnd(send,8)
    send.MouseEnter:Connect(function() tw(send,{BackgroundColor3=accent:Lerp(C.WHITE,0.15)}) end)
    send.MouseLeave:Connect(function() tw(send,{BackgroundColor3=accent}) end)

    local msgN=0
    local function addMsg(sender,text,sys)
        msgN+=1
        local col=sys and C.MUTED or pColor(sender or "?")
        local bubble=inst("Frame",{
            Name=("M%d"):format(msgN),
            Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundColor3=C.SURFACE,
            BackgroundTransparency=sys and 1 or 0,
            LayoutOrder=msgN,ZIndex=12,
        },scroll)
        if not sys then rnd(bubble,6) end

        local inner=inst("Frame",{
            Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,ZIndex=13,
        },bubble)
        pdg(inner,5)
        inst("UIListLayout",{Padding=UDim.new(0,1)},inner)

        if not sys then
            local nr=inst("Frame",{Size=UDim2.new(1,0,0,15),BackgroundTransparency=1,ZIndex=13},inner)
            inst("Frame",{Size=UDim2.new(0,2,1,-4),Position=UDim2.new(0,0,0,2),
                BackgroundColor3=col,BorderSizePixel=0,ZIndex=14},nr)
            inst("TextLabel",{Size=UDim2.new(1,-6,1,0),Position=UDim2.new(0,6,0,0),
                BackgroundTransparency=1,Text=sender,TextColor3=col,
                TextSize=11,Font=Enum.Font.GothamBold,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=14},nr)
        end

        inst("TextLabel",{
            Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,Text=text,
            TextColor3=sys and C.MUTED or C.TEXT,
            TextSize=12,Font=sys and Enum.Font.GothamItalic or Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=13,
        },inner)

        task.defer(function() scroll.CanvasPosition=Vector2.new(0,math.huge) end)

        local all={}
        for _,c in ipairs(scroll:GetChildren()) do if c:IsA("Frame") then all[#all+1]=c end end
        if #all>60 then
            table.sort(all,function(a,b) return a.LayoutOrder<b.LayoutOrder end)
            all[1]:Destroy()
        end
    end

    return panel,tbox,send,addMsg
end

