local notifOn  = true
local nQ, nBusy = {}, false

local function notify(title, body, col)
    if not notifOn then return end
    table.insert(nQ,{title=title,body=body,col=col or C.ACC})
    if nBusy then return end
    nBusy=true
    task.spawn(function()
        while #nQ>0 do
            local n=table.remove(nQ,1)
            local f=inst("Frame",{
                Size=UDim2.new(0,255,0,60),
                Position=UDim2.new(1,10,1,-68),
                AnchorPoint=Vector2.new(1,1),
                BackgroundColor3=C.SURFACE,
                ZIndex=500,
            },SG)
            rnd(f,10); brdr(f,n.col,1)
            inst("Frame",{Size=UDim2.new(0,3,1,-10),Position=UDim2.new(0,0,0,5),
                BackgroundColor3=n.col,BorderSizePixel=0,ZIndex=501},f)
            inst("TextLabel",{Size=UDim2.new(1,-12,0,20),Position=UDim2.new(0,10,0,5),
                BackgroundTransparency=1,Text=n.title,TextColor3=n.col,
                TextSize=13,Font=Enum.Font.GothamBold,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=501},f)
            inst("TextLabel",{Size=UDim2.new(1,-12,0,24),Position=UDim2.new(0,10,0,25),
                BackgroundTransparency=1,Text=n.body,TextColor3=C.MUTED,
                TextSize=11,Font=Enum.Font.Gotham,TextWrapped=true,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=501},f)
            tw(f,{Position=UDim2.new(1,-8,1,-68)},0.2)
            task.wait(3.2)
            tw(f,{Position=UDim2.new(1,280,1,-68)},0.2)
            task.wait(0.25); f:Destroy(); task.wait(0.1)
        end
        nBusy=false
    end)
end

