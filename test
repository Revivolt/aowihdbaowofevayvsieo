local Players       = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService    = game:GetService("RunService")

local localPlayer   = Players.LocalPlayer

-- ── CONFIG ────────────────────────────────────────────────────
local TARGET_NAME   = "62_AM"   -- ← change to the target's username
local HEIGHT_OFFSET = 5                         -- studs above their HumanoidRootPart
local WELD_NAME     = "AbovePlayerWeld"
-- ─────────────────────────────────────────────────────────────

local activeWeld: Weld? = nil

-- ── Helpers ───────────────────────────────────────────────────

local function getRootPart(character: Model): BasePart?
    return character:FindFirstChild("HumanoidRootPart") :: BasePart?
end

local function getHumanoid(character: Model): Humanoid?
    return character:FindFirstChildOfClass("Humanoid")
end

local function removeExistingWeld(localRoot: BasePart)
    local existing = localRoot:FindFirstChild(WELD_NAME)
    if existing then
        existing:Destroy()
    end
    activeWeld = nil
end

-- ── Core: Weld local character above target ───────────────────

local function weldAbovePlayer(targetName: string)
    -- Resolve characters
    local localChar = localPlayer.Character
    if not localChar then
        warn("[WeldAbove] Local character not found.")
        return
    end

    local targetPlayer = Players:FindFirstChild(targetName)
    if not targetPlayer then
        warn(("[WeldAbove] Player '%s' is not in the game."):format(targetName))
        return
    end

    local targetChar = (targetPlayer :: Player).Character
    if not targetChar then
        warn(("[WeldAbove] '%s' has no character yet."):format(targetName))
        return
    end

    local localRoot  = getRootPart(localChar)
    local targetRoot = getRootPart(targetChar)

    if not localRoot or not targetRoot then
        warn("[WeldAbove] Could not find HumanoidRootParts.")
        return
    end

    -- Remove any existing weld first
    removeExistingWeld(localRoot)

    -- Freeze local humanoid so physics doesn't fight the weld
    local humanoid = getHumanoid(localChar)
    if humanoid then
        humanoid.PlatformStand = true
    end

    -- Snap the local root to the correct offset position before welding
    -- so C0/C1 math is straightforward
    localRoot.CFrame = targetRoot.CFrame * CFrame.new(0, HEIGHT_OFFSET, 0)

    -- Build the Weld
    --   Part0 = target root  (the anchor)
    --   Part1 = local root   (the passenger)
    --   C0    = offset expressed in Part0's local space (HEIGHT_OFFSET studs up)
    --   C1    = identity (local root sits at its own origin)
    local weld      = Instance.new("Weld")
    weld.Name       = WELD_NAME
    weld.Part0      = targetRoot
    weld.Part1      = localRoot
    weld.C0         = CFrame.new(0, HEIGHT_OFFSET, 0)
    weld.C1         = CFrame.identity
    weld.Parent     = localRoot   -- lives on the passenger part

    activeWeld = weld

    print(("[WeldAbove] ✅  Welded %s above %s at +%d studs.")
        :format(localPlayer.Name, targetName, HEIGHT_OFFSET))

    -- Auto-clean if the target's character is removed (respawn / leave)
    targetChar.AncestryChanged:Connect(function(_, newParent)
        if newParent == nil and activeWeld == weld then
            unweld()
            print("[WeldAbove] Target character removed – weld released.")
        end
    end)
end

-- ── Core: Remove weld & restore control ───────────────────────

function unweld()
    local localChar = localPlayer.Character
    if localChar then
        local localRoot = getRootPart(localChar)
        if localRoot then
            removeExistingWeld(localRoot)
        end

        local humanoid = getHumanoid(localChar)
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
    print("[WeldAbove] 🔓 Weld removed. Control restored.")
end

-- ── Chat Commands (optional convenience) ──────────────────────
--   /weld   PlayerName    → welds you above that player
--   /weld                 → welds you above TARGET_NAME
--   /unweld               → removes weld

localPlayer.Chatted:Connect(function(msg: string)
    local lower = msg:lower()

    if lower:sub(1, 7) == "/weld" then
        local parts  = msg:split(" ")
        local name   = parts[2] or TARGET_NAME
        weldAbovePlayer(name)

    elseif lower == "/unweld" then
        unweld()
    end
end)

-- ── Keyboard Shortcut (optional) ──────────────────────────────
--   F5  →  weld above TARGET_NAME
--   F6  →  unweld

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.F5 then
        weldAbovePlayer(TARGET_NAME)

    elseif input.KeyCode == Enum.KeyCode.F6 then
        unweld()
    end
end)

