-- ════════════════════════════════════════════════════════════════════
--  FORCE-HIDE ROBLOX'S NATIVE COREGUI (keep calling — it can re-enable)
-- ════════════════════════════════════════════════════════════════════
local function disableCoreGui()
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All,          false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack,      false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat,          false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.EmotesMenu,    false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Health,        false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList,    false) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.SelfView,      false) end)

    -- Also hide the actual CoreGui children directly
    pcall(function()
        for _, child in ipairs(CoreGui:GetChildren()) do
            if child:IsA("ScreenGui") then
                child.Enabled = false
            end
        end
    end)
end

disableCoreGui()

-- Keep disabling every frame for the first 5 seconds (handles late-loading CoreGui)
local startTime = tick()
local killConn
killConn = RunService.Heartbeat:Connect(function()
    disableCoreGui()
    if tick() - startTime > 5 then
        killConn:Disconnect()
        -- Then check every 3 seconds forever just in case
        task.spawn(function()
            while task.wait(3) do disableCoreGui() end
        end)
    end
end)

-- Also re-disable on each respawn
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.1)
    disableCoreGui()
end)

