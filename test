-- ── Slider helper ────────────────────────────────────────────
local function setSliderRatio(ratio)
    ratio = math.clamp(ratio, 0, 1)
    local px = ratio * TRACK_W
    knob.Position = UDim2.new(0, px, 0.5, 0)
    sliderFill.Size = UDim2.new(0, px, 1, 0)
    ANIM_DURATION = SPEED_MIN + ratio * (SPEED_MAX - SPEED_MIN)
    speedValueLabel.Text = string.format("%.1fs", ANIM_DURATION)
end

local defaultRatio = (1.0 - SPEED_MIN) / (SPEED_MAX - SPEED_MIN)
setSliderRatio(defaultRatio)

-- ── Slider drag ──────────────────────────────────────────────
local slidingKnob = false

knob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = true
    end
end)

knob.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = false
    end
end)

sliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = true
        local trackAbsPos = sliderTrack.AbsolutePosition.X
        local ratio = (input.Position.X - trackAbsPos) / TRACK_W
        setSliderRatio(ratio)
    end
end)

sliderTrack.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = false
    end
end)

-- ============================================================
--  DRAG LOGIC  (title bar)
-- ============================================================
local dragging = false
local dragStartPos
local frameStartPos

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStartPos = input.Position
        frameStartPos = frame.Position
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            local delta = input.Position - dragStartPos
            frame.Position = UDim2.new(
                frameStartPos.X.Scale,
                frameStartPos.X.Offset + delta.X,
                frameStartPos.Y.Scale,
                frameStartPos.Y.Offset + delta.Y
            )
        end
        if slidingKnob then
            local trackAbsPos = sliderTrack.AbsolutePosition.X
            local ratio = (input.Position.X - trackAbsPos) / TRACK_W
            setSliderRatio(ratio)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = false
        dragging = false
    end
end)

-- ============================================================
--  BUTTON / INPUT LOGIC
-- ============================================================
local function triggerPlay()
    if isPlaying then
        statusLabel.Text = "Already playing — press Stop first"
        return
    end
    local input = textBox.Text
    if input == "" then
        statusLabel.Text = "Type something first!"
        return
    end
    statusLabel.Text = 'Playing: "' .. input .. '"'
    playButton.BackgroundTransparency = 0.65
    task.spawn(function()
        playAnimationsForText(input)
        statusLabel.Text = 'Done: "' .. input .. '"'
        playButton.BackgroundTransparency = 0.80
    end)
end

textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then triggerPlay() end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Return and textBox:IsFocused() then
        triggerPlay()
    end
end)

playButton.MouseButton1Click:Connect(triggerPlay)

playButton.MouseEnter:Connect(function()
    if not isPlaying then playButton.BackgroundTransparency = 0.70 end
end)
playButton.MouseLeave:Connect(function()
    if not isPlaying then playButton.BackgroundTransparency = 0.80 end
end)

closeButton.MouseButton1Click:Connect(function()
    isPlaying = false
    stopCurrentTrack()
    setLimbStiffness(false)
    screenGui:Destroy()
end)

closeButton.MouseEnter:Connect(function()
    closeButton.BackgroundTransparency = 0.70
end)
closeButton.MouseLeave:Connect(function()
    closeButton.BackgroundTransparency = 0.85
end)

stopButton.MouseButton1Click:Connect(function()
    if isPlaying then
        isPlaying = false
        stopCurrentTrack()
        setLimbStiffness(false)
        statusLabel.Text = "Stopped."
        playButton.BackgroundTransparency = 0.80
    end
end)

stopButton.MouseEnter:Connect(function()
    stopButton.BackgroundTransparency = 0.75
end)
stopButton.MouseLeave:Connect(function()
    stopButton.BackgroundTransparency = 0.88
end)

