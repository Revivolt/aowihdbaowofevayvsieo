local function getPath(i)
    local p, c = {}, i
    while c and c ~= game do table.insert(p, 1, c.Name); c = c.Parent end
    return table.concat(p, " > ")
end

local function trySource(s)
    local ok, r = pcall(function() return s.Source end)
    if ok and type(r) == "string" and #r > 0 then return r end
    if type(decompile) == "function" then
        local ok2, d = pcall(decompile, s)
        if ok2 and type(d) == "string" and #d > 0 then return "-- [DECOMPILED]\n"..d end
    end
    return nil
end

local function collectProps(s)
    local out = {}
    for _, k in ipairs({"Name","ClassName","Disabled","RunContext","LinkedSource","ScriptGuid"}) do
        local ok, v = pcall(function() return s[k] end)
        if ok then out[k] = tostring(v) end
    end
    return out
end

local function snapAdd(inst)
    if inst:IsA("LuaSourceContainer") then snapshot[inst] = true end
    for _, d in ipairs(inst:GetDescendants()) do
        if d:IsA("LuaSourceContainer") then snapshot[d] = true end
    end
end

local function buildReport(e)
    local L = {}
    local function ln(s) table.insert(L, s or "") end
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln("  INJECTION CAPTURE REPORT")
    ln("  Detected at : " .. e.time)
    ln("  Method      : " .. e.method)
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln(); ln("[ IDENTITY ]")
    ln("  Name      : " .. tostring(e.name))
    ln("  ClassName : " .. tostring(e.className))
    ln("  Path      : " .. tostring(e.path))
    ln(); ln("[ PROPERTIES ]")
    for k, v in pairs(e.props) do
        if k ~= "Name" and k ~= "ClassName" then
            ln(string.format("  %-16s: %s", k, v))
        end
    end
    ln()
    if e.source and #e.source > 0 then
        ln("[ SOURCE / BYTECODE ]"); ln()
        ln(e.source)
    else
        ln("[ SOURCE / BYTECODE ]"); ln()
        ln("-- Source not readable in this environment.")
        ln("-- Executor with decompile() required for full source.")
    end
    ln(); ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    return table.concat(L, "\n")
end

local function toClip(t)
    if type(setclipboard) == "function" then pcall(setclipboard, t); return true end
    if type(toclipboard)  == "function" then pcall(toclipboard,  t); return true end
    return false
end

-- ─────────────────────────────────────────────────────────────────────────────
-- ANTHROPIC API — deobfuscation via executor HTTP
-- ─────────────────────────────────────────────────────────────────────────────
local function getHttpFunc()
    if type(syn)  == "table"    and type(syn.request)  == "function" then return syn.request  end
    if type(http) == "table"    and type(http.request) == "function" then return http.request end
    if type(request)            == "function"                        then return request       end
    return nil
end

-- callback(result: string | nil, err: string | nil)
local function deobfuscateWithClaude(src, callback)
    if ANTHROPIC_API_KEY == "" then
        callback(nil, "No API key set.\nEdit the top of the script and add your Anthropic key.")
        return
    end
    local httpFunc = getHttpFunc()
    if not httpFunc then
        callback(nil, "No HTTP function found.\nYour executor needs syn.request / request() / http.request.")
        return
    end

    task.spawn(function()
        local prompt = [[You are a Lua deobfuscator. The user will give you obfuscated Roblox Lua code.
Your job is to:
1. Rename mangled variables/functions to readable names based on what they do.
2. Unwrap string encodings (hex escapes, charcode arrays, XOR tables, etc.).
3. Remove dead code and no-op chains.
4. Flatten control-flow obfuscation (VM loops, opcode tables).
5. Add brief inline comments explaining what each section does.
6. Output ONLY the cleaned Lua code. No explanation, no markdown fences.

Obfuscated code:
]] .. src

        local bodyJson = HttpService:JSONEncode({
            model      = "claude-sonnet-4-20250514",
            max_tokens = 4096,
            messages   = {{ role = "user", content = prompt }},
        })

        local ok, res = pcall(httpFunc, {
            Url    = "https://api.anthropic.com/v1/messages",
            Method = "POST",
            Headers = {
                ["Content-Type"]      = "application/json",
                ["x-api-key"]         = ANTHROPIC_API_KEY,
                ["anthropic-version"] = "2023-06-01",
            },
            Body = bodyJson,
        })

        if not ok then
            callback(nil, "HTTP request failed:\n" .. tostring(res))
            return
        end

        local ok2, decoded = pcall(HttpService.JSONDecode, HttpService, res.Body or "")
        if not ok2 then
            callback(nil, "JSON decode error.\nRaw response (first 300 chars):\n" .. tostring(res.Body or ""):sub(1,300))
            return
        end

        if decoded.error then
            callback(nil, "API error: " .. tostring(decoded.error.message or decoded.error))
            return
        end

        local content = decoded.content
        if content and content[1] and content[1].text then
            callback(content[1].text, nil)
        else
            callback(nil, "Unexpected response shape.")
        end
    end)
end

