-- ─────────────────────────────────────────────────────────
--  TOGGLE VISIBILITY  [Right Shift]
-- ─────────────────────────────────────────────────────────
local function setVisible(v)
    chatVisible = v
    local targetSize = v
        and UDim2.new(0, CFG.WINDOW_WIDTH, 0, CFG.WINDOW_HEIGHT)
        or  UDim2.new(0, CFG.WINDOW_WIDTH, 0, 40)

    TweenService:Create(Window, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
        Size = targetSize
    }):Play()

    MsgScroll.Visible = v
    InputRow.Visible  = v
    Sep.Visible       = v
    Hint.Visible      = v
end

HideBtn.MouseButton1Click:Connect(function()
    setVisible(not chatVisible)
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        setVisible(not chatVisible)
    end
end)

-- ─────────────────────────────────────────────────────────
--  DRAG: TITLE BAR
-- ─────────────────────────────────────────────────────────
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = true
        local wPos  = Window.AbsolutePosition
        local mPos  = UserInputService:GetMouseLocation()
        dragOffset  = mPos - wPos
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mPos   = UserInputService:GetMouseLocation()
        local newPos = mPos - dragOffset
        local vSize  = Root.AbsoluteSize
        -- Clamp within screen
        newPos = Vector2.new(
            math.clamp(newPos.X, 0, vSize.X - Window.AbsoluteSize.X),
            math.clamp(newPos.Y, 0, vSize.Y - Window.AbsoluteSize.Y)
        )
        Window.Position = UDim2.new(0, newPos.X, 0, newPos.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = false
    end
end)

-- ─────────────────────────────────────────────────────────
--  PERIODIC HANDSHAKE BROADCAST
-- ─────────────────────────────────────────────────────────
task.spawn(function()
    -- Initial broadcast
    task.wait(2)
    broadcastHandshake()
    addMessage("System",
        "Secret Chat ready. Waiting for other script users...", "system")

    -- Recurring ping
    while true do
        task.wait(CFG.PING_INTERVAL)
        broadcastHandshake()
    end
end)

print("[SecretChat] Loaded successfully. Script key:", CFG.SCRIPT_KEY)
