-- ════════════════════════════════════════════════════════════════════
--  NOTIFICATION SYSTEM  (defined before panels so menu can use it)
-- ════════════════════════════════════════════════════════════════════
local notifOn = true
local nQ = {}
local nBusy = false

local function notify(title, body, color)
    if not notifOn then return end
    table.insert(nQ, {title = title, body = body, c = color or T.ACCENT})
    if nBusy then return end
    nBusy = true
    task.spawn(function()
        while #nQ > 0 do
            local n = table.remove(nQ, 1)
            local f = make("Frame", {
                Size             = UDim2.new(0, 255, 0, 60),
                Position         = UDim2.new(1, 10, 1, -68),
                AnchorPoint      = Vector2.new(1, 1),
                BackgroundColor3 = T.BG2,
                ZIndex           = 100,
            }, Root)
            addCorner(f, 8)
            addStroke(f, n.c, 1)
            make("Frame", {
                Size = UDim2.new(0, 3, 1, -10), Position = UDim2.new(0, 0, 0, 5),
                BackgroundColor3 = n.c, BorderSizePixel = 0, ZIndex = 101,
            }, f)
            make("TextLabel", {
                Size = UDim2.new(1, -8, 0, 20), Position = UDim2.new(0, 9, 0, 5),
                BackgroundTransparency = 1, Text = n.title, TextColor3 = n.c,
                TextSize = 12, Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 101,
            }, f)
            make("TextLabel", {
                Size = UDim2.new(1, -8, 0, 22), Position = UDim2.new(0, 9, 0, 24),
                BackgroundTransparency = 1, Text = n.body, TextColor3 = T.DIMTEXT,
                TextSize = 11, Font = Enum.Font.Gotham, TextWrapped = true,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 101,
            }, f)
            tween(f, {Position = UDim2.new(1, -6, 1, -68)}, 0.2)
            task.wait(3.5)
            tween(f, {Position = UDim2.new(1, 270, 1, -68)}, 0.2)
            task.wait(0.25)
            f:Destroy()
            task.wait(0.1)
        end
        nBusy = false
    end)
end

