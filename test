-- ─────────────────────────────────────────────
--  MESSAGE RENDERING
-- ─────────────────────────────────────────────
local msgCount = 0

local function scrollToBottom()
    task.defer(function()
        ScrollFrame.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

local function addMessage(speaker, text, msgType)
    msgCount += 1

    local row            = Instance.new("Frame")
    row.Size             = UDim2.new(1, 0, 0, 0)
    row.AutomaticSize    = Enum.AutomaticSize.Y
    row.BackgroundTransparency = 1
    row.LayoutOrder      = msgCount
    row.Parent           = ScrollFrame

    if msgType == "system" then
        local lbl           = Instance.new("TextLabel", row)
        lbl.Size            = UDim2.new(1, 0, 0, 0)
        lbl.AutomaticSize   = Enum.AutomaticSize.Y
        lbl.BackgroundTransparency = 1
        lbl.TextXAlignment  = Enum.TextXAlignment.Left
        lbl.TextWrapped     = true
        lbl.Font            = Enum.Font.Gotham
        lbl.TextSize        = 11
        lbl.TextColor3      = Color3.fromRGB(110, 120, 155)
        lbl.Text            = "  ◈ " .. text

    elseif msgType == "join" then
        local lbl           = Instance.new("TextLabel", row)
        lbl.Size            = UDim2.new(1, 0, 0, 16)
        lbl.BackgroundTransparency = 1
        lbl.TextXAlignment  = Enum.TextXAlignment.Left
        lbl.Font            = Enum.Font.Gotham
        lbl.TextSize        = 11
        lbl.TextColor3      = Color3.fromRGB(80, 200, 120)
        lbl.Text            = "  → " .. speaker .. " joined the secret channel"

    elseif msgType == "leave" then
        local lbl           = Instance.new("TextLabel", row)
        lbl.Size            = UDim2.new(1, 0, 0, 16)
        lbl.BackgroundTransparency = 1
        lbl.TextXAlignment  = Enum.TextXAlignment.Left
        lbl.Font            = Enum.Font.Gotham
        lbl.TextSize        = 11
        lbl.TextColor3      = Color3.fromRGB(200, 90, 80)
        lbl.Text            = "  ← " .. speaker .. " left the secret channel"

    else  -- "chat"
        local isSelf        = (speaker == LocalPlayer.DisplayName)
        local nameColor     = isSelf
            and Color3.fromRGB(100, 160, 255)
            or  Color3.fromRGB(200, 160, 255)

        local nameLbl       = Instance.new("TextLabel", row)
        nameLbl.Size        = UDim2.new(1, 0, 0, 15)
        nameLbl.BackgroundTransparency = 1
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.Font        = Enum.Font.GothamBold
        nameLbl.TextSize    = 11
        nameLbl.TextColor3  = nameColor
        nameLbl.Text        = "  " .. speaker

        local msgLbl        = Instance.new("TextLabel", row)
        msgLbl.Size         = UDim2.new(1, 0, 0, 0)
        msgLbl.Position     = UDim2.new(0, 12, 0, 15)
        msgLbl.AutomaticSize = Enum.AutomaticSize.Y
        msgLbl.BackgroundTransparency = 1
        msgLbl.TextXAlignment = Enum.TextXAlignment.Left
        msgLbl.TextWrapped  = true
        msgLbl.Font         = Enum.Font.Gotham
        msgLbl.TextSize     = 12
        msgLbl.TextColor3   = Color3.fromRGB(210, 215, 240)
        msgLbl.Text         = text
    end

    scrollToBottom()
end

-- ─────────────────────────────────────────────
--  ONLINE COUNTER
-- ─────────────────────────────────────────────
local function refreshOnlineLabel()
    local count = 0
    for _ in pairs(verifiedSet) do count += 1 end
    if count == 0 then
        OnlineLabel.Text       = "● No other users with script online"
        OnlineLabel.TextColor3 = Color3.fromRGB(160, 80, 80)
    else
        OnlineLabel.Text       = "● " .. count .. " other user"
            .. (count ~= 1 and "s" or "") .. " with script"
        OnlineLabel.TextColor3 = Color3.fromRGB(80, 200, 120)
    end
end

-- ─────────────────────────────────────────────
--  PROCESS INCOMING CHAT MESSAGES
-- ─────────────────────────────────────────────
local function onChatMessage(player, message)
    if player == LocalPlayer then return end  -- we handle our own messages locally

    -- Handshake received from another script user
    if message == HS_MSG then
        local isNew = not verifiedSet[player]
        verifiedSet[player] = true
        refreshOnlineLabel()
        if isNew then
            addMessage(player.DisplayName, nil, "join")
            -- Reply with our handshake so they discover us too (throttled)
            task.delay(0.5, broadcastHandshake)
        end
        return
    end

    -- Secret message from a verified player
    if message:sub(1, #MSG_PFX) == MSG_PFX and verifiedSet[player] then
        local decoded = message:sub(#MSG_PFX + 1)
        if decoded ~= "" then
            addMessage(player.DisplayName, decoded, "chat")
        end
        return
    end
end

-- ── Hook into legacy chat (Player.Chatted fires on all clients) ──
local function hookPlayer(p)
    p.Chatted:Connect(function(msg)
        onChatMessage(p, msg)
    end)
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then hookPlayer(p) end
end

Players.PlayerAdded:Connect(function(p)
    hookPlayer(p)
end)

Players.PlayerRemoving:Connect(function(p)
    if verifiedSet[p] then
        verifiedSet[p] = nil
        refreshOnlineLabel()
        addMessage(p.DisplayName, nil, "leave")
    end
end)

-- ── Also hook into new TextChatService if present ──
-- MessageReceived fires on all clients for all messages
pcall(function()
    TextChatService.MessageReceived:Connect(function(msg)
        if not msg.TextSource then return end
        local userId = msg.TextSource.UserId
        local player = Players:GetPlayerByUserId(userId)
        if player and player ~= LocalPlayer then
            -- Strip any rich-text tags Roblox may inject
            local rawText = msg.Text:gsub("<[^>]+>", "")
            onChatMessage(player, rawText)
        end
    end)
end)

-- ─────────────────────────────────────────────
--  SEND A SECRET MESSAGE
-- ─────────────────────────────────────────────
local function submitMessage()
    local text = InputBox.Text:match("^%s*(.-)%s*$")
    if text == "" then return end
    if #text > 150 then
        addMessage(nil, "Too long — max 150 characters.", "system")
        return
    end

    -- Show immediately in our own window
    addMessage(LocalPlayer.DisplayName, text, "chat")
    InputBox.Text = ""

    -- Broadcast via chat (prefixed so other scripts can decode it)
    sendChat(MSG_PFX .. text)
end

SendBtn.MouseButton1Click:Connect(submitMessage)

InputBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then submitMessage() end
end)

-- ─────────────────────────────────────────────
--  DRAG TO MOVE
-- ─────────────────────────────────────────────
local dragging, dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging  = true
        dragStart = input.Position
        startPos  = Window.Position
    end
end)

TitleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Window.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- ─────────────────────────────────────────────
--  HIDE / SHOW
-- ─────────────────────────────────────────────
local hidden = false

local function toggleWindow()
    hidden = not hidden
    Window.Size    = hidden
        and UDim2.new(0, WIN_W, 0, 36)
        or  UDim2.new(0, WIN_W, 0, WIN_H)
    ToggleBtn.Text = hidden and "□" or "─"
end

ToggleBtn.MouseButton1Click:Connect(toggleWindow)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.H
        and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        toggleWindow()
    end
end)

