-- ============================================================
--  TOGGLE PANEL (slide up / down with tween)
-- ============================================================
local panelOpen = false
local tweenInfo = TweenInfo.new(0.30, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

local function setPanelOpen(open)
    panelOpen = open
    local targetOffset = open and PANEL_SHOWN_OFFSET or PANEL_HIDDEN_OFFSET
    TweenService:Create(frame, tweenInfo, {
        Position = UDim2.new(0.5, -PANEL_W / 2, 1, targetOffset)
    }):Play()
    toggleButton.Text = open and "Body Language" or "Body Language"
end

toggleButton.MouseButton1Click:Connect(function()
    setPanelOpen(not panelOpen)
end)

toggleButton.MouseEnter:Connect(function()
    toggleButton.BackgroundTransparency = 0.15
end)
toggleButton.MouseLeave:Connect(function()
    toggleButton.BackgroundTransparency = 0.30
end)

-- ============================================================
--  INPUT CHANGED (slider drag only now, no panel drag)
-- ============================================================
UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        if slidingKnob then
            local ratio = (input.Position.X - sliderTrack.AbsolutePosition.X) / TRACK_W
            setSliderRatio(ratio)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = false
    end
end)

-- ============================================================
--  PLAY / STOP LOGIC
-- ============================================================
local function triggerPlay()
    if isPlaying then
        statusLabel.Text = "Already playing — press Stop first"
        return
    end
    local input = textBox.Text
    if input == "" then
        statusLabel.Text = "Type something first!"
        return
    end
    statusLabel.Text = 'Playing: "' .. input .. '"'
    playButton.BackgroundTransparency = 0.65
    task.spawn(function()
        playAnimationsForText(input)
        statusLabel.Text = 'Done: "' .. input .. '"'
        playButton.BackgroundTransparency = 0.80
    end)
end

textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then triggerPlay() end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Return and textBox:IsFocused() then
        triggerPlay()
    end
end)

playButton.MouseButton1Click:Connect(triggerPlay)

playButton.MouseEnter:Connect(function()
    if not isPlaying then playButton.BackgroundTransparency = 0.70 end
end)
playButton.MouseLeave:Connect(function()
    if not isPlaying then playButton.BackgroundTransparency = 0.80 end
end)

stopButton.MouseButton1Click:Connect(function()
    if isPlaying then
        isPlaying = false
        stopCurrentTrack()
        setLimbStiffness(false)
        statusLabel.Text = "Stopped."
        playButton.BackgroundTransparency = 0.80
    end
end)

stopButton.MouseEnter:Connect(function()
    stopButton.BackgroundTransparency = 0.75
end)
stopButton.MouseLeave:Connect(function()
    stopButton.BackgroundTransparency = 0.88
end)

