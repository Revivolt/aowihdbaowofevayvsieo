--  PANEL TOGGLE  — one open at a time
-- ════════════════════════════════════════════════════════════════════
local allPanels = {
    {btn = BtnMenu,   panel = MenuPanel},
    {btn = BtnChat,   panel = ChatPanel},
    {btn = BtnGlobal, panel = GlobalPanel},
}

for _, e in ipairs(allPanels) do
    e.btn.MouseButton1Click:Connect(function()
        local willOpen = not e.panel.Visible
        for _, x in ipairs(allPanels) do
            x.panel.Visible = false
            setActive(x.btn, false)
        end
        if willOpen then
            e.panel.Visible = true
            setActive(e.btn, true)
        end
    end)
end

