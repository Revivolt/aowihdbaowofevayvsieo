-- ─────────────────────────────────────────────────────────────────────────────
-- UTILITIES
-- ─────────────────────────────────────────────────────────────────────────────
local function getPath(i)
    local p, c = {}, i
    while c and c ~= game do table.insert(p, 1, c.Name); c = c.Parent end
    return table.concat(p, " > ")
end

local function trySource(s)
    local ok, r = pcall(function() return s.Source end)
    if ok and type(r) == "string" and #r > 0 then return r end
    if type(decompile) == "function" then
        local ok2, d = pcall(decompile, s)
        if ok2 and type(d) == "string" and #d > 0 then return "-- [DECOMPILED]\n" .. d end
    end
    return nil
end

local function collectProps(s)
    local out = {}
    for _, k in ipairs({"Name","ClassName","Disabled","RunContext","LinkedSource","ScriptGuid"}) do
        local ok, v = pcall(function() return s[k] end)
        if ok then out[k] = tostring(v) end
    end
    return out
end

local function snapAdd(inst)
    if inst:IsA("LuaSourceContainer") then snapshot[inst] = true end
    for _, d in ipairs(inst:GetDescendants()) do
        if d:IsA("LuaSourceContainer") then snapshot[d] = true end
    end
end

local function toClip(t)
    if type(setclipboard) == "function" then pcall(setclipboard, t); return true end
    if type(toclipboard)  == "function" then pcall(toclipboard,  t); return true end
    return false
end

