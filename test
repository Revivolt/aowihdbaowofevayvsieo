--  NOTIFICATIONS  (defined before Menu so menu items can call it)
-- ══════════════════════════════════════════════════════════════════════
local notifEnabled = true
local notifQueue   = {}
local notifBusy    = false

local function notify(title, body, color)
    if not notifEnabled then return end
    table.insert(notifQueue, {title = title, body = body, color = color or T.ACCENT})
    if notifBusy then return end
    notifBusy = true
    task.spawn(function()
        while #notifQueue > 0 do
            local n = table.remove(notifQueue, 1)
            local f = make("Frame", {
                Size             = UDim2.new(0, 255, 0, 60),
                Position         = UDim2.new(1, 10, 1, -68),
                AnchorPoint      = Vector2.new(1, 1),
                BackgroundColor3 = T.BG2,
                ZIndex           = 500,
            }, Root)
            addCorner(f, 9)
            addStroke(f, n.color, 1)
            make("Frame", {
                Size = UDim2.new(0, 3, 1, -10), Position = UDim2.new(0, 0, 0, 5),
                BackgroundColor3 = n.color, BorderSizePixel = 0, ZIndex = 501,
            }, f)
            make("TextLabel", {
                Size = UDim2.new(1, -12, 0, 20), Position = UDim2.new(0, 10, 0, 5),
                BackgroundTransparency = 1, Text = n.title, TextColor3 = n.color,
                TextSize = 13, Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 501,
            }, f)
            make("TextLabel", {
                Size = UDim2.new(1, -12, 0, 24), Position = UDim2.new(0, 10, 0, 26),
                BackgroundTransparency = 1, Text = body, TextColor3 = T.DIM,
                TextSize = 11, Font = Enum.Font.Gotham, TextWrapped = true,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 501,
            }, f)
            tween(f, {Position = UDim2.new(1, -8, 1, -68)}, 0.2)
            task.wait(3.2)
            tween(f, {Position = UDim2.new(1, 280, 1, -68)}, 0.2)
            task.wait(0.25)
            f:Destroy()
            task.wait(0.1)
        end
        notifBusy = false
    end)
end

