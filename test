-- Active underline indicator
local function setActiveBtn(btn, on)
    local ul = btn:FindFirstChild("_ul")
    if not ul then
        ul = make("Frame", {
            Name             = "_ul",
            Size             = UDim2.new(0.75, 0, 0, 2),
            Position         = UDim2.new(0.125, 0, 1, -3),
            BackgroundColor3 = T.ACCENT,
            BorderSizePixel  = 0,
            ZIndex           = 13,
        }, btn)
        addCorner(ul, 1)
    end
    ul.Visible = on
    tween(btn, {TextColor3 = on and T.ACCENT or T.WHITE})
end

