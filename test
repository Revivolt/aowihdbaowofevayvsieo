-- =============================================
-- DRAGGING
-- =============================================
local dragging, dragInput, dragStart, startPos = false, nil, nil, nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- =============================================
-- MESSAGE LOGIC
-- =============================================
local msgCount = 0
local msgRows = {}

local nameColors = {
    Color3.fromRGB(255, 180,  80),
    Color3.fromRGB( 80, 200, 255),
    Color3.fromRGB(180, 255, 120),
    Color3.fromRGB(255, 120, 180),
    Color3.fromRGB(180, 130, 255),
    Color3.fromRGB(255, 230,  80),
}
local playerColorMap = {}
local colorIndex = 0

local function getPlayerColor(name)
    if not playerColorMap[name] then
        colorIndex = (colorIndex % #nameColors) + 1
        playerColorMap[name] = nameColors[colorIndex]
    end
    return playerColorMap[name]
end

-- Deduplicate: track last few messages to avoid double-posting
local recentMessages = {}
local function isDuplicate(speaker, text)
    local key = speaker .. "|" .. text
    local now = tick()
    for i = #recentMessages, 1, -1 do
        local entry = recentMessages[i]
        if now - entry.t > 1 then
            table.remove(recentMessages, i)
        elseif entry.key == key then
            return true
        end
    end
    table.insert(recentMessages, { key = key, t = now })
    return false
end

local function addMessage(speaker, message)
    if not message or message:match("^%s*$") then return end
    if isDuplicate(speaker, message) then return end

    msgCount += 1
    local color = getPlayerColor(speaker)

    local row = Instance.new("Frame")
    row.Name = "Row_" .. msgCount
    row.Size = UDim2.new(1, 0, 0, 0)
    row.AutomaticSize = Enum.AutomaticSize.Y
    row.BackgroundTransparency = 1
    row.LayoutOrder = msgCount
    row.Parent = scrollFrame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 0)
    label.AutomaticSize = Enum.AutomaticSize.Y
    label.BackgroundTransparency = 1
    label.TextSize = CONFIG.fontSize
    label.Font = Enum.Font.Gotham
    label.TextWrapped = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.RichText = true
    -- Escape any rich text characters from user input
    local safeMsg = message:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;")
    label.Text = string.format(
        '<font color="rgb(%d,%d,%d)"><b>%s:</b></font> <font color="rgb(210,210,210)">%s</font>',
        math.floor(color.R * 255),
        math.floor(color.G * 255),
        math.floor(color.B * 255),
        speaker,
        safeMsg
    )
    label.Parent = row

    table.insert(msgRows, row)

    while #msgRows > CONFIG.maxMessages do
        local old = table.remove(msgRows, 1)
        if old then old:Destroy() end
    end

    task.defer(function()
        scrollFrame.CanvasPosition = Vector2.new(0, math.huge)
    end)

    if CONFIG.messageLifetime > 0 then
        task.delay(CONFIG.messageLifetime, function()
            if row.Parent then row:Destroy() end
        end)
    end
end

-- =============================================
-- METHOD 1: Hook each TextChannel directly
-- (Most reliable for modern Roblox chat)
-- =============================================
local function hookTextChannel(channel)
    channel.MessageReceived:Connect(function(msg)
        local speaker = (msg.TextSource and msg.TextSource.Name) or "Unknown"
        local text = msg.Text
        if text and text ~= "" then
            addMessage(speaker, text)
        end
    end)
end

task.spawn(function()
    -- Wait up to 10 seconds for TextChannels to exist
    local channelFolder = TextChatService:WaitForChild("TextChannels", 10)
    if not channelFolder then
        addMessage("System", "Warning: TextChannels not found.")
        return
    end

    -- Hook all existing channels (RBXGeneral, team channels, etc.)
    for _, ch in ipairs(channelFolder:GetChildren()) do
        if ch:IsA("TextChannel") then
            hookTextChannel(ch)
        end
    end

    -- Hook channels added later (team channels spawn dynamically)
    channelFolder.ChildAdded:Connect(function(ch)
        if ch:IsA("TextChannel") then
            hookTextChannel(ch)
        end
    end)
end)

-- =============================================
-- METHOD 2: TextChatService.MessageReceived
-- (Backup — fires for all messages service-wide)
-- =============================================
TextChatService.MessageReceived:Connect(function(msg)
    local speaker = (msg.TextSource and msg.TextSource.Name) or "Unknown"
    local text = msg.Text
    if text and text ~= "" then
        addMessage(speaker, text)
    end
end)

-- =============================================
-- METHOD 3: Legacy Player.Chatted
-- (Fallback for older games not using TextChatService)
-- =============================================
local function hookPlayerChatted(player)
    player.Chatted:Connect(function(msg)
        addMessage(player.Name, msg)
    end)
end

for _, player in ipairs(Players:GetPlayers()) do
    hookPlayerChatted(player)
end
Players.PlayerAdded:Connect(hookPlayerChatted)

