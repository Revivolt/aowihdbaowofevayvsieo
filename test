-- ─────────────────────────────────────────────────────────────────────────────
-- CODE VIEW  — ScrollingFrame with manual CanvasSize sync
--
-- WHY NOT AutomaticCanvasSize:
--   Roblox's AutomaticCanvasSize reads the UIListLayout/AbsoluteContentSize,
--   but a single TextLabel with AutomaticSize=Y doesn't update the content
--   size reliably when the text is very long or contains many newlines.
--   The fix: use a wrapper Frame (AutomaticSize=Y) → TextLabel inside it,
--   then manually sync CanvasSize via AbsoluteSize change signal.
-- ─────────────────────────────────────────────────────────────────────────────
local codeScroll = Instance.new("ScrollingFrame")
codeScroll.Name                 = "CodeScroll"
codeScroll.Size                 = UDim2.new(1,-8,1,-44)
codeScroll.Position             = UDim2.new(0,4,0,40)
codeScroll.BackgroundColor3     = T.CODE_BG
codeScroll.BorderSizePixel      = 0
codeScroll.ScrollBarThickness   = 6
codeScroll.ScrollBarImageColor3 = T.ACCENT
codeScroll.ScrollingDirection   = Enum.ScrollingDirection.Y
codeScroll.CanvasSize           = UDim2.new(0,0,0,300)
codeScroll.AutomaticCanvasSize  = Enum.AutomaticSize.None   -- manual!
codeScroll.ElasticBehavior      = Enum.ElasticBehavior.Never
codeScroll.Parent               = rp
corner(codeScroll, 6); stroke(codeScroll, T.BORDER, 1)

-- Wrapper frame grows with the text and drives CanvasSize
local codeInner = Instance.new("Frame")
codeInner.BackgroundTransparency = 1
codeInner.Size                   = UDim2.new(1, 0, 0, 0)
codeInner.AutomaticSize          = Enum.AutomaticSize.Y
