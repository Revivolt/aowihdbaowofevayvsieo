local PANEL_TOP = BAR_H + 2

local function makePanel(name, w, h, title, accent)
    local p = make("Frame", {
        Name             = name,
        Size             = UDim2.new(0, w, 0, h),
        Position         = UDim2.new(0, 4, 0, PANEL_TOP),
        BackgroundColor3 = T.BG,
        Visible          = false,
        ClipsDescendants = true,
        ZIndex           = 5,
    }, Root)
    addCorner(p, 10)
    addStroke(p, T.BORDER, 1)

    -- Header strip
    local hdr = make("Frame", {
        Name             = "Hdr",
        Size             = UDim2.new(1, 0, 0, 42),
        BackgroundColor3 = T.BG2,
        ZIndex           = 6,
    }, p)
    addCorner(hdr, 10)
    -- Fill the bottom-round corners of header so it blends into body
    make("Frame", {
        Size = UDim2.new(1, 0, 0, 10), Position = UDim2.new(0, 0, 1, -10),
        BackgroundColor3 = T.BG2, BorderSizePixel = 0, ZIndex = 6,
    }, hdr)

    -- Coloured left strip
    local strip = make("Frame", {
        Size             = UDim2.new(0, 3, 1, -14),
        Position         = UDim2.new(0, 8, 0.5, 0),
        AnchorPoint      = Vector2.new(0, 0.5),
        BackgroundColor3 = accent,
        BorderSizePixel  = 0,
        ZIndex           = 7,
    }, hdr)
    addCorner(strip, 2)

    make("TextLabel", {
        Size = UDim2.new(1, -70, 1, 0), Position = UDim2.new(0, 18, 0, 0),
        BackgroundTransparency = 1, Text = title, TextColor3 = T.TEXT,
        TextSize = 13, Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 7,
    }, hdr)

    -- Close button
    local close = make("TextButton", {
        Size = UDim2.new(0, 26, 0, 26), Position = UDim2.new(1, -32, 0.5, -13),
        BackgroundColor3 = T.RED, Text = "✕", TextColor3 = T.WHITE,
        TextSize = 11, Font = Enum.Font.GothamBold,
        AutoButtonColor = false, ZIndex = 8,
    }, hdr)
    addCorner(close, 6)
    onHover(close, T.RED, Color3.fromRGB(255, 80, 80))
    close.MouseButton1Click:Connect(function() p.Visible = false end)

    return p
end

