local function isDefaultAnimation(id)
    if DEFAULT_ANIMATION_IDS[id] then return true end
    local n = tonumber(id:match("%d+$"))
    return n and DEFAULT_NUMERIC_IDS[n]
end
local function extractNumericId(id)
    return id:match("%d+$") or id
end

-- ============================================================
-- NAME FETCH
-- ============================================================
local function fetchAnimName(numId)
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(tonumber(numId), Enum.InfoType.Asset)
    end)
    return (ok and info and info.Name) or "Unknown"
end

-- ============================================================
-- BUILDER HELPERS
-- ============================================================
local W = Color3.fromRGB(255, 255, 255)

local function addCorner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
end
local function addStroke(p, t, w)
    local s = Instance.new("UIStroke")
    s.Color = W; s.Transparency = t or 0.82; s.Thickness = w or 1
    s.Parent = p
end
local function newFrame(props)
    local f = Instance.new("Frame")
    for k, v in pairs(props) do f[k] = v end
    return f
end
local function newLabel(props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    for k, v in pairs(props) do l[k] = v end
    return l
end
local function newButton(props)
    local b = Instance.new("TextButton")
    b.BorderSizePixel = 0; b.AutoButtonColor = false
    for k, v in pairs(props) do b[k] = v end
    return b
end
local function hover(btn, onT, offT)
    btn.MouseEnter:Connect(function()  btn.BackgroundTransparency = onT  end)
    btn.MouseLeave:Connect(function()  btn.BackgroundTransparency = offT end)
end

