    corner(hdr, 10)
    -- fill bottom-round of header
    new("Frame", {
        Size             = UDim2.new(1, 0, 0, 10),
        Position         = UDim2.new(0, 0, 1, -10),
        BackgroundColor3 = T.BG2,
        BorderSizePixel  = 0,
        ZIndex           = 112,
    }, hdr)

    -- Accent strip
