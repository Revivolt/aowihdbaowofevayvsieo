-- LocalScript (place in StarterCharacterScripts or StarterPlayerScripts)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

-- CONFIG
local TARGET_PLAYER_NAME = "62_AM" -- Change this to the target player's username
local VERTICAL_OFFSET = 5 -- Studs above the target player

-- References
local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- Disable default character physics so the weld can take effect
humanoid.PlatformStand = true

-- Find the target player
local targetPlayer = Players:FindFirstChild(TARGET_PLAYER_NAME)

if not targetPlayer then
	warn("Player not found: " .. TARGET_PLAYER_NAME)
	return
end

local targetCharacter = targetPlayer.Character or targetPlayer.CharacterAdded:Wait()
local targetHRP = targetCharacter:WaitForChild("HumanoidRootPart")

-- Remove any existing weld
local existingWeld = hrp:FindFirstChild("PlayerRideWeld")
if existingWeld then
	existingWeld:Destroy()
end

-- Unanchor the local HRP just in case
hrp.Anchored = false

-- Create the weld
local weld = Instance.new("WeldConstraint")
weld.Name = "PlayerRideWeld"
weld.Part0 = hrp
weld.Part1 = targetHRP
weld.Parent = hrp

-- Offset your character above the target using CFrame before welding locks it in
hrp.CFrame = targetHRP.CFrame * CFrame.new(0, VERTICAL_OFFSET, 0)

print("Welded to " .. TARGET_PLAYER_NAME .. " successfully!")

-- Optional: Clean up if target character is removed
targetCharacter.AncestryChanged:Connect(function()
	if not targetCharacter:IsDescendantOf(workspace) then
		if weld and weld.Parent then
			weld:Destroy()
			humanoid.PlatformStand = false
			warn("Target character left — weld removed.")
		end
	end
end)
