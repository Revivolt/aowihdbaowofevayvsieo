--  SERVER CHAT
-- ════════════════════════════════════════════════════════════════════
local ChatPanel, chatBox, chatSend, addLocalMsg =
    makeChatPanel("ChatPanel", 310, 415,
        "  💬  Server Chat", T.ACCENT, "Message players on this server…")

addLocalMsg(nil, "📡 Visible to players on this server also running this script.", true)
addLocalMsg(nil, "──────────────────────────────────────────", true)

-- RemoteEvent for cross-client relay (requires small server relay script)
local LocalChatRemote = nil
task.spawn(function()
    local folder = ReplicatedStorage:FindFirstChild("CGUIv1")
    if not folder then
        folder = new("Folder", {Name = "CGUIv1"}, ReplicatedStorage)
    end
    local re = folder:FindFirstChild("LocalChat")
    if not re then
        re = new("RemoteEvent", {Name = "LocalChat"}, folder)
    end
    LocalChatRemote = re
    re.OnClientEvent:Connect(function(sender, msg)
        if type(sender) ~= "string" or type(msg) ~= "string" then return end
        if sender == LocalPlayer.Name then return end
        addLocalMsg(sender, msg)
    end)
end)

local lastLocal = 0
local function doLocalSend()
    local msg = chatBox.Text:match("^%s*(.-)%s*$")
    if msg == "" then return end
    if tick() - lastLocal < 1 then return end
    lastLocal = tick()
    chatBox.Text = ""
    msg = msg:sub(1, MAX_LEN)
    addLocalMsg(LocalPlayer.Name, msg)
    if LocalChatRemote then
        pcall(function() LocalChatRemote:FireServer(msg) end)
    end
end

chatSend.MouseButton1Click:Connect(doLocalSend)
chatBox.FocusLost:Connect(function(enter) if enter then doLocalSend() end end)

