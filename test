local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")
local TargetPlayer
local connection

local TARGET_NAME = "62_AM" -- Type the target player's username here

local function attachToPlayer(target)
    TargetPlayer = target
    if connection then
        connection:Disconnect()
    end
    local targetCharacter = TargetPlayer.Character
    if not targetCharacter then return end
    local targetHead = targetCharacter:WaitForChild("Head") -- changed to Head
    connection = RunService.RenderStepped:Connect(function()
        if not targetHead then return end
        RootPart.CFrame =
            CFrame.new(targetHead.Position + Vector3.new(0, 3.6, 0)) -- sit on top of head
            * CFrame.Angles(-math.pi/2,0,0)
        RootPart.Velocity = Vector3.new(0,0,0)
    end)
end

-- Find and attach to the named player
local target = Players:FindFirstChild(TARGET_NAME)
if target then
    attachToPlayer(target)
else
    warn("Player not found: " .. TARGET_NAME)
end
