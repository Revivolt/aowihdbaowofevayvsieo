-- LocalScript: Weld yourself above another player
-- Place inside StarterCharacterScripts or run as a LocalScript

local Players = game:GetService("Players")

-- ============================================================
--  CONFIG
-- ============================================================
local TARGET_NAME   = "62_AM"   -- Target player's username
local HEIGHT_OFFSET = 5                  -- Studs above their HumanoidRootPart
-- ============================================================

local LocalPlayer = Players.LocalPlayer
local character   = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local hrp         = character:WaitForChild("HumanoidRootPart")
local humanoid    = character:WaitForChild("Humanoid")

-- Wait for the target player to exist
local target
repeat
	target = Players:FindFirstChild(TARGET_NAME)
	if not target then task.wait(1) end
until target
print("[WeldAbove] Found target: " .. TARGET_NAME)

-- Wait for their character and root part
local targetCharacter = target.Character or target.CharacterAdded:Wait()
local targetHRP       = targetCharacter:WaitForChild("HumanoidRootPart")
print("[WeldAbove] Target character loaded.")

-- Unanchor all local character parts so the weld can move freely
for _, part in character:GetDescendants() do
	if part:IsA("BasePart") then
		part.Anchored = false
	end
end

-- Snap into position above the target before welding
hrp.CFrame = targetHRP.CFrame * CFrame.new(0, HEIGHT_OFFSET, 0)

-- Create the weld between our HRP and the target's HRP
local weld      = Instance.new("WeldConstraint")
weld.Part0      = hrp
weld.Part1      = targetHRP
weld.Parent     = hrp
print("[WeldAbove] Welded to " .. TARGET_NAME .. " (" .. HEIGHT_OFFSET .. " studs above).")

-- Clean up weld if either character is removed
local function onCharacterRemoving()
	if weld and weld.Parent then
		weld:Destroy()
		print("[WeldAbove] Weld removed (character reset).")
	end
end

LocalPlayer.CharacterRemoving:Connect(onCharacterRemoving)
target.CharacterRemoving:Connect(onCharacterRemoving)
