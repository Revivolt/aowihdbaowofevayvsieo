-- ─────────────────────────────────────────────────────────────────────────────
-- CAPTURE A SCRIPT
-- ─────────────────────────────────────────────────────────────────────────────
local function captureScript(script)
    -- Skip the GUI itself and non-script instances
    if not (script:IsA("LocalScript") or script:IsA("ModuleScript") or script:IsA("Script")) then
        return
    end
    -- Avoid duplicate captures
    for _, entry in ipairs(capturedScripts) do
        if entry.instance == script then return end
    end

    local entry = {
        instance  = script,
        name      = script.Name,
        className = script.ClassName,
        path      = getFullPath(script),
        props     = collectProps(script),
        source    = tryGetSource(script),
        time      = os.date("%H:%M:%S"),
    }

    table.insert(capturedScripts, entry)
    local idx = #capturedScripts

    -- Update count badge
    CountLabel.Text = tostring(idx)

    -- Create list entry
    createListEntry(idx, entry)

    -- Flash status bar
    StatusBarText.Text = string.format(
        "  ⬡  Captured: %s  |  Total: %d  |  %s",
        entry.name, idx, entry.time
    )
    StatusBarText.TextColor3 = THEME.SUCCESS
    task.delay(3, function()
        if StatusBarText and StatusBarText.Parent then
            StatusBarText.Text = "  ⬡  ScriptCapture v1.0  |  Monitoring LocalPlayer ..."
            StatusBarText.TextColor3 = THEME.SUBTEXT
        end
    end)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- RECURSIVE SCANNER — scan existing and watch for new scripts
-- ─────────────────────────────────────────────────────────────────────────────
local function watchInstance(inst)
    -- Capture existing descendants
    for _, desc in ipairs(inst:GetDescendants()) do
        pcall(captureScript, desc)
    end
    -- Watch for new descendants
    local conn = inst.DescendantAdded:Connect(function(desc)
        task.defer(function()   -- defer so script has time to start
            pcall(captureScript, desc)
        end)
    end)
    table.insert(logConnections, conn)
end

-- Watch all the common places scripts live under LocalPlayer
local watchTargets = {
    PlayerScripts,
    LocalPlayer:WaitForChild("Backpack"),
}
pcall(function()
    table.insert(watchTargets, LocalPlayer:WaitForChild("Character", 0))
end)

for _, target in ipairs(watchTargets) do
    watchTargets[#watchTargets + 1] = nil   -- prevent double-add
    pcall(watchInstance, target)
end

-- Also watch the top-level PlayerScripts continuously
watchInstance(PlayerScripts)

