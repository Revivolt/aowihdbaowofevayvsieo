-- ─── HELPERS ──────────────────────────────────────────────────────────────────

-- Deterministic per-player color from display name
local function nameColor(name)
    local palette = {
        Color3.fromRGB(130, 200, 255),
        Color3.fromRGB(180, 255, 180),
        Color3.fromRGB(255, 210, 130),
        Color3.fromRGB(255, 160, 200),
        Color3.fromRGB(200, 160, 255),
        Color3.fromRGB(100, 230, 220),
    }
    local n = 0
    for i = 1, #name do n = n + string.byte(name, i) end
    return palette[(n % #palette) + 1]
end

-- Scroll to the bottom of the chat log
local function scrollToBottom()
    RunService.Heartbeat:Wait()
    ScrollFrame.CanvasPosition = Vector2.new(0, ScrollFrame.AbsoluteCanvasSize.Y)
end

-- Render one message entry into the scroll frame
local function renderEntry(entry)
    local c = entry.color
    local row = Instance.new("TextLabel", ScrollFrame)
    row.Name                = "Msg"
    row.Size                = UDim2.new(1, 0, 0, 0)
    row.AutomaticSize       = Enum.AutomaticSize.Y
    row.BackgroundTransparency = 1
    row.Font                = Enum.Font.Gotham
    row.TextSize            = 12
    row.TextColor3          = Color3.fromRGB(220, 215, 255)
    row.TextXAlignment      = Enum.TextXAlignment.Left
    row.TextYAlignment      = Enum.TextYAlignment.Top
    row.TextWrapped         = true
    row.RichText            = true
    row.LayoutOrder         = entry.order
    row.Text                = string.format(
        '<font color="#%02x%02x%02x"><b>%s</b></font>'
        .. '<font color="#aaaacc">: %s</font>',
        math.floor(c.R * 255), math.floor(c.G * 255), math.floor(c.B * 255),
        entry.name,
        entry.text
    )
    scrollToBottom()
end

-- Add a player message to the log and GUI
local function addMessage(playerName, text)
    messageCount += 1
    local entry = {
        order = messageCount,
        name  = playerName,
        text  = text,
        color = nameColor(playerName),
    }
    table.insert(messageLog, entry)

    -- Remove oldest entry when over the cap
    if #messageLog > MAX_MESSAGES then
        local oldest = table.remove(messageLog, 1)
        for _, child in ipairs(ScrollFrame:GetChildren()) do
            if child:IsA("TextLabel") and child.LayoutOrder == oldest.order then
                child:Destroy()
                break
            end
        end
    end

    renderEntry(entry)
end

-- Show a local-only system notice (italicised, not sent to others)
local function systemNotice(text)
    messageCount += 1
    local row = Instance.new("TextLabel", ScrollFrame)
    row.Name                = "Sys"
    row.Size                = UDim2.new(1, 0, 0, 0)
    row.AutomaticSize       = Enum.AutomaticSize.Y
    row.BackgroundTransparency = 1
    row.Font                = Enum.Font.GothamItalic
    row.TextSize            = 11
    row.TextColor3          = Color3.fromRGB(150, 140, 200)
    row.TextXAlignment      = Enum.TextXAlignment.Left
    row.TextWrapped         = true
    row.LayoutOrder         = messageCount
    row.Text                = "  ◈ " .. text
    scrollToBottom()
end

-- ─── SEND ─────────────────────────────────────────────────────────────────────

local function sendMessage(rawText)
    rawText = rawText:match("^%s*(.-)%s*$")
    if rawText == "" then return end

    -- Prefix the secret tag so other script users can identify the message.
    -- Players without the script will still see the raw tag in normal chat.
    local tagged = SECRET_TAG .. rawText

    local ok, err = pcall(function()
        -- Try the modern TextChatService channel first
        local channels = TextChatService:FindFirstChild("TextChannels")
        local channel  = channels and channels:FindFirstChild(CHAT_CHANNEL)
        if channel then
            channel:SendAsync(tagged)
        else
            -- Fallback for games that still use the legacy Chat service
            local Chat = game:GetService("Chat")
            local head = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
            if head then
                Chat:Chat(head, tagged)
            else
                warn("[SecretChat] Could not find a chat channel to send through.")
            end
        end
    end)

    if not ok then
        systemNotice("Send failed: " .. tostring(err))
    end
end

-- ─── RECEIVE ──────────────────────────────────────────────────────────────────

--[[
    OnIncomingMessage fires for EVERY incoming chat message.
    We check for the secret tag:
      • If found   → decode, display in SC window, blank out in normal chat.
      • If missing → leave normal chat untouched (return nil).
--]]
TextChatService.OnIncomingMessage = function(message)
    local raw = message.Text or ""

    if raw:find(SECRET_TAG, 1, true) then
        -- Decode
        local clean = raw:gsub(SECRET_TAG, "", 1)
        clean = clean:match("^%s*(.-)%s*$")

        -- Identify sender
        local senderName = "Unknown"
        if message.TextSource then
            local uid    = message.TextSource.UserId
            local player = Players:GetPlayerByUserId(uid)
            senderName   = player and player.DisplayName or ("User#" .. uid)
            scriptUsers[uid] = true   -- mark as confirmed script user
        end

        -- Own messages are already shown immediately on send; skip duplicates
        local isOwn = message.TextSource
            and message.TextSource.UserId == LocalPlayer.UserId
        if not isOwn then
            addMessage(senderName, clean)
        end

        -- Suppress the tagged message in normal Roblox chat
        local props = Instance.new("TextChatMessageProperties")
        props.Text = ""
        return props
    end

    return nil   -- leave non-SC messages alone
end

-- ─── INPUT HANDLING ───────────────────────────────────────────────────────────

-- Send on Enter
TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local msg = TextBox.Text
        TextBox.Text = ""
        if msg:match("^%s*$") then return end
        addMessage(LocalPlayer.DisplayName, msg)   -- show own message immediately
        sendMessage(msg)
    end
end)

-- Send button
SendButton.MouseButton1Click:Connect(function()
    local msg = TextBox.Text
    TextBox.Text = ""
    if msg:match("^%s*$") then return end
    addMessage(LocalPlayer.DisplayName, msg)
    sendMessage(msg)
    TextBox:CaptureFocus()
end)

-- Toggle hotkey
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == TOGGLE_KEY and not gameProcessed then
        guiVisible = not guiVisible
        ScreenGui.Enabled = guiVisible
        if guiVisible then
            TextBox:CaptureFocus()
        end
    end
end)

-- ─── PLAYER LEAVE NOTICE ──────────────────────────────────────────────────────

Players.PlayerRemoving:Connect(function(player)
    if scriptUsers[player.UserId] then
        scriptUsers[player.UserId] = nil
        if guiVisible then
            systemNotice(player.DisplayName .. " left the game.")
        end
    end
end)

-- ─── READY ────────────────────────────────────────────────────────────────────

systemNotice("Secret Chat ready. Press ['] to open / close.")
