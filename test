-- ─────────────────────────────────────────────
--  MESSAGE DISPLAY
-- ─────────────────────────────────────────────
local msgOrder   = 0
local knownUsers = { [LocalPlayer.Name] = true }

local COLORS = {
    self    = Color3.fromRGB(110, 165, 255),
    other   = Color3.fromRGB(160, 230, 170),
    system  = Color3.fromRGB(110, 110, 150),
}

local function addMsg(sender, text, isSystem)
    msgOrder = msgOrder + 1

    local row = Instance.new("Frame", scroll)
    row.Size             = UDim2.new(1, 0, 0, 0)
    row.AutomaticSize    = Enum.AutomaticSize.Y
    row.BackgroundTransparency = 1
    row.LayoutOrder      = msgOrder

    local lbl = Instance.new("TextLabel", row)
    lbl.Size             = UDim2.new(1, 0, 0, 0)
    lbl.AutomaticSize    = Enum.AutomaticSize.Y
    lbl.BackgroundTransparency = 1
    lbl.TextWrapped      = true
    lbl.TextXAlignment   = Enum.TextXAlignment.Left
    lbl.RichText         = true

    if isSystem then
        lbl.Text      = "<font color='#6e6e96'>⚡ " .. text .. "</font>"
        lbl.TextSize  = 11
        lbl.Font      = Enum.Font.Gotham
        lbl.TextColor3 = COLORS.system
    elseif sender == LocalPlayer.Name then
        lbl.Text      = "<b><font color='#6ea5ff'>You</font></b>  " .. text
        lbl.TextSize  = 13
        lbl.Font      = Enum.Font.Gotham
        lbl.TextColor3 = Color3.fromRGB(210, 215, 255)
    else
        lbl.Text      = "<b><font color='#a0e6aa'>" .. sender .. "</font></b>  " .. text
        lbl.TextSize  = 13
        lbl.Font      = Enum.Font.Gotham
        lbl.TextColor3 = Color3.fromRGB(210, 215, 255)
    end

    -- Auto-scroll to bottom
    task.defer(function()
        scroll.CanvasPosition = Vector2.new(0, math.huge)
    end)

    -- Trim history
    if msgOrder > MAX_MSGS then
        for _, child in ipairs(scroll:GetChildren()) do
            if child:IsA("Frame") and child.LayoutOrder <= msgOrder - MAX_MSGS then
                child:Destroy()
            end
        end
    end
end

local function updateOnline()
    local n = 0
    for _ in pairs(knownUsers) do n = n + 1 end
    onlineBadge.Text = "● " .. n .. " online"
end

local function onScriptMessage(playerName, rawText)
    local decoded = decode(rawText)
    if not decoded then return end
    if playerName == LocalPlayer.Name then return end -- we show our own immediately

    if not knownUsers[playerName] then
        knownUsers[playerName] = true
        updateOnline()
        addMsg(nil, playerName .. " joined Script Chat", true)
    end
    addMsg(playerName, decoded)
end

-- ─────────────────────────────────────────────
--  SEND
-- ─────────────────────────────────────────────
local function sendMessage()
    local msg = inputBox.Text:match("^%s*(.-)%s*$") -- trim
    if msg == "" then return end
    inputBox.Text = ""

    addMsg(LocalPlayer.Name, msg)
    local encoded = encode(msg)

    local ok, err = pcall(function()
        if USING_NEW_CHAT then
            -- New TextChatService path
            local channels = TextChatService:FindFirstChild("TextChannels")
            if channels then
                -- Try RBXGeneral first, then any available channel
                local ch = channels:FindFirstChild("RBXGeneral")
                    or channels:FindFirstChildWhichIsA("TextChannel")
                if ch then
                    ch:SendAsync(encoded)
                end
            end
        else
            -- Legacy chat path
            local events = game:GetService("ReplicatedStorage")
                :WaitForChild("DefaultChatSystemChatEvents", 5)
            if events then
                events:WaitForChild("SayMessageRequest"):FireServer(encoded, "All")
            end
        end
    end)

    if not ok then
        addMsg(nil, "Send failed: " .. tostring(err), true)
    end
end

-- ─────────────────────────────────────────────
--  RECEIVE  (hide encoded msgs from normal chat)
-- ─────────────────────────────────────────────
if USING_NEW_CHAT then
    -- Suppress garbled text in the default chat bubble & chat window
    TextChatService.OnIncomingMessage = function(msg)
        local props = Instance.new("TextChatMessageProperties")
        if msg.Text and msg.Text:sub(1, #MSG_PREFIX) == MSG_PREFIX then
            props.Text = "" -- hide from normal chat
        end
        return props
    end

    TextChatService.MessageReceived:Connect(function(msg)
        if msg.TextSource and msg.Text:sub(1, #MSG_PREFIX) == MSG_PREFIX then
            local sender = Players:GetPlayerByUserId(msg.TextSource.UserId)
            if sender then
                onScriptMessage(sender.Name, msg.Text)
            end
        end
    end)
else
    -- Legacy: hook Chatted on every player
    local function hookPlayer(p)
        if p == LocalPlayer then return end
        p.Chatted:Connect(function(msg)
            onScriptMessage(p.Name, msg)
        end)
    end

    for _, p in ipairs(Players:GetPlayers()) do hookPlayer(p) end
    Players.PlayerAdded:Connect(hookPlayer)
end

-- Track departures
Players.PlayerRemoving:Connect(function(p)
    if knownUsers[p.Name] then
        knownUsers[p.Name] = nil
        updateOnline()
        addMsg(nil, p.Name .. " left Script Chat", true)
    end
end)

-- ─────────────────────────────────────────────
--  INPUT EVENTS
-- ─────────────────────────────────────────────
sendBtn.MouseButton1Click:Connect(sendMessage)
inputBox.FocusLost:Connect(function(enter)
    if enter then sendMessage() end
end)

-- ─────────────────────────────────────────────
--  DRAGGABLE WINDOW
-- ─────────────────────────────────────────────
do
    local dragging, dragStart, winStart = false, nil, nil

    titleBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = inp.Position
            winStart  = win.Position
        end
    end)
    titleBar.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - dragStart
            win.Position = UDim2.new(
                winStart.X.Scale, winStart.X.Offset + d.X,
                winStart.Y.Scale, winStart.Y.Offset + d.Y
            )
        end
    end)
end

