-- Update the visible log text and status
local function refreshDisplay()
    if #capturedOrder == 0 then
        LogLabel.Text = "Waiting for LocalScripts to be detected…"
        fullLog = ""
    else
        local lines = {}
        for _, ref in ipairs(capturedOrder) do
            local report = capturedScripts[ref]
            if report then
                table.insert(lines, report)
            end
        end
        fullLog = table.concat(lines, "\n")
        LogLabel.Text = fullLog
    end

    StatusLabel.Text = string.format(
        "● Monitoring… %d script(s) captured",
        #capturedOrder
    )

    -- Auto-scroll to bottom
    task.defer(function()
        ScrollFrame.CanvasPosition = Vector2.new(0, math.huge)
    end)
end

-- Register a captured script (idempotent)
local function captureScript(scriptObj)
    if capturedScripts[scriptObj] then return end   -- already captured

    local report = buildReport(scriptObj)
    capturedScripts[scriptObj] = report
    table.insert(capturedOrder, scriptObj)

    -- If the instance is destroyed later, mark it
    scriptObj.AncestryChanged:Connect(function()
        if not scriptObj:IsDescendantOf(game) then
            if capturedScripts[scriptObj] then
                capturedScripts[scriptObj] = capturedScripts[scriptObj]
                    .. "\n[⚠️  This script was removed from the DataModel]\n"
                refreshDisplay()
            end
        end
    end)

    refreshDisplay()
end

-- ─────────────────────────────────────────────────────────
--  Detection: scan a container for LocalScripts
-- ─────────────────────────────────────────────────────────
local function scanContainer(container)
    if not container then return end
    for _, obj in ipairs(container:GetDescendants()) do
        if obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
            captureScript(obj)
        end
    end
    -- Watch for newly added children
    container.DescendantAdded:Connect(function(obj)
        if obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
            captureScript(obj)
        end
    end)
end

