local ChatPanel, chatBox, chatSend, addLocalMsg =
    buildChatPanel("Chat", 308, 418,
        "  💬  Server Chat", T.ACCENT,
        "Message players on this server…")

addLocalMsg(nil, "📡 Visible to other players on this server running this script.", true)
addLocalMsg(nil, "────────────────────────────────────", true)

-- Shared RemoteEvent (requires tiny server relay script for cross-client delivery)
local LocalChatRemote = nil
task.spawn(function()
    local folder = ReplicatedStorage:FindFirstChild("CGUIv1")
                or make("Folder", {Name = "CGUIv1"}, ReplicatedStorage)
    local re = folder:FindFirstChild("LocalChat")
              or make("RemoteEvent", {Name = "LocalChat"}, folder)
    LocalChatRemote = re
    re.OnClientEvent:Connect(function(sender, msg)
        if type(sender) == "string" and type(msg) == "string" then
            if sender ~= LocalPlayer.Name then
                addLocalMsg(sender, msg)
            end
        end
    end)
end)

local lastLocalSend = 0
local function sendLocal()
    local msg = chatBox.Text:match("^%s*(.-)%s*$")
    if msg == "" then return end
    if tick() - lastLocalSend < 0.8 then return end
    lastLocalSend = tick()
    chatBox.Text = ""
    msg = msg:sub(1, 200)
    addLocalMsg(LocalPlayer.Name, msg)   -- always echo to self
    if LocalChatRemote then
        pcall(function() LocalChatRemote:FireServer(msg) end)
    end
end
chatSend.MouseButton1Click:Connect(sendLocal)
chatBox.FocusLost:Connect(function(enter) if enter then sendLocal() end end)

