-- Button factory
local function makeTopBtn(icon, xPos, tipText)
    local btn = make("TextButton", {
        Name             = icon,
        Size             = UDim2.new(0, 32, 0, 28),
        Position         = UDim2.new(0, xPos, 0, 4),
        BackgroundColor3 = T.BLACK,
        BackgroundTransparency = 1,
        Text             = icon,
        TextColor3       = T.WHITE,
        TextSize         = 17,
        Font             = Enum.Font.GothamBold,
        AutoButtonColor  = false,
        ZIndex           = 12,
    }, Root)
    addCorner(btn, 6)

    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundTransparency = 0.6})
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundTransparency = 1})
    end)
    btn.MouseButton1Down:Connect(function()
        tween(btn, {BackgroundTransparency = 0.3})
    end)
    btn.MouseButton1Up:Connect(function()
        tween(btn, {BackgroundTransparency = 0.6})
    end)

    -- Tooltip
    local tip = make("TextLabel", {
        Size                   = UDim2.new(0, 0, 0, 20),
        AutomaticSize          = Enum.AutomaticSize.X,
        Position               = UDim2.new(0.5, 0, 1, 4),
        AnchorPoint            = Vector2.new(0.5, 0),
        BackgroundColor3       = Color3.fromRGB(20, 20, 20),
        BackgroundTransparency = 0.1,
        Text                   = " " .. tipText .. " ",
        TextColor3             = T.TEXT,
        TextSize               = 11,
        Font                   = Enum.Font.Gotham,
        Visible                = false,
        ZIndex                 = 50,
    }, btn)
    addCorner(tip, 4)
    btn.MouseEnter:Connect(function() tip.Visible = true  end)
    btn.MouseLeave:Connect(function() tip.Visible = false end)

    return btn
end

local BtnMenu   = makeTopBtn("☰",  6,  "Menu")
