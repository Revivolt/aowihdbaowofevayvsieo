    local send = new("TextButton", {
        Size             = UDim2.new(0, 36, 0, 32),
        Position         = UDim2.new(1, -42, 0, 8),
        BackgroundColor3 = accent,
        Text             = "➤",
        TextColor3       = Color3.new(1, 1, 1),
        TextSize         = 15,
        Font             = Enum.Font.GothamBold,
        AutoButtonColor  = false,
        ZIndex           = 116,
    }, bar)
    corner(send, 7)
    hoverColor(send, accent, accent:Lerp(Color3.new(1,1,1), 0.15))

    local msgN = 0

    local function addMsg(sender, text, isSystem)
        msgN += 1
        local col = isSystem and T.TEXT_DIM or nameColor(sender or "?")

        local bubble = new("Frame", {
            Name             = ("M%d"):format(msgN),
            Size             = UDim2.new(1, 0, 0, 0),
            AutomaticSize    = Enum.AutomaticSize.Y,
            BackgroundColor3 = T.BG2,
            BackgroundTransparency = isSystem and 1 or 0,
            LayoutOrder      = msgN,
            ZIndex           = 116,
        }, scroll)
        corner(bubble, 6)

        local inner = new("Frame", {
            Size          = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            ZIndex        = 117,
        }, bubble)
        padObj(inner, 5)
        new("UIListLayout", {Padding = UDim.new(0, 1)}, inner)

        if not isSystem then
            local nameRow = new("Frame", {
                Size = UDim2.new(1, 0, 0, 16),
                BackgroundTransparency = 1,
                ZIndex = 117,
            }, inner)
            new("Frame", {
                Size = UDim2.new(0, 3, 1, -4), Position = UDim2.new(0, 0, 0, 2),
                BackgroundColor3 = col, BorderSizePixel = 0, ZIndex = 118,
            }, nameRow)
            new("TextLabel", {
                Size = UDim2.new(1, -8, 1, 0), Position = UDim2.new(0, 8, 0, 0),
                BackgroundTransparency = 1, Text = sender, TextColor3 = col,
                TextSize = 11, Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 118,
            }, nameRow)
        end

        new("TextLabel", {
            Size          = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Text          = text,
            TextColor3    = isSystem and T.TEXT_DIM or T.TEXT,
            TextSize      = 13,
            Font          = isSystem and Enum.Font.GothamItalic or Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped   = true,
            ZIndex        = 117,
        }, inner)

        task.defer(function()
            scroll.CanvasPosition = Vector2.new(0, math.huge)
        end)

        -- Keep last 60 messages
        local all = {}
        for _, c in ipairs(scroll:GetChildren()) do
            if c:IsA("Frame") then all[#all+1] = c end
        end
        if #all > 60 then
            table.sort(all, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
            all[1]:Destroy()
        end
    end

    return panel, box, send, addMsg
end

