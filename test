-- LocalScript: Weld to Top of Player
-- Place inside: StarterCharacterScripts or StarterPlayerScripts
-- ============================================================

local Players       = game:GetService("Players")
local RunService    = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- ──────────────────────────────────────────────
--  CONFIG  (edit these)
-- ──────────────────────────────────────────────
local TARGET_NAME   = "62_AM"   -- Username of the player to ride
local VERT_OFFSET   = 5.5                    -- Studs above their HumanoidRootPart
local DETACH_KEY    = Enum.KeyCode.X         -- Hold X to detach
-- ──────────────────────────────────────────────

local localPlayer   = Players.LocalPlayer
local character     = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local hrp           = character:WaitForChild("HumanoidRootPart")
local humanoid      = character:WaitForChild("Humanoid")
local rootJoint     = character:WaitForChild("LowerTorso"):WaitForChild("Root")

-- ── Suppress the humanoid so it stops fighting the weld ──
humanoid.PlatformStand    = true
humanoid.AutoRotate       = false
rootJoint.Enabled         = false   -- kills the root motor so physics doesn't wrestle us

-- ── Locate target ────────────────────────────────────────
local targetPlayer = Players:FindFirstChild(TARGET_NAME)
if not targetPlayer then
    -- Wait up to 15 s in case they're still loading
    local t = tick()
    repeat task.wait(0.1) targetPlayer = Players:FindFirstChild(TARGET_NAME)
    until targetPlayer or (tick() - t > 15)
end

if not targetPlayer then
    warn("[RideScript] Target player '" .. TARGET_NAME .. "' not found.")
    return
end

local targetChar  = targetPlayer.Character or targetPlayer.CharacterAdded:Wait()
local targetHRP   = targetChar:WaitForChild("HumanoidRootPart")

-- ── Snap into position BEFORE welding (WeldConstraint bakes the current delta) ──
local offset = CFrame.new(0, VERT_OFFSET, 0)   -- pure vertical, horizontal orientation locked
hrp.CFrame   = targetHRP.CFrame * offset

task.wait()   -- one physics step so the engine registers the new position

-- ── Create WeldConstraint ────────────────────────────────
local weld      = Instance.new("WeldConstraint")
weld.Part0      = targetHRP          -- anchor
weld.Part1      = hrp                -- rider
weld.Parent     = hrp

-- ── RenderStepped enforcement loop ──────────────────────
-- This is the latency shield: every frame, before the camera renders,
-- we slam the CFrame back to exactly where it should be.
-- Client-authoritative — zero network round-trip involved.
local enforceConn = RunService.RenderStepped:Connect(function()
    if not targetHRP or not targetHRP.Parent then return end

    -- Maintain exact upright horizontal position regardless of target tilt/rotation
    local targetPos = targetHRP.Position
    hrp.CFrame = CFrame.new(targetPos + Vector3.new(0, VERT_OFFSET, 0))
end)

-- ── Detach on keypress ───────────────────────────────────
local detachConn
detachConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == DETACH_KEY then
        enforceConn:Disconnect()
        detachConn:Disconnect()
        weld:Destroy()
        humanoid.PlatformStand = false
        humanoid.AutoRotate    = true
        rootJoint.Enabled      = true
        print("[RideScript] Detached.")
    end
end)

-- ── Auto-cleanup if target leaves ───────────────────────
targetPlayer.CharacterRemoving:Connect(function()
    enforceConn:Disconnect()
    weld:Destroy()
    humanoid.PlatformStand = false
    humanoid.AutoRotate    = true
    rootJoint.Enabled      = true
    warn("[RideScript] Target left — detached.")
end)

print("[RideScript] Welded to " .. TARGET_NAME .. ". Press " .. DETACH_KEY.Name .. " to detach.")
