local function makePanel(name, w, h, title, accent)
    local p = make("Frame", {
        Name             = name,
        Size             = UDim2.new(0, w, 0, h),
        Position         = UDim2.new(0, 4, 0, BAR_H + 4),
        BackgroundColor3 = T.BG,
        Visible          = false,
        ClipsDescendants = true,
        ZIndex           = 20,
    }, Root)
    addCorner(p, 10)
    addStroke(p, T.BORDER, 1)

    -- Header bar
    local hdr = make("Frame", {
        Name             = "Hdr",
        Size             = UDim2.new(1, 0, 0, 42),
        BackgroundColor3 = T.BG2,
        ZIndex           = 21,
    }, p)
    addCorner(hdr, 10)
    -- fill the bottom-rounded corners of header
    make("Frame", {
        Size = UDim2.new(1, 0, 0, 10), Position = UDim2.new(0, 0, 1, -10),
        BackgroundColor3 = T.BG2, BorderSizePixel = 0, ZIndex = 21,
    }, hdr)

    -- Colour strip on left of header
    local strip = make("Frame", {
        Size             = UDim2.new(0, 3, 0, 24),
        Position         = UDim2.new(0, 9, 0.5, -12),
        BackgroundColor3 = accent,
        BorderSizePixel  = 0,
        ZIndex           = 22,
    }, hdr)
    addCorner(strip, 2)

    make("TextLabel", {
        Size = UDim2.new(1, -80, 1, 0), Position = UDim2.new(0, 18, 0, 0),
        BackgroundTransparency = 1, Text = title, TextColor3 = T.TEXT,
        TextSize = 14, Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 22,
    }, hdr)

    -- Close button
    local close = make("TextButton", {
        Size = UDim2.new(0, 26, 0, 26), Position = UDim2.new(1, -34, 0.5, -13),
        BackgroundColor3 = T.RED, Text = "✕", TextColor3 = T.WHITE,
        TextSize = 12, Font = Enum.Font.GothamBold,
        AutoButtonColor = false, ZIndex = 23,
    }, hdr)
    addCorner(close, 6)
    onHover(close, T.RED, Color3.fromRGB(255, 80, 80))
    close.MouseButton1Click:Connect(function() p.Visible = false end)

    return p
end

