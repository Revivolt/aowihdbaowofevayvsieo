addLocal(nil, "📡  Visible to other players on this server running the same script.", true)
addLocal(nil, "─────────────────────────────", true)

-- Expose so the RemoteEvent listener (created at top) can call it
_G._CGUIAddLocal = addLocal

local lastLocal = 0
local function doLocalSend()
    local msg = chatBox.Text:match("^%s*(.-)%s*$")
    if msg == "" then return end
    local now = tick()
    if now - lastLocal < 1 then return end
    lastLocal = now
    chatBox.Text = ""
    msg = msg:sub(1, MAX_LEN)

    -- Always echo to self immediately
    addLocal(LocalPlayer.Name, msg)

    -- Try to relay through server (only works if relay Script is present)
    if LocalChatRemote then
        pcall(function() LocalChatRemote:FireServer(msg) end)
    end
end

chatSend.MouseButton1Click:Connect(doLocalSend)
chatBox.FocusLost:Connect(function(enter) if enter then doLocalSend() end end)

