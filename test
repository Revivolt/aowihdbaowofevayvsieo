        BackgroundTransparency = 1, Text = label, TextColor3 = T.TEXT,
        TextSize = 12, Font = Enum.Font.Gotham, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 7,
    }, row)

    local pill = make("TextButton", {
        Size = UDim2.new(0, 42, 0, 21), Position = UDim2.new(1, -50, 0.5, -10.5),
        BackgroundColor3 = def and T.ACCENT or T.BTN,
        Text = "", AutoButtonColor = false, ZIndex = 7,
    }, row)
    addCorner(pill, 11)

    local knob = make("Frame", {
        Size = UDim2.new(0, 15, 0, 15),
        Position = def and UDim2.new(1, -18, 0.5, -7.5) or UDim2.new(0, 3, 0.5, -7.5),
        BackgroundColor3 = T.WHITE, ZIndex = 8,
    }, pill)
    addCorner(knob, 8)

    local state = def or false
    pill.MouseButton1Click:Connect(function()
        state = not state
        tween(pill, {BackgroundColor3 = state and T.ACCENT or T.BTN})
        tween(knob, {Position = state and UDim2.new(1,-18,0.5,-7.5) or UDim2.new(0,3,0.5,-7.5)})
        if cb then cb(state) end
    end)
end

