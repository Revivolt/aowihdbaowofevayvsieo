--  GLOBAL CHAT
-- ════════════════════════════════════════════════════════════════════
local GlobalPanel, globalBox, globalSendBtn, addGlobalMsg =
    makeChatPanel("Global", 305, 410, "  🌐  Global Chat", T.GLOB,
        "Message players across all servers…")

addGlobalMsg(nil, "🌐 Chat with everyone using this script across all servers.", true)
addGlobalMsg(nil, "⚠ Needs a published game — not available in Studio test.", true)
addGlobalMsg(nil, "—————————————————————————————————", true)

task.spawn(function()
    local ok, err = pcall(function()
        MessagingService:SubscribeAsync(GLOBAL_CHANNEL, function(data)
            local d = data.Data
            if type(d) ~= "table" then return end
            if type(d.s) ~= "string" or type(d.m) ~= "string" then return end
            if d.s == LocalPlayer.Name and d.id == SERVER_ID then return end
            local pfx = d.id and ("["..d.id.."] ") or ""
            addGlobalMsg(pfx .. d.s, d.m:sub(1, MAX_LEN))
            if not GlobalPanel.Visible then
                notify("Global · " .. d.s, d.m:sub(1, 55), T.GLOB)
            end
        end)
    end)
    if not ok then
        addGlobalMsg(nil, "⚠ MessagingService unavailable: " .. tostring(err), true)
    end
end)

local lastGlobal = 0
local function sendGlobal()
    local txt = globalBox.Text:match("^%s*(.-)%s*$")
    if txt == "" or tick() - lastGlobal < 1.5 then return end
    lastGlobal = tick()
    globalBox.Text = ""
    txt = txt:sub(1, MAX_LEN)
    addGlobalMsg("[" .. SERVER_ID .. "] " .. LocalPlayer.Name, txt)
    task.spawn(function()
        local ok, err = pcall(function()
            MessagingService:PublishAsync(GLOBAL_CHANNEL, {
                s = LocalPlayer.Name, m = txt, id = SERVER_ID,
            })
        end)
        if not ok then
            addGlobalMsg(nil, "⚠ Failed to send: " .. tostring(err), true)
        end
    end)
end

globalSendBtn.MouseButton1Click:Connect(sendGlobal)
globalBox.FocusLost:Connect(function(enter) if enter then sendGlobal() end end)

