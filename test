-- Copy full log to clipboard
CopyBtn.MouseButton1Click:Connect(function()
    if fullLog == "" then
        CopyBtn.Text = "⚠️  Nothing to copy"
        task.delay(2, function() CopyBtn.Text = "📋  Copy Full Log" end)
        return
    end
    local ok = pcall(function()
        setclipboard(fullLog)   -- works in supported executors / Studio
    end)
    if not ok then
        -- Fallback: try game clipboard via TextBox trick
        pcall(function()
            UserInputService:GetFocusedTextBox()
        end)
    end
    CopyBtn.Text = "✅  Copied!"
    task.delay(2, function() CopyBtn.Text = "📋  Copy Full Log" end)
end)

