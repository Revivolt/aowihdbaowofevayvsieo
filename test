--  GLOBAL CHAT PANEL  (MessagingService — published games only)
-- ════════════════════════════════════════════════════════════════════════
local GlobalPanel, globalBox, globalSend, addGlobal =
    makeChatPanel("GlobalPanel", 308, 415,
        "  🌐  Global Chat", T.ACCENT_GLOB, "Message players across all servers…")

addGlobal(nil, "🌐  Chat with everyone using this script across all servers.", true)
addGlobal(nil, "⚠  Requires a published game — not available in Studio test.", true)
addGlobal(nil, "─────────────────────────────", true)

-- Subscribe to cross-server messages
task.spawn(function()
    local ok, err = pcall(function()
        MessagingService:SubscribeAsync(GLOBAL_CHANNEL, function(data)
            local p = data.Data
            if type(p) ~= "table" then return end
            if type(p.sender) ~= "string" or type(p.msg) ~= "string" then return end
            local prefix = p.sid and ("[" .. p.sid .. "] ") or ""
            addGlobal(prefix .. p.sender, p.msg:sub(1, MAX_LEN))
        end)
    end)
    if not ok then
        addGlobal(nil, "⚠ MessagingService unavailable: " .. tostring(err), true)
    end
end)

local lastGlobal = 0
local function doGlobalSend()
    local msg = globalBox.Text:match("^%s*(.-)%s*$")
    if msg == "" then return end
    local now = tick()
    if now - lastGlobal < 1.5 then return end
    lastGlobal = now
    globalBox.Text = ""
    msg = msg:sub(1, MAX_LEN)

    -- Echo self immediately
    addGlobal("[" .. SERVER_ID .. "] " .. LocalPlayer.Name, msg)

    -- Publish cross-server
    task.spawn(function()
        local ok, err = pcall(function()
            MessagingService:PublishAsync(GLOBAL_CHANNEL, {
                sender = LocalPlayer.Name,
                msg    = msg,
                sid    = SERVER_ID,
            })
        end)
        if not ok then
            addGlobal(nil, "⚠ Send failed: " .. tostring(err), true)
        end
    end)
end

globalSend.MouseButton1Click:Connect(doGlobalSend)
globalBox.FocusLost:Connect(function(enter) if enter then doGlobalSend() end end)

-- Notify when global message arrives with panel closed
task.spawn(function()
    pcall(function()
        MessagingService:SubscribeAsync(GLOBAL_CHANNEL .. "_notif", function(data)
            local p = data.Data
            if type(p) ~= "table" then return end
            if not GlobalPanel.Visible then
                local prefix = p.sid and ("[" .. p.sid .. "] ") or ""
                showNotif("Global · " .. (p.sender or "?"),
                    (prefix .. (p.msg or "")):sub(1, 60), T.ACCENT_GLOB)
            end
        end)
    end)
end)

