--[[
    ╔══════════════════════════════════════════════════════════╗
    ║               SECRET CHAT  —  LocalScript v2            ║
    ║  Only players running this exact script can communicate  ║
    ╚══════════════════════════════════════════════════════════╝

    HOW IT WORKS (v2 — uses the chat system for replication):
    ─────────────────────────────────────────────────────────
    Roblox LocalScript-created objects do NOT replicate to
    other clients.  The only thing that does replicate between
    clients without a ServerScript is the chat system.

    This script uses Roblox's chat as a transport layer:

    • On load it broadcasts a special handshake chat message.
    • Other running copies detect the handshake, mark you as
      "verified", and reply with their own handshake so you
      can discover each other.
    • Real messages are sent as chat messages with an invisible-
      looking prefix.  Only script users see them decoded in
      the private UI window; everyone else sees the raw prefix
      string in regular chat (a known tradeoff of LocalScript-
      only solutions — no ServerScript = no secret transport).

    USAGE:
    • Type in the secret window and press Enter / Send.
    • Press Ctrl+H or click [─] to hide/show the window.
    • Drag the title bar to move the window.
    • The window shows how many other script users are online.

    NOTE:  All three CONFIG values must be IDENTICAL in every
    copy of the script for players to recognise each other.
--]]

-- ─────────────────────────────────────────────
--  CONFIG  ← must be the same in every copy
-- ─────────────────────────────────────────────
local SECRET       = "SC_v2_a9f3c2xK"   -- shared secret token
local WINDOW_TITLE = "🔒 Secret Chat"

-- Internal prefixes derived from the secret (don't touch)
local HS_MSG  = "❮HS❯" .. SECRET .. "❮❯"   -- handshake broadcast
local MSG_PFX = "❮SC❯" .. SECRET .. "❮❯"   -- secret message prefix

-- ─────────────────────────────────────────────
--  SERVICES
-- ─────────────────────────────────────────────
local Players          = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TextChatService  = game:GetService("TextChatService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

-- ─────────────────────────────────────────────
--  SEND A CHAT MESSAGE (supports both chat systems)
-- ─────────────────────────────────────────────
local generalChannel  -- cached TextChannel for new chat system

local function findGeneralChannel()
    local tcs = TextChatService
    -- New system: TextChannels folder
    local channelsFolder = tcs:FindFirstChild("TextChannels")
    if channelsFolder then
        for _, ch in ipairs(channelsFolder:GetChildren()) do
            if ch:IsA("TextChannel") then
                generalChannel = ch
                return ch
            end
        end
    end
    return nil
end

local function sendChat(text)
    -- Try new TextChatService path first
    local ch = generalChannel or findGeneralChannel()
    if ch then
        local ok = pcall(function() ch:SendAsync(text) end)
        if ok then return end
    end
    -- Fallback: legacy Player:Chat()
    pcall(function() LocalPlayer:Chat(text) end)
end

-- ─────────────────────────────────────────────
--  HANDSHAKE LOGIC
-- ─────────────────────────────────────────────
local verifiedSet  = {}   -- [Player] = true
local lastHsSent   = 0    -- rate-limit our own HS broadcasts

local function broadcastHandshake()
    -- Throttle: don't spam HS more than once every 3 seconds
    if (os.clock() - lastHsSent) < 3 then return end
    lastHsSent = os.clock()
    sendChat(HS_MSG)
end

