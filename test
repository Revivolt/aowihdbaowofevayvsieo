task.spawn(function()
    task.wait(2)
    sendHandshake()
    addMsg("", "Ready · " .. CFG.SCRIPT_KEY, "sys")
    while true do
        task.wait(CFG.PING_INTERVAL)
        sendHandshake()
    end
end)

updateOnline()
print("[SecretChat v2] Ready · key:", CFG.SCRIPT_KEY)
