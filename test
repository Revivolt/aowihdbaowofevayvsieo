-- ============================================================
-- ENTRY LOGIC
-- ============================================================
local capturedCount = 0
local seenIds = {}

local function setStatus(msg)
    statusLabel.Text = msg
end

local function flashStatus(msg)
    setStatus(msg)
    task.delay(2.5, function()
        setStatus("● Listening for animations")
    end)
end

local function addAnimationEntry(animId)
    local numericId = extractNumericId(animId)

    if seenIds[numericId] then
        flashStatus("Already captured: " .. numericId)
        return
    end

    seenIds[numericId] = true
    capturedCount = capturedCount + 1
    emptyLabel.Visible = false
    countLabel.Text = capturedCount .. " captured"
    setStatus("Fetching name...")

    -- Row
    local row = Instance.new("Frame")
    row.LayoutOrder = capturedCount
    row.Size = UDim2.new(1, 0, 0, 58)
    row.BackgroundColor3 = WHITE
    row.BackgroundTransparency = 0.91
    row.BorderSizePixel = 0
    row.Parent = scrollFrame
    mkCorner(row, 8)
    mkStroke(row, 0.86, 1)

    -- Index pill
    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0, 24, 0, 24)
    pill.Position = UDim2.new(0, 10, 0.5, -12)
    pill.BackgroundColor3 = WHITE
    pill.BackgroundTransparency = 0.84
    pill.BorderSizePixel = 0
    pill.Parent = row
    mkCorner(pill, 6)

    local pillNum = Instance.new("TextLabel")
    pillNum.Size = UDim2.new(1, 0, 1, 0)
    pillNum.BackgroundTransparency = 1
    pillNum.Text = tostring(capturedCount)
    pillNum.TextColor3 = WHITE
    pillNum.TextTransparency = 0.10
    pillNum.TextSize = 10
    pillNum.Font = Enum.Font.GothamBold
    pillNum.Parent = pill

    -- Animation name (top line) — resolves async
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -116, 0, 22)
    nameLabel.Position = UDim2.new(0, 42, 0, 6)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = "Loading..."
    nameLabel.TextColor3 = WHITE
    nameLabel.TextTransparency = 0.10
    nameLabel.TextSize = 12
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.Parent = row

    -- Numeric ID (bottom line)
    local idLabel = Instance.new("TextLabel")
    idLabel.Size = UDim2.new(1, -116, 0, 16)
    idLabel.Position = UDim2.new(0, 42, 0, 30)
    idLabel.BackgroundTransparency = 1
    idLabel.Text = numericId
    idLabel.TextColor3 = MID
    idLabel.TextTransparency = 0.18
    idLabel.TextSize = 10
    idLabel.Font = Enum.Font.Gotham
    idLabel.TextXAlignment = Enum.TextXAlignment.Left
    idLabel.TextTruncate = Enum.TextTruncate.AtEnd
    idLabel.Parent = row

    -- Copy button
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 52, 0, 28)
    copyBtn.Position = UDim2.new(1, -60, 0.5, -14)
    copyBtn.BackgroundColor3 = WHITE
    copyBtn.BackgroundTransparency = 0.84
    copyBtn.BorderSizePixel = 0
    copyBtn.Text = "Copy"
    copyBtn.TextColor3 = WHITE
    copyBtn.TextTransparency = 0.10
    copyBtn.TextSize = 10
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.Parent = row
    mkCorner(copyBtn, 6)
    mkStroke(copyBtn, 0.80, 1)

    copyBtn.MouseEnter:Connect(function()
        if copyBtn.Text == "Copy" then copyBtn.BackgroundTransparency = 0.66 end
    end)
    copyBtn.MouseLeave:Connect(function()
        if copyBtn.Text == "Copy" then copyBtn.BackgroundTransparency = 0.84 end
    end)
    copyBtn.MouseButton1Click:Connect(function()
        setclipboard(numericId)
        copyBtn.Text = "✓"
        copyBtn.BackgroundTransparency = 0.72
        flashStatus("Copied: " .. numericId)
        task.delay(1.5, function()
            copyBtn.Text = "Copy"
            copyBtn.BackgroundTransparency = 0.84
        end)
    end)

    -- Fade-in
    row.BackgroundTransparency = 1
    TweenService:Create(row, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 0.91
    }):Play()

    task.defer(function()
        scrollFrame.CanvasPosition = Vector2.new(0, math.huge)
    end)

    -- Async name fetch
    task.spawn(function()
        local animName = fetchAnimName(numericId)
        nameLabel.Text = animName
        flashStatus("Captured: " .. animName)
    end)
end

-- Clear
clearBtn.MouseButton1Click:Connect(function()
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    seenIds = {}
    capturedCount = 0
    countLabel.Text = "0 captured"
    emptyLabel.Visible = true
    flashStatus("Cleared all entries")
end)

-- ============================================================
-- ANIMATION DETECTION
-- ============================================================
local function onAnimationPlayed(track)
    if track.Animation then
        local animId = track.Animation.AnimationId
        if animId and animId ~= "" and not isDefaultAnimation(animId) then
            addAnimationEntry(animId)
        end
    end
end

local character = player.Character or player.CharacterAdded:Wait()

local function connectHumanoid(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.AnimationPlayed:Connect(onAnimationPlayed)
end

connectHumanoid(character)

player.CharacterAdded:Connect(function(newChar)
    connectHumanoid(newChar)
end)

print("[AnimDetector] Loaded.")
