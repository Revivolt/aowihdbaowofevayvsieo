local function getPath(inst)
    local p = {}
    local c = inst
    while c and c ~= game do
        table.insert(p, 1, c.Name)
        c = c.Parent
    end
    return table.concat(p, " > ")
end

local function trySource(s)
    local ok, src = pcall(function() return s.Source end)
    if ok and type(src) == "string" and #src > 0 then return src end
    if type(decompile) == "function" then
        local ok2, d = pcall(decompile, s)
        if ok2 and type(d) == "string" and #d > 0 then
            return "-- [DECOMPILED]\n" .. d
        end
    end
    return nil
end

local function collectProps(s)
    local props, keys = {}, {"Name","ClassName","Disabled","RunContext","LinkedSource","ScriptGuid"}
    for _, k in ipairs(keys) do
        local ok, v = pcall(function() return s[k] end)
        if ok then props[k] = tostring(v) end
    end
    return props
end

local function buildReport(e)
    local L = {}
    local function ln(s) table.insert(L, s or "") end
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln("  INJECTION CAPTURE REPORT")
    ln("  Detected at: " .. e.time)
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    ln()
    ln("[ IDENTITY ]")
    ln("  Name      : " .. tostring(e.name))
    ln("  ClassName : " .. tostring(e.className))
    ln("  Path      : " .. tostring(e.path))
    ln()
    ln("[ PROPERTIES ]")
    for k, v in pairs(e.props) do
        if k ~= "Name" and k ~= "ClassName" then
            ln(string.format("  %-16s: %s", k, v))
        end
    end
    ln()
    if e.source then
        ln("[ INJECTED SOURCE CODE ]")
        ln()
        ln(e.source)
    else
        ln("[ INJECTED SOURCE CODE ]")
        ln()
        ln("-- Source not readable in this environment.")
        ln("-- Use an executor with decompile() to capture source.")
    end
    ln()
    ln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    return table.concat(L, "\n")
end

local function toClipboard(text)
    if type(setclipboard) == "function" then pcall(setclipboard, text); return true end
    if type(toclipboard)  == "function" then pcall(toclipboard,  text); return true end
    return false
end

