    classLabel.AutomaticSize = Enum.AutomaticSize.X
    classLabel.Font = Enum.Font.GothamBold

    -- Source indicator dot
    local srcDot = makeLabel(row, entry.source and "⬤" or "○", 9,
        entry.source and THEME.SUCCESS or THEME.WARNING)
    srcDot.Size = UDim2.new(0, 12, 0, 12)
    srcDot.Position = UDim2.new(1, -16, 0, 4)

    -- Select logic
    local normalBG = isEven and THEME.ENTRY_EVEN or THEME.ENTRY_ODD
    local function setSelected(sel)
        if sel then
            row.BackgroundColor3 = Color3.fromRGB(30, 45, 75)
            bar.BackgroundColor3 = THEME.ACCENT2
        else
            row.BackgroundColor3 = normalBG
            bar.BackgroundColor3 = THEME.ACCENT
        end
    end

    row.MouseButton1Click:Connect(function()
        -- Deselect previous
        for _, child in ipairs(ListScroll:GetChildren()) do
            if child:IsA("TextButton") then
                local idx = tonumber(child.Name:match("Entry_(%d+)"))
                if idx then
                    local even = (idx % 2 == 0)
                    child.BackgroundColor3 = even and THEME.ENTRY_EVEN or THEME.ENTRY_ODD
                    local b = child:FindFirstChildOfClass("Frame")
                    if b then b.BackgroundColor3 = THEME.ACCENT end
                end
            end
        end
        setSelected(true)
        selectedIndex = index
        -- Populate right panel
        local data = capturedScripts[index]
        if data then
            DetailText.Text = buildReport(data)
            DetailText.TextColor3 = THEME.CODE_TEXT
            DetailTitle.Text = "📄  " .. data.name
        end
    end)

    row.MouseEnter:Connect(function()
        if selectedIndex ~= index then
            row.BackgroundColor3 = Color3.fromRGB(28, 32, 52)
        end
    end)
    row.MouseLeave:Connect(function()
        if selectedIndex ~= index then
            row.BackgroundColor3 = normalBG
        end
    end)

    return row
end

