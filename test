-- ─────────────────────────────────────────────────────────
--  FUNCTIONS
-- ─────────────────────────────────────────────────────────
local function updateOnline()
    local n = 0
    for _ in pairs(scriptUsers) do n += 1 end
    CountLbl.Text = tostring(n)
    local col = n > 0 and C.accent or C.sysText
    Dot.BackgroundColor3 = col
    CountLbl.TextColor3  = n > 0 and C.accent or C.subText
end

local function scrollBottom()
    task.defer(function() Scroll.CanvasPosition = Vector2.new(0, 1e6) end)
end

local function addMsg(sender, body, kind)
    msgCount += 1
    if msgCount > CFG.MAX_MESSAGES then
        local f = Scroll:FindFirstChildWhichIsA("Frame")
        if f then f:Destroy() end
    end

    local Row = Instance.new("Frame")
    Row.LayoutOrder          = msgCount
    Row.Size                 = UDim2.new(1, 0, 0, 0)
    Row.AutomaticSize        = Enum.AutomaticSize.Y
    Row.BackgroundTransparency = 1
    Row.Parent               = Scroll

    local Lbl = Instance.new("TextLabel")
    Lbl.Size             = UDim2.new(1, 0, 0, 0)
    Lbl.AutomaticSize    = Enum.AutomaticSize.Y
    Lbl.BackgroundTransparency = 1
    Lbl.TextWrapped      = true
    Lbl.RichText         = true
    Lbl.TextSize         = 11
    Lbl.Font             = Enum.Font.Gotham
    Lbl.TextXAlignment   = Enum.TextXAlignment.Left
    Lbl.ZIndex           = 3
    Lbl.Parent           = Row

    if kind == "sys" then
        Lbl.Text = string.format('<font color="#2a3558"><i>%s</i></font>', body)
    elseif kind == "self" then
        Lbl.Text = string.format(
            '<font color="#50BEFF"><b>%s</b></font><font color="#252e50"> › </font><font color="#bfcfe8">%s</font>',
            sender, body)
    else
        Lbl.Text = string.format(
            '<font color="#FF9150"><b>%s</b></font><font color="#252e50"> › </font><font color="#bfcfe8">%s</font>',
            sender, body)
    end

    scrollBottom()
end

-- ─────────────────────────────────────────────────────────
--  CHAT SEND
-- ─────────────────────────────────────────────────────────
local function getChannel()
    local chs = TextChatService:FindFirstChild("TextChannels")
    return chs and chs:FindFirstChild("RBXGeneral")
end

local function rawSend(text)
    local ch = getChannel()
    if ch then pcall(function() ch:SendAsync(text) end) end
end

local function sendHandshake() rawSend(HS_TAG) end

local function sendMsg(text)
    text = text:match("^%s*(.-)%s*$")
    if text == "" then return end
    rawSend(MSG_TAG .. text)
    addMsg(LocalPlayer.Name, text, "self")
end

-- ─────────────────────────────────────────────────────────
--  INTERCEPT INCOMING
-- ─────────────────────────────────────────────────────────
TextChatService.OnIncomingMessage = function(msg)
    local text   = msg.Text or ""
    local source = msg.TextSource
    if not source then return msg end

    local sender = Players:GetPlayerByUserId(source.UserId)

    if not sender or sender == LocalPlayer then
        if text:sub(1, #HS_TAG) == HS_TAG or text:sub(1, #MSG_TAG) == MSG_TAG then
            msg.Text = ""
        end
        return msg
    end

    if text:sub(1, #HS_TAG) == HS_TAG then
        if not scriptUsers[sender.Name] then
            scriptUsers[sender.Name] = true
            updateOnline()
            addMsg("", sender.Name .. " connected 🔓", "sys")
            task.delay(0.6, sendHandshake)
        end
        msg.Text = ""
        return msg
    end

    if text:sub(1, #MSG_TAG) == MSG_TAG then
        local body = text:sub(#MSG_TAG + 1)
        if not scriptUsers[sender.Name] then
            scriptUsers[sender.Name] = true
            updateOnline()
            task.delay(0.6, sendHandshake)
        end
        addMsg(sender.Name, body, "other")
        msg.Text = ""
        return msg
    end

    return msg
end

