--  GLOBAL CHAT  (MessagingService — published games only)
-- ══════════════════════════════════════════════════════════════════════
local GLOBAL_CHANNEL = "CGUIv1_Global"
local SERVER_ID      = tostring(game.JobId):sub(1, 6)

local GlobalPanel, globalBox, globalSend, addGlobalMsg =
    buildChatPanel("Global", 308, 418,
        "  🌐  Global Chat", T.ACCENT_GLOB,
        "Message players across all servers…")

addGlobalMsg(nil, "🌐 Chat with everyone using this script across all servers.", true)
addGlobalMsg(nil, "⚠ Requires a published game (not Studio solo-test).", true)
addGlobalMsg(nil, "────────────────────────────────────", true)

task.spawn(function()
    local ok, err = pcall(function()
        MessagingService:SubscribeAsync(GLOBAL_CHANNEL, function(data)
            local p = data.Data
            if type(p) ~= "table" then return end
            if type(p.s) ~= "string" or type(p.m) ~= "string" then return end
            if p.s == LocalPlayer.Name and p.id == SERVER_ID then return end
            local prefix = p.id and ("["..p.id.."] ") or ""
            addGlobalMsg(prefix .. p.s, p.m:sub(1, 200))
            if not GlobalPanel.Visible then
                notify("Global · " .. p.s, p.m:sub(1, 55), T.ACCENT_GLOB)
            end
        end)
    end)
    if not ok then
        addGlobalMsg(nil, "⚠ MessagingService unavailable: "..tostring(err), true)
    end
end)

local lastGlobalSend = 0
local function sendGlobal()
    local msg = globalBox.Text:match("^%s*(.-)%s*$")
    if msg == "" then return end
    if tick() - lastGlobalSend < 1.2 then return end
    lastGlobalSend = tick()
    globalBox.Text = ""
    msg = msg:sub(1, 200)
    addGlobalMsg("["..SERVER_ID.."] "..LocalPlayer.Name, msg)
    task.spawn(function()
        local ok, err = pcall(function()
            MessagingService:PublishAsync(GLOBAL_CHANNEL, {
                s  = LocalPlayer.Name,
                m  = msg,
                id = SERVER_ID,
            })
        end)
        if not ok then
            addGlobalMsg(nil, "⚠ Publish failed: "..tostring(err), true)
        end
    end)
end
globalSend.MouseButton1Click:Connect(sendGlobal)
globalBox.FocusLost:Connect(function(enter) if enter then sendGlobal() end end)

