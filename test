local function makePanel(name, w, h, title, accent)
    -- Shadow
    local pshadow = inst("Frame",{
        Size=UDim2.new(0,w+8,0,h+8),
        Position=UDim2.new(0,70,0,58),
        BackgroundColor3=C.BLACK,
        BackgroundTransparency=0.6,
        Visible=false,
        ZIndex=9,
    },SG)
    rnd(pshadow,16)

    local p = inst("Frame",{
        Name=name,
        Size=UDim2.new(0,w,0,h),
        Position=UDim2.new(0,68,0,62),
        BackgroundColor3=C.BG,
        Visible=false,
        ClipsDescendants=true,
        ZIndex=10,
    },SG)
    rnd(p,14)
    brdr(p,C.BORDER,1)

    -- Sync shadow visibility with panel
    p:GetPropertyChangedSignal("Visible"):Connect(function()
        pshadow.Visible=p.Visible
    end)

    -- Header
    local hdr = inst("Frame",{
        Name="Hdr",
        Size=UDim2.new(1,0,0,44),
        BackgroundColor3=C.SURFACE,
        ZIndex=11,
    },p)
    rnd(hdr,14)
    inst("Frame",{  -- fill bottom corners of header
        Size=UDim2.new(1,0,0,14),Position=UDim2.new(0,0,1,-14),
        BackgroundColor3=C.SURFACE,BorderSizePixel=0,ZIndex=11,
    },hdr)

    -- Accent dot
    inst("Frame",{
        Size=UDim2.new(0,8,0,8),Position=UDim2.new(0,14,0.5,-4),
        BackgroundColor3=accent,BorderSizePixel=0,ZIndex=12,
    },hdr):FindFirstAncestorWhichIsA("GuiObject") -- noop, just trigger parent
    local dot=inst("Frame",{
        Size=UDim2.new(0,8,0,8),Position=UDim2.new(0,14,0.5,-4),
        BackgroundColor3=accent,BorderSizePixel=0,ZIndex=12,
    },hdr)
    rnd(dot,4)

    inst("TextLabel",{
        Size=UDim2.new(1,-80,1,0),Position=UDim2.new(0,28,0,0),
        BackgroundTransparency=1,Text=title,TextColor3=C.TEXT,
        TextSize=14,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12,
    },hdr)

    local close=inst("TextButton",{
        Size=UDim2.new(0,28,0,28),Position=UDim2.new(1,-36,0.5,-14),
        BackgroundColor3=Color3.fromRGB(55,38,38),Text="✕",TextColor3=C.RED,
        TextSize=13,Font=Enum.Font.GothamBold,AutoButtonColor=false,ZIndex=13,
    },hdr)
    rnd(close,7)
    close.MouseEnter:Connect(function() tw(close,{BackgroundColor3=C.RED,TextColor3=C.WHITE}) end)
    close.MouseLeave:Connect(function() tw(close,{BackgroundColor3=Color3.fromRGB(55,38,38),TextColor3=C.RED}) end)
    close.MouseButton1Click:Connect(function() p.Visible=false end)

    return p
end

