-- ─────────────────────────────────────────────────────────────────────────────
-- REGISTER A CAPTURE
-- ─────────────────────────────────────────────────────────────────────────────
local function registerCapture(inst, method)
    -- Deduplicate
    for _, e in ipairs(captured) do if e.instance == inst then return end end

    local entry = {
        instance  = inst,
        name      = inst.Name,
        className = inst.ClassName,
        path      = getPath(inst),
        props     = collectProps(inst),
        source    = trySource(inst),
        time      = os.date("%X"),
        method    = method or "DataModel",
    }
    table.insert(captured, entry)
    local idx = #captured

    cntLbl.Text = tostring(idx)
    addRow(idx, entry)
    setStatus(string.format("⚠  Injection: %s  [%s]  @ %s", entry.name, entry.method, entry.time), T.DANGER)
    warn(string.format("[InjDetect] Caught '%s' via %s @ %s", entry.name, entry.method, entry.path))
end

-- ─────────────────────────────────────────────────────────────────────────────
-- FILTER: should we ignore this instance?
-- ─────────────────────────────────────────────────────────────────────────────
local function shouldIgnore(inst)
    -- Must be a script type
    if not (inst:IsA("LocalScript") or inst:IsA("ModuleScript") or inst:IsA("Script")) then
        return true
    end
    -- In snapshot (existed at load time or was a character script)
    if snapshot[inst] then return true end
    -- Known Roblox default name
    if ROBLOX_DEFAULTS[inst.Name] then return true end
    -- Inside a character model (extra safety net)
    local cur = inst.Parent
    while cur do
        if cur == workspace then break end
        -- If any ancestor is a player's character model
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character and cur == p.Character then return true end
        end
        cur = cur.Parent
    end
    return false
end

-- ─────────────────────────────────────────────────────────────────────────────
-- HOOK: loadstring
-- Many executors run scripts through loadstring(). We wrap it to intercept.
-- ─────────────────────────────────────────────────────────────────────────────
local function tryHookLoadstring()
    if type(hookfunction) ~= "function" then return false end
    if type(loadstring) ~= "function"   then return false end

    local orig = loadstring
    local ok = pcall(hookfunction, loadstring, function(src, chunkName)
        if armed and type(src) == "string" and #src > 0 then
            -- Build a synthetic entry (no real instance)
            local entry = {
                instance  = nil,
                name      = chunkName or "(anonymous loadstring)",
                className = "loadstring",
                path      = chunkName or "N/A",
                props     = { Source = "(runtime string)", Chunk = tostring(chunkName) },
                source    = src,
                time      = os.date("%X"),
                method    = "loadstring",
            }
            -- dedup by first 80 chars of source
            local sig = src:sub(1, 80)
            for _, e in ipairs(captured) do
                if e.source and e.source:sub(1,80) == sig then return orig(src, chunkName) end
            end
            table.insert(captured, entry)
            local idx = #captured
            cntLbl.Text = tostring(idx)
            addRow(idx, entry)
            setStatus(string.format("⚠  loadstring injection: %s  @ %s", entry.name, entry.time), T.DANGER)
        end
        return orig(src, chunkName)
    end)
    return ok
end

-- ─────────────────────────────────────────────────────────────────────────────
-- WATCH: DataModel DescendantAdded
-- Catches scripts that ARE parented into the tree (some executors do this)
-- ─────────────────────────────────────────────────────────────────────────────
local function watchDataModel()
    local conn = game.DescendantAdded:Connect(function(inst)
        if not armed then return end
        task.defer(function()
            if not shouldIgnore(inst) then
                pcall(registerCapture, inst, "DataModel")
            end
        end)
    end)
    table.insert(conns, conn)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- CHARACTER — snapshot scripts on each spawn so Health/Animate are ignored
-- ─────────────────────────────────────────────────────────────────────────────
local function onCharacter(char)
    -- Snapshot the character tree IMMEDIATELY (before DescendantAdded fires)
    snapAdd(char)
    -- Also watch for future char descendants and snapshot them before eval
    -- (equipment, tool scripts, etc. that Roblox adds automatically)
    local innerConn
    innerConn = char.DescendantAdded:Connect(function(d)
        -- If this fires BEFORE armed, just add to snapshot
        if not armed then
            if d:IsA("LuaSourceContainer") then snapshot[d] = true end
        end
    end)
    table.insert(conns, innerConn)
end

LocalPlayer.CharacterAdded:Connect(onCharacter)
if LocalPlayer.Character then onCharacter(LocalPlayer.Character) end

-- ─────────────────────────────────────────────────────────────────────────────
-- MAIN INIT — wait for load, snapshot, arm
-- ─────────────────────────────────────────────────────────────────────────────
task.spawn(function()
    -- Wait for full load
    if not game:IsLoaded() then game.Loaded:Wait() end
    for _ = 1, 15 do RunService.Heartbeat:Wait() end   -- extra buffer

    -- Snapshot everything currently in the tree
    for _, d in ipairs(game:GetDescendants()) do
        if d:IsA("LuaSourceContainer") then snapshot[d] = true end
    end
    local snapCount = 0
    for _ in pairs(snapshot) do snapCount = snapCount + 1 end

    -- Try to hook loadstring
    local hooked = tryHookLoadstring()

    -- Start DataModel watcher
    watchDataModel()

    -- Mark armed
    armed = true

    -- Update UI
    pillDot.TextColor3 = T.SUCCESS; pillTxt.TextColor3 = T.SUCCESS
    pillTxt.Text = "ARMED"; pill.BackgroundColor3 = Color3.fromRGB(20,55,30)

    local hookStatus = hooked and "  |  loadstring hooked ✓" or "  |  loadstring hook N/A"
    setStatus(string.format("✓  Armed — %d scripts ignored%s", snapCount, hookStatus), T.SUCCESS, true)
    dText.Text = string.format(
        "-- Armed.\n-- %d pre-existing scripts snapshotted and ignored.\n-- Character scripts (Health, Animate, etc.) are also filtered.\n-- loadstring hook: %s\n\n-- Waiting for injections…",
        snapCount, hooked and "active" or "not available (run via executor for this)"
    )
    dText.TextColor3 = T.SUB

    print(string.format("[InjDetect] Armed. %d ignored. loadstring hook: %s", snapCount, tostring(hooked)))
end)
