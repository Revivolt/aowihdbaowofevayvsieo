-- ============================================================
--  BUTTON / INPUT LOGIC
-- ============================================================
local function triggerPlay()
    if isPlaying then
        statusLabel.Text = "⏳ Already playing — press Stop first"
        return
    end
    local input = textBox.Text
    if input == "" then
        statusLabel.Text = "⚠  Please type something first!"
        return
    end
    statusLabel.Text = '▶ Playing: "' .. input .. '"'
    playButton.BackgroundColor3 = Color3.fromRGB(50, 50, 140)
    task.spawn(function()
        playAnimationsForText(input)
        statusLabel.Text = '✔ Done: "' .. input .. '"'
        playButton.BackgroundColor3 = Color3.fromRGB(80, 80, 200)
    end)
end

-- Press Enter inside the text box
textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        triggerPlay()
    end
end)

-- Click Play button
playButton.MouseButton1Click:Connect(triggerPlay)

-- Hover effects for Play button
playButton.MouseEnter:Connect(function()
    if not isPlaying then
        playButton.BackgroundColor3 = Color3.fromRGB(100, 100, 230)
    end
end)
playButton.MouseLeave:Connect(function()
    if not isPlaying then
        playButton.BackgroundColor3 = Color3.fromRGB(80, 80, 200)
    end
end)

-- Click Stop button
stopButton.MouseButton1Click:Connect(function()
    if isPlaying then
        isPlaying = false
        stopCurrentTrack()
        statusLabel.Text = "⏹ Stopped."
        playButton.BackgroundColor3 = Color3.fromRGB(80, 80, 200)
    end
end)

-- Hover effects for Stop button
stopButton.MouseEnter:Connect(function()
    stopButton.BackgroundColor3 = Color3.fromRGB(210, 70, 70)
end)
stopButton.MouseLeave:Connect(function()
    stopButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
end)

