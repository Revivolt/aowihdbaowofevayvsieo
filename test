    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
end

local function mkStroke(parent, t, w)
    local s = Instance.new("UIStroke")
    s.Color = Color3.fromRGB(255, 255, 255)
    s.Transparency = t or 0.82
    s.Thickness = w or 1
    s.Parent = parent
end

