-- LocalScript: Place in StarterCharacterScripts
-- Welds your character above a target player with low-latency replication.

local Players         = game:GetService("Players")
local RunService      = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- ─── CONFIG ───────────────────────────────────────────────────────────────────
local CONFIG = {
	TargetName   = "62_AM",  -- Exact username of the player to sit above
	HeightOffset = 5,                 -- Studs above their HumanoidRootPart
	ToggleKey    = Enum.KeyCode.E,    -- Key to attach / detach
	MatchOrientation = true,          -- Inherit the target's facing direction
}
-- ─────────────────────────────────────────────────────────────────────────────

local localPlayer = Players.LocalPlayer
local attached    = false
local heartbeat   = nil

-- Returns the local character's HRP and Humanoid, or nils if unavailable
local function getLocalParts()
	local char = localPlayer.Character
	if not char then return nil, nil end
	return char:FindFirstChild("HumanoidRootPart"),
	       char:FindFirstChildOfClass("Humanoid")
end

-- Returns the target's HRP, or nil
local function getTargetHRP()
	local target = Players:FindFirstChild(CONFIG.TargetName)
	if not (target and target.Character) then return nil end
	return target.Character:FindFirstChild("HumanoidRootPart")
end

local function attach()
	local hrp, hum = getLocalParts()
	if not (hrp and hum) then
		warn("[Attach] Local character not ready.")
		return
	end

	if not getTargetHRP() then
		warn("[Attach] Target '"..CONFIG.TargetName.."' not found or has no character.")
		return
	end

	attached = true
	hrp.Anchored = false

	-- Physics state: the Humanoid stops overriding our CFrame assignments.
	-- This is the key step that makes client-side positioning smooth and
	-- prevents the character controller from fighting the placement.
	hum:ChangeState(Enum.HumanoidStateType.Physics)

	heartbeat = RunService.Heartbeat:Connect(function()
		local myHRP, myHum = getLocalParts()
		local targetHRP    = getTargetHRP()

		if not (myHRP and targetHRP and myHum) then return end

		-- Build the desired world CFrame: target position + height offset.
		-- Optionally inherit target's rotation so we face the same direction.
		local targetCF = targetHRP.CFrame
		local desiredCF

		if CONFIG.MatchOrientation then
			-- Same rotation as target, shifted up on the Y axis in world space
			desiredCF = CFrame.new(targetCF.Position + Vector3.new(0, CONFIG.HeightOffset, 0))
			            * (targetCF - targetCF.Position)  -- rotation component only
		else
			desiredCF = CFrame.new(targetCF.Position + Vector3.new(0, CONFIG.HeightOffset, 0))
		end

		myHRP.CFrame = desiredCF

		-- Copy the target's linear velocity so our character moves in the same
		-- inertial frame. Without this you get a one-frame stutter every time
		-- the target accelerates.
		myHRP.AssemblyLinearVelocity  = targetHRP.AssemblyLinearVelocity
		myHRP.AssemblyAngularVelocity = Vector3.zero
	end)

	print("[Attach] Attached above '"..CONFIG.TargetName.."'. Press "..CONFIG.ToggleKey.Name.." to detach.")
end

local function detach()
	attached = false

	if heartbeat then
		heartbeat:Disconnect()
		heartbeat = nil
	end

	local _, hum = getLocalParts()
	if hum then
		-- GettingUp transitions back to normal locomotion
		hum:ChangeState(Enum.HumanoidStateType.GettingUp)
	end

	print("[Attach] Detached.")
end

-- Toggle on keypress
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == CONFIG.ToggleKey then
		if attached then detach() else attach() end
	end
end)

-- Auto-detach on death / respawn so the new character starts clean
localPlayer.CharacterAdded:Connect(function()
	if heartbeat then
		heartbeat:Disconnect()
		heartbeat = nil
	end
	attached = false
end)
