local function watchDataModel()
    table.insert(conns, game.DescendantAdded:Connect(function(inst)
        if not armed then return end
        task.defer(function()
            if not shouldIgnore(inst) then pcall(registerCapture, inst, "DataModel") end
        end)
    end))
end

