local function makePanel(name, w, h, title, accent)
    local p = new("Frame", {
        Name             = name,
        Size             = UDim2.new(0, w, 0, h),
        Position         = UDim2.new(0, 8, 0, 60),
        BackgroundColor3 = T.BG,
        Visible          = false,
        ClipsDescendants = true,
        ZIndex           = 5,
    }, Root)
    corner(p, 12)
    stroke(p, T.BORDER, 1)

    -- Header
    local hdr = new("Frame", {Size=UDim2.new(1,0,0,44), BackgroundColor3=T.BG2, ZIndex=6}, p)
    corner(hdr, 12)
    new("Frame", {Size=UDim2.new(1,0,0,12), Position=UDim2.new(0,0,1,-12),
        BackgroundColor3=T.BG2, BorderSizePixel=0, ZIndex=6}, hdr)

    local strip = new("Frame", {
        Size=UDim2.new(0,3,1,-16), Position=UDim2.new(0,8,0.5,0),
        AnchorPoint=Vector2.new(0,0.5), BackgroundColor3=accent or T.ACCENT,
        BorderSizePixel=0, ZIndex=7,
    }, hdr)
    corner(strip, 2)

    new("TextLabel", {
        Size=UDim2.new(1,-80,1,0), Position=UDim2.new(0,18,0,0),
        BackgroundTransparency=1, Text=title, TextColor3=T.TEXT,
        TextSize=14, Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=7,
    }, hdr)

    local close = new("TextButton", {
        Size=UDim2.new(0,28,0,28), Position=UDim2.new(1,-36,0.5,-14),
        BackgroundColor3=T.RED, Text="✕", TextColor3=T.TEXT,
        TextSize=12, Font=Enum.Font.GothamBold, AutoButtonColor=false, ZIndex=8,
    }, hdr)
    corner(close, 7)
    hover(close, T.RED, Color3.fromRGB(255, 88, 88))
    close.MouseButton1Click:Connect(function() p.Visible = false end)

    return p
end

