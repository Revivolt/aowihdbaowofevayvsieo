-- ============================================================
--  HoverAbovePlayer  •  LocalScript  (v2 – flat + no-lag)
--  Place in: StarterPlayerScripts or StarterCharacterScripts
-- ============================================================

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local localPlayer = Players.LocalPlayer

-- ── CONFIG ────────────────────────────────────────────────────
local TARGET_NAME   = "62_AM"  -- ← target's exact username
local HEIGHT_OFFSET = 5                        -- studs above their HumanoidRootPart
-- ─────────────────────────────────────────────────────────────

local heartbeatConn: RBXScriptConnection? = nil
local isHovering = false

-- ── Helpers ───────────────────────────────────────────────────

local function getRoot(character: Model): BasePart?
    return character:FindFirstChild("HumanoidRootPart") :: BasePart?
end

local function getHumanoid(character: Model): Humanoid?
    return character:FindFirstChildOfClass("Humanoid")
end

-- ── Start hovering ────────────────────────────────────────────

local function startHover(targetName: string)
    if isHovering then
        warn("[Hover] Already hovering. Call /unweld first.")
        return
    end

    local localChar = localPlayer.Character
    if not localChar then
        warn("[Hover] Local character not ready.")
        return
    end

    local targetPlayer = Players:FindFirstChild(targetName) :: Player?
    if not targetPlayer then
        warn(("[Hover] Player '%s' not found."):format(targetName))
        return
    end

    local targetChar = targetPlayer.Character
    if not targetChar then
        warn(("[Hover] '%s' has no character yet."):format(targetName))
        return
    end

    local localRoot  = getRoot(localChar)
    local targetRoot = getRoot(targetChar)
    if not localRoot or not targetRoot then
        warn("[Hover] Missing HumanoidRootPart(s).")
        return
    end

    -- Freeze local character so normal physics don't fight us
    local humanoid = getHumanoid(localChar)
    if humanoid then
        humanoid.PlatformStand = true
    end
    localRoot.Anchored = true

    isHovering = true
    print(("[Hover] ✅ Now hovering above %s"):format(targetName))

    -- ── Heartbeat loop ────────────────────────────────────────
    -- Runs every frame on the CLIENT only – no server round-trip,
    -- so movement tracking has no network latency.
    heartbeatConn = RunService.Heartbeat:Connect(function()
        if not localChar.Parent or not targetChar.Parent then
            stopHover()
            print("[Hover] A character was removed – hover stopped.")
            return
        end

        localRoot  = getRoot(localChar)
        targetRoot = getRoot(targetChar)
        if not localRoot or not targetRoot then return end

        --[[
            CFrame breakdown:
              hoverPos  – world position directly above the target
              yawCF     – copy ONLY the target's horizontal yaw so we
                          spin with them but keep a flat orientation
              flatCF    – pitch our character –90° so their body lies
                          FLAT / HORIZONTAL (parallel to the ground,
                          face pointing downward like a plank)
        --]]
        local tPos  = targetRoot.Position
        local tYaw  = math.atan2(
                          -targetRoot.CFrame.LookVector.X,
                          -targetRoot.CFrame.LookVector.Z
                      )

        local hoverPos = CFrame.new(tPos.X, tPos.Y + HEIGHT_OFFSET, tPos.Z)
        local yawCF    = CFrame.Angles(0, tYaw, 0)
        local flatCF   = CFrame.Angles(math.rad(-90), 0, 0)

        localRoot.CFrame = hoverPos * yawCF * flatCF
    end)
end

-- ── Stop hovering ─────────────────────────────────────────────

function stopHover()
    if heartbeatConn then
        heartbeatConn:Disconnect()
        heartbeatConn = nil
    end
    isHovering = false

    local localChar = localPlayer.Character
    if not localChar then return end

    local localRoot = getRoot(localChar)
    if localRoot then
        localRoot.Anchored = false
    end

    local humanoid = getHumanoid(localChar)
    if humanoid then
        humanoid.PlatformStand = false
    end

    print("[Hover] 🔓 Hover removed. Control restored.")
end

-- ── Chat commands ─────────────────────────────────────────────
--   /hover  [PlayerName]   → hover above that player
--   /unweld                → stop

localPlayer.Chatted:Connect(function(msg: string)
    local lower = msg:lower()
    local parts = msg:split(" ")
    if lower:sub(1, 6) == "/hover" then
        startHover(parts[2] or TARGET_NAME)
    elseif lower == "/unweld" then
        stopHover()
    end
end)

-- ── Keyboard shortcuts ────────────────────────────────────────
--   F5  →  hover above TARGET_NAME
--   F6  →  stop

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F5 then
        startHover(TARGET_NAME)
    elseif input.KeyCode == Enum.KeyCode.F6 then
        stopHover()
    end
end)

