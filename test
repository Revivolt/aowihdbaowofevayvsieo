-- Build top-bar icon buttons
local function makeTopBtn(icon, posX, tooltip)
    local btn = new("TextButton", {
        Size             = UDim2.new(0, BTN_SZ, 0, BTN_SZ),
        Position         = UDim2.new(0, posX, 0.5, -BTN_SZ / 2),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 1,
        Text             = icon,
        TextColor3       = Color3.fromRGB(255, 255, 255),
        TextSize         = 18,
        Font             = Enum.Font.GothamBold,
        AutoButtonColor  = false,
        ZIndex           = 102,
    }, LeftPill)
    corner(btn, 6)

    -- Pressed flash
    btn.MouseButton1Down:Connect(function()
        tw(btn, {BackgroundTransparency = 0.3})
    end)
    btn.MouseButton1Up:Connect(function()
        tw(btn, {BackgroundTransparency = 1})
    end)
    btn.MouseLeave:Connect(function()
        tw(btn, {BackgroundTransparency = 1})
    end)

    -- Tooltip
    if tooltip then
        local tip = new("TextLabel", {
            Size                   = UDim2.new(0, 0, 0, 22),
            AutomaticSize          = Enum.AutomaticSize.X,
            Position               = UDim2.new(0.5, 0, 1, 4),
            AnchorPoint            = Vector2.new(0.5, 0),
            BackgroundColor3       = Color3.fromRGB(0, 0, 0),
            BackgroundTransparency = 0.2,
            Text                   = "  " .. tooltip .. "  ",
            TextColor3             = T.TEXT,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            Visible                = false,
            ZIndex                 = 200,
        }, btn)
        corner(tip, 4)
        btn.MouseEnter:Connect(function() tip.Visible = true  end)
        btn.MouseLeave:Connect(function() tip.Visible = false end)
    end

    return btn
end

local xOffset = BTN_PAD
