local panels = {
    {btn = BtnMenu,   panel = MenuPanel},
    {btn = BtnChat,   panel = ChatPanel},
    {btn = BtnGlobal, panel = GlobalPanel},
}

local function setTint(btn, on)
    tw(btn, {BackgroundTransparency = on and 0.42 or 0.85})
end

for _, e in ipairs(panels) do
    e.btn.MouseButton1Click:Connect(function()
        local opening = not e.panel.Visible
        for _, x in ipairs(panels) do
            x.panel.Visible = false
            setTint(x.btn, false)
        end
        e.panel.Visible = opening
        setTint(e.btn, opening)
    end)
end

