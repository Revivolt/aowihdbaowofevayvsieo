-- ─────────────────────────────────────────────────────────────────────
--  HIDE NATIVE ROBLOX GUI
--  Must wait a moment before calling SetCore — it errors if CoreGui
--  hasn't fully loaded yet. We retry until it succeeds.
-- ─────────────────────────────────────────────────────────────────────
local function nukeRobloxGui()
    -- Hide every CoreGui category
    for _, t in ipairs({
        Enum.CoreGuiType.All,
        Enum.CoreGuiType.Chat,
        Enum.CoreGuiType.Backpack,
        Enum.CoreGuiType.Health,
        Enum.CoreGuiType.PlayerList,
        Enum.CoreGuiType.EmotesMenu,
        Enum.CoreGuiType.SelfView,
    }) do
        pcall(StarterGui.SetCoreGuiEnabled, StarterGui, t, false)
    end
    -- Hide the topbar pill (menu + voice chat icons)
    pcall(StarterGui.SetCore, StarterGui, "TopbarEnabled", false)
end

-- Retry loop — keeps calling until SetCore stops erroring
task.spawn(function()
    for _ = 1, 60 do        -- try for up to ~6 seconds
        nukeRobloxGui()
        task.wait(0.1)
    end
    -- Then re-apply every 5 s indefinitely (some games re-enable it)
    while true do
        nukeRobloxGui()
        task.wait(5)
    end
end)

-- Also re-apply on respawn
LP.CharacterAdded:Connect(function()
    task.wait(0.2)
    nukeRobloxGui()
end)

