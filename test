-- ── Slider helper: set knob position from a 0–1 ratio ───────
local function setSliderRatio(ratio)
    ratio = math.clamp(ratio, 0, 1)
    -- knob X position along the track (pixels)
    local px = ratio * TRACK_W
    knob.Position = UDim2.new(0, px, 0.5, 0)
    sliderFill.Size = UDim2.new(0, px, 1, 0)
    -- map ratio → speed value
    ANIM_DURATION = SPEED_MIN + ratio * (SPEED_MAX - SPEED_MIN)
    speedValueLabel.Text = string.format("%.1fs", ANIM_DURATION)
end

-- Initialise slider to default 1.0s
local defaultRatio = (1.0 - SPEED_MIN) / (SPEED_MAX - SPEED_MIN)
setSliderRatio(defaultRatio)

-- ── Slider drag ─────────────────────────────────────────────
local slidingKnob = false

knob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = true
    end
end)

knob.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = false
    end
end)

-- Also allow clicking anywhere on the track to jump
sliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = true
        local trackAbsPos = sliderTrack.AbsolutePosition.X
        local ratio = (input.Position.X - trackAbsPos) / TRACK_W
        setSliderRatio(ratio)
    end
end)

sliderTrack.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = false
    end
end)

-- ============================================================
--  DRAG LOGIC  (title bar)
-- ============================================================
local dragging = false
local dragStartPos
local frameStartPos

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStartPos = input.Position
        frameStartPos = frame.Position
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        -- Handle frame drag
        if dragging then
            local delta = input.Position - dragStartPos
            frame.Position = UDim2.new(
                frameStartPos.X.Scale,
                frameStartPos.X.Offset + delta.X,
                frameStartPos.Y.Scale,
                frameStartPos.Y.Offset + delta.Y
            )
        end
        -- Handle slider drag
        if slidingKnob then
            local trackAbsPos = sliderTrack.AbsolutePosition.X
            local ratio = (input.Position.X - trackAbsPos) / TRACK_W
            setSliderRatio(ratio)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        slidingKnob = false
        dragging = false
    end
end)

-- ============================================================
--  BUTTON / INPUT LOGIC
-- ============================================================
local function triggerPlay()
    if isPlaying then
        statusLabel.Text = "⏳ Already playing — close to stop"
        return
    end
    local input = textBox.Text
    if input == "" then
        statusLabel.Text = "⚠ Please type something first!"
        return
    end
    statusLabel.Text = '▶ "' .. input .. '"'
    playButton.BackgroundColor3 = Color3.fromRGB(50, 50, 140)
    task.spawn(function()
        playAnimationsForText(input)
        statusLabel.Text = '✔ Done: "' .. input .. '"'
        playButton.BackgroundColor3 = Color3.fromRGB(80, 80, 200)
    end)
end

-- Enter key (two methods for reliability)
textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then triggerPlay() end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Return and textBox:IsFocused() then
        triggerPlay()
    end
end)

-- Play button
playButton.MouseButton1Click:Connect(triggerPlay)

playButton.MouseEnter:Connect(function()
    if not isPlaying then playButton.BackgroundColor3 = Color3.fromRGB(100, 100, 230) end
end)
playButton.MouseLeave:Connect(function()
    if not isPlaying then playButton.BackgroundColor3 = Color3.fromRGB(80, 80, 200) end
end)

