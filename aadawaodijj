--// Sonic

--// SERVICES
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

--// =========================
--// CONFIG
--// =========================

-- Default Animation IDs
local TRANSFORM_ID = 112109141479594
local IDLE_ID = 0
local WALK_ID = 118320322718866
local SPRINT_ID = 76931637880681
local JUMP_ID = 119889021060156
local CLICK_ID = 0

-- Alternate Animation IDs
local ALT_IDLE_ID = 0
local ALT_WALK_ID = 0
local ALT_SPRINT_ID = 0
local ALT_JUMP_ID = 110340154189809
local ALT_TRANSFORM_ID = 0

-- T/Y/U Loop Emotes
local T_ID = 0
local Y_ID = 0
local U_ID = 0

-- Movement Speeds
local BASE_WALK_SPEED = 100
local SPRINT_SPEED = 300

-- Animation Speeds
local TRANSFORM_SPEED = 1
local IDLE_SPEED = 1
local WALK_SPEED_MULTIPLIER = 1
local SPRINT_SPEED_MULTIPLIER = 2
local JUMP_SPEED = 1
local CLICK_SPEED = 1

-- Transform Duration
local TRANSFORM_DURATION = 8

--// =========================
--// INTERNAL
--// =========================

local tracks = {}
local currentState = "None"
local transformed = false
local sprinting = false

local useAltIdle = false
local useAltWalk = false
local useAltSprint = false
local useAltJump = false

--// =========================

local function valid(id)
	return id and id ~= 0
end

local function stopAll()
	for _, track in pairs(tracks) do
		if track then
			track:Stop(0.15)
			track:Destroy()
		end
	end
	tracks = {}
end

local function load(id, looped, priority)
	if not valid(id) then return nil end

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. id

	local track = humanoid:LoadAnimation(anim)
	track.Looped = looped or false
	track.Priority = priority or Enum.AnimationPriority.Movement

	return track
end

--// =========================
--// STATE SYSTEM
--// =========================

local function playIdle()
	local id = useAltIdle and ALT_IDLE_ID or IDLE_ID
	if not valid(id) then return end

	stopAll()

	tracks.idle = load(id, true)
	tracks.idle:Play()
	tracks.idle:AdjustSpeed(IDLE_SPEED)

	currentState = "Idle"
end

local function playWalk()
	local id = useAltWalk and ALT_WALK_ID or WALK_ID
	if not valid(id) then return end

	stopAll()

	tracks.walk = load(id, true)
	tracks.walk:Play()
	tracks.walk:AdjustSpeed(WALK_SPEED_MULTIPLIER)

	currentState = "Walk"
end

local function playSprint()
	local id = useAltSprint and ALT_SPRINT_ID or SPRINT_ID
	if not valid(id) then return end

	stopAll()

	tracks.sprint = load(id, true)
	tracks.sprint:Play()
	tracks.sprint:AdjustSpeed(SPRINT_SPEED_MULTIPLIER)

	currentState = "Sprint"
end

local function refresh()
	if not transformed then return end
	if humanoid:GetState() == Enum.HumanoidStateType.Freefall then return end

	if humanoid.MoveDirection.Magnitude == 0 then
		playIdle()
	else
		if sprinting then
			playSprint()
		else
			playWalk()
		end
	end
end

--// =========================
--// TRANSFORMATION
--// =========================

local function transform()
	local id = ALT_TRANSFORM_ID ~= 0 and ALT_TRANSFORM_ID or TRANSFORM_ID
	if not valid(id) then
		transformed = true
		refresh()
		return
	end

	stopAll()

	tracks.transform = load(id, false, Enum.AnimationPriority.Action)
	tracks.transform:Play()
	tracks.transform:AdjustSpeed(TRANSFORM_SPEED)

	task.wait(TRANSFORM_DURATION)

	transformed = true
	refresh()
end

--// =========================
--// JUMP
--// =========================

humanoid.StateChanged:Connect(function(_, new)
	if not transformed then return end

	if new == Enum.HumanoidStateType.Jumping then
		local id = useAltJump and ALT_JUMP_ID or JUMP_ID
		if not valid(id) then return end

		stopAll()

		tracks.jump = load(id, false, Enum.AnimationPriority.Action)
		tracks.jump:Play()
		tracks.jump:AdjustSpeed(JUMP_SPEED)

	elseif new == Enum.HumanoidStateType.Landed then
		refresh()
	end
end)

--// =========================
--// CLICK
--// =========================

UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if not transformed then return end

	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		local id = CLICK_ID
		if not valid(id) then return end

		stopAll()

		tracks.click = load(id, false, Enum.AnimationPriority.Action)
		tracks.click:Play()
		tracks.click:AdjustSpeed(CLICK_SPEED)

		tracks.click.Stopped:Connect(function()
			refresh()
		end)
	end
end)

--// =========================
--// MOVEMENT LISTENER
--// =========================

humanoid:GetPropertyChangedSignal("MoveDirection"):Connect(function()
	if currentState ~= "Jump" then
		refresh()
	end
end)

--// =========================
--// SPRINT
--// =========================

UserInputService.InputBegan:Connect(function(input,gpe)
	if gpe then return end

	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = true
		humanoid.WalkSpeed = SPRINT_SPEED
		refresh()
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = false
		humanoid.WalkSpeed = BASE_WALK_SPEED
		refresh()
	end
end)

--// =========================
--// T Y U LOOP EMOTES
--// =========================

local function loopEmote(id)
	if not valid(id) then return end

	stopAll()

	local track = load(id, true, Enum.AnimationPriority.Action)
	track:Play()
	tracks.emote = track
end

UserInputService.InputBegan:Connect(function(input,gpe)
	if gpe then return end

	if input.KeyCode == Enum.KeyCode.T then
		loopEmote(T_ID)
	elseif input.KeyCode == Enum.KeyCode.Y then
		loopEmote(Y_ID)
	elseif input.KeyCode == Enum.KeyCode.U then
		loopEmote(U_ID)
	end
end)

-- Cancel loop on movement
humanoid:GetPropertyChangedSignal("MoveDirection"):Connect(function()
	if tracks.emote and humanoid.MoveDirection.Magnitude > 0 then
		stopAll()
		refresh()
	end
end)

--// =========================
--// TOGGLES G H J K
--// =========================

UserInputService.InputBegan:Connect(function(input,gpe)
	if gpe then return end

	if input.KeyCode == Enum.KeyCode.G then
		useAltWalk = not useAltWalk
	elseif input.KeyCode == Enum.KeyCode.H then
		useAltSprint = not useAltSprint
	elseif input.KeyCode == Enum.KeyCode.J then
		useAltIdle = not useAltIdle
	elseif input.KeyCode == Enum.KeyCode.K then
		useAltJump = not useAltJump
	end

	refresh()
end)

--// =========================
--// INIT
--// =========================

humanoid.WalkSpeed = BASE_WALK_SPEED
transform()
