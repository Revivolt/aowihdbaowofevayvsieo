--// FULL TRANSFORMATION CONTROLLER (SAFE VERSION)

-----------------------------
-- CONFIG
-----------------------------

-- DEFAULT ANIMATIONS
local TRANSFORMATION_ID = 110574635021740
local IDLE_ID = 138503654818181
local WALK_ID = 96819546392344
local SPRINT_ID = 83065934116885
local JUMP_ID = 0
local M1_ID = 0

-- ALTERNATE ANIMATIONS
local ALT_IDLE_ID = 0
local ALT_WALK_ID = 109318260839099
local ALT_SPRINT_ID = 0
local ALT_JUMP_ID = 0
local ALT_M1_ID = 0

-- EMOTES (movement cancels)
local EMOTE_T_ID = 0
local EMOTE_Y_ID = 0
local EMOTE_U_ID = 0

-- TIMING
local TRANSFORMATION_DURATION = 8

-- MOVEMENT SPEEDS
local BASE_WALK_SPEED = 7
local SPRINT_SPEED = 30

-- ANIMATION SPEEDS
local TRANSFORM_ANIM_SPEED = 1
local IDLE_ANIM_SPEED = 1
local WALK_ANIM_SPEED = 1
local SPRINT_ANIM_SPEED = 4
local JUMP_ANIM_SPEED = 1
local M1_ANIM_SPEED = 1

-----------------------------
-- SERVICES
-----------------------------

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local animator = humanoid:WaitForChild("Animator")

-----------------------------
-- STATE VARIABLES
-----------------------------

local transformed = false
local sprinting = false

local useAltWalk = false
local useAltSprint = false
local useAltIdle = false
local useAltJump = false
local useAltM1 = false

local currentTrack
local emoteTrack
local actionLocked = false

-----------------------------
-- SAFETY CHECK
-----------------------------

local function isValidId(id)
	return typeof(id) == "number" and id > 0
end

-----------------------------
-- PLAY ANIMATION
-----------------------------

local function playAnimation(assetId, looped, speed)
	if not isValidId(assetId) then
		return
	end

	if currentTrack then
		currentTrack:Stop()
		currentTrack:Destroy()
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. tostring(assetId)

	currentTrack = animator:LoadAnimation(anim)
	currentTrack.Priority = Enum.AnimationPriority.Action
	currentTrack.Looped = looped
	currentTrack:Play()

	if speed then
		currentTrack:AdjustSpeed(speed)
	end
end

local function stopEmote()
	if emoteTrack then
		emoteTrack:Stop()
		emoteTrack:Destroy()
		emoteTrack = nil
	end
end

-----------------------------
-- STATE FUNCTIONS
-----------------------------

local function playIdle()
	if emoteTrack or actionLocked then return end
	
	local idleAnim = IDLE_ID
	if useAltIdle and isValidId(ALT_IDLE_ID) then
		idleAnim = ALT_IDLE_ID
	end

	playAnimation(idleAnim, true, IDLE_ANIM_SPEED)
end

local function playWalk()
	if emoteTrack or actionLocked then return end
	
	local walkAnim = WALK_ID
	if useAltWalk and isValidId(ALT_WALK_ID) then
		walkAnim = ALT_WALK_ID
	end

	playAnimation(walkAnim, true, WALK_ANIM_SPEED)
end

local function playSprint()
	if emoteTrack or actionLocked then return end
	
	local sprintAnim = SPRINT_ID
	if useAltSprint and isValidId(ALT_SPRINT_ID) then
		sprintAnim = ALT_SPRINT_ID
	end

	playAnimation(sprintAnim, true, SPRINT_ANIM_SPEED)
end

local function playJump()
	actionLocked = true
	
	local jumpAnim = JUMP_ID
	if useAltJump and isValidId(ALT_JUMP_ID) then
		jumpAnim = ALT_JUMP_ID
	end

	playAnimation(jumpAnim, false, JUMP_ANIM_SPEED)
end

local function playM1()
	if actionLocked then return end
	actionLocked = true
	
	local m1Anim = M1_ID
	if useAltM1 and isValidId(ALT_M1_ID) then
		m1Anim = ALT_M1_ID
	end

	playAnimation(m1Anim, false, M1_ANIM_SPEED)

	if currentTrack then
		currentTrack.Stopped:Connect(function()
			actionLocked = false
			
			if humanoid.MoveDirection.Magnitude > 0 then
				if sprinting then
					playSprint()
				else
					playWalk()
				end
			else
				playIdle()
			end
		end)
	end
end

-----------------------------
-- TRANSFORMATION
-----------------------------

local function playTransformation()
	if isValidId(TRANSFORMATION_ID) then
		playAnimation(TRANSFORMATION_ID, false, TRANSFORM_ANIM_SPEED)
	end

	transformed = true
	humanoid.WalkSpeed = BASE_WALK_SPEED

	task.delay(TRANSFORMATION_DURATION, function()
		if transformed then
			playIdle()
		end
	end)
end

-----------------------------
-- MOVEMENT
-----------------------------

humanoid.Running:Connect(function(speed)
	if not transformed or actionLocked then return end
	
	if speed > 0 then
		stopEmote()
		if sprinting then
			playSprint()
		else
			playWalk()
		end
	else
		playIdle()
	end
end)

-----------------------------
-- JUMP DETECTION
-----------------------------

humanoid.StateChanged:Connect(function(_, new)
	if not transformed then return end
	
	if new == Enum.HumanoidStateType.Jumping then
		playJump()
	elseif new == Enum.HumanoidStateType.Landed then
		actionLocked = false
		
		if humanoid.MoveDirection.Magnitude > 0 then
			playWalk()
		else
			playIdle()
		end
	end
end)

-----------------------------
-- EMOTE FUNCTION (T/Y/U)
-----------------------------

local function playLoopEmote(assetId)
	if not isValidId(assetId) then return end
	
	stopEmote()

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. tostring(assetId)

	emoteTrack = animator:LoadAnimation(anim)
	emoteTrack.Priority = Enum.AnimationPriority.Action
	emoteTrack.Looped = true
	emoteTrack:Play()
end

-----------------------------
-- INPUT
-----------------------------

UserInputService.InputBegan:Connect(function(input, gp)
	if gp or not transformed then return end

	-- Sprint Hold
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = true
		humanoid.WalkSpeed = SPRINT_SPEED
	end

	-- Left Click
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		playM1()
	end

	-- Toggle Alternates
	if input.KeyCode == Enum.KeyCode.G then
		useAltWalk = not useAltWalk
	end

	if input.KeyCode == Enum.KeyCode.H then
		useAltSprint = not useAltSprint
	end

	if input.KeyCode == Enum.KeyCode.J then
		useAltIdle = not useAltIdle
	end

	if input.KeyCode == Enum.KeyCode.K then
		useAltJump = not useAltJump
	end

	if input.KeyCode == Enum.KeyCode.L then
		useAltM1 = not useAltM1
	end

	-- Loop Emotes (cancel on movement)
	if input.KeyCode == Enum.KeyCode.T then
		playLoopEmote(EMOTE_T_ID)
	end

	if input.KeyCode == Enum.KeyCode.Y then
		playLoopEmote(EMOTE_Y_ID)
	end

	if input.KeyCode == Enum.KeyCode.U then
		playLoopEmote(EMOTE_U_ID)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.LeftShift then
		sprinting = false
		humanoid.WalkSpeed = BASE_WALK_SPEED
	end
end)

-----------------------------
-- START
-----------------------------

playTransformation()
